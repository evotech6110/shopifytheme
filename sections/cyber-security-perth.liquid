<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is cyber security for small business in Perth?","acceptedAnswer":{"@type":"Answer","text":"Small business cyber security in Perth means implementing the right combination of tools, processes and training to protect your business from ransomware, phishing, data breaches and business email compromise. EvoTech Digital provides affordable, layered cyber security solutions tailored for Perth SMBs."}},
    {"@type":"Question","name":"What is MDR and do Perth small businesses need it?","acceptedAnswer":{"@type":"Answer","text":"Managed Detection and Response (MDR) is a 24/7 cyber security service where a team of analysts monitors your systems, detects threats in real time, and responds before damage occurs. Perth SMBs absolutely benefit from MDR because attackers often strike outside business hours and most small businesses lack the in-house expertise to detect advanced threats."}},
    {"@type":"Question","name":"What is the Essential Eight and is it mandatory in Australia?","acceptedAnswer":{"@type":"Answer","text":"The Essential Eight is a set of eight cyber security controls developed by the Australian Signals Directorate (ASD). It is mandatory for Australian government entities and is strongly recommended for all Australian businesses. Only 22% of Australian organisations currently meet Maturity Level 2 — the baseline target — leaving most businesses exposed."}},
    {"@type":"Question","name":"How much does a cyber security audit cost in Perth?","acceptedAnswer":{"@type":"Answer","text":"A cyber security audit in Perth can range from a free initial assessment to several thousand dollars for a comprehensive penetration test and compliance report. EvoTech Digital offers a free introductory security health check for Perth businesses. Contact us to book yours."}},
    {"@type":"Question","name":"What cyber threats are Perth businesses facing in 2026?","acceptedAnswer":{"@type":"Answer","text":"In 2026, Perth businesses face AI-powered phishing, ransomware-as-a-service, business email compromise (BEC), supply chain attacks and identity-based threats. The average cost of a cyber incident for an Australian small business rose to $56,600 in 2024-25 (ASD Annual Cyber Threat Report). Proactive defences including MDR, MFA and employee training are essential."}}
  ]
}
</script>

<style>
  /* ═══════════════════════════════════════════════════
     EVOTECH CYBER SECURITY PAGE — DESIGN SYSTEM
     Inherits brand from Managed IT page + adds:
     --cyber-red: #e63946  (threat / alert accent)
     --cyber-amber: #f4a261 (warning accent)
  ═══════════════════════════════════════════════════ */

  .evo-page { font-family: var(--body-font); color: #5e6979; background: #fff; }

  /* ── Shared variables ─────────────────────── */
  :root {
    --cyber-red: #e63946;
    --cyber-red-soft: rgba(230,57,70,0.10);
    --cyber-amber: #f4a261;
  }

  /* ── ANNOUNCE BAR ─────────────────────────── */
  .evo-announce {
    background: #e63946;
    color: #fff;
    text-align: center;
    padding: 10px 20px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .evo-announce a { color: #fff; text-decoration: underline; }
  .evo-announce strong { color: #fff; }

  /* ── HERO ─────────────────────────────────── */
  .evo-hero {
    background: #0a1628;
    position: relative;
    overflow: hidden;
    padding: 80px 0 70px;
  }
  /* Animated threat grid background */
  .evo-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(230,57,70,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(230,57,70,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .evo-hero::after {
    content: '';
    position: absolute;
    top: -80px; right: -120px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(207,243,148,0.07) 0%, transparent 60%);
    pointer-events: none;
  }
  .evo-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .evo-hero__eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    color: #e63946;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; margin-bottom: 18px;
  }
  .evo-hero__eyebrow::before {
    content: ''; display: inline-block; width: 24px; height: 2px;
    background: #e63946; flex-shrink: 0;
  }
  .evo-hero h1 {
    font-family: var(--heading-font);
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    font-weight: 700; color: #fff; line-height: 1.13; margin-bottom: 20px;
  }
  .evo-hero h1 span { color: #cff394; }
  .evo-hero h1 em { font-style: normal; color: #e63946; }
  .evo-hero__lead { font-size: 1.05rem; color: #c5d3e8; line-height: 1.75; margin-bottom: 28px; }

  /* Threat stat bar */
  .evo-threat-bar {
    background: rgba(230,57,70,0.1);
    border: 1px solid rgba(230,57,70,0.25);
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 28px;
    display: flex; align-items: center; gap: 12px;
    font-size: 0.87rem; color: #e8c8cb;
  }
  .evo-threat-bar strong { color: #ff6b76; }
  .evo-threat-bar__icon { font-size: 1.2rem; flex-shrink: 0; }

  .evo-hero__actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px; }
  .evo-btn-red {
    display: inline-flex; align-items: center; gap: 7px;
    background: #e63946; color: #fff;
    padding: 14px 28px; border-radius: var(--button-border-radius, 6px);
    font-weight: 700; font-size: 0.93rem; text-decoration: none;
    transition: background 0.2s, transform 0.2s; border: none;
  }
  .evo-btn-red:hover { background: #c8303c; transform: translateY(-2px); text-decoration: none; color: #fff; }
  .evo-btn-lime {
    display: inline-flex; align-items: center; gap: 7px;
    background: #cff394; color: #0e2240;
    padding: 14px 28px; border-radius: var(--button-border-radius, 6px);
    font-weight: 700; font-size: 0.93rem; text-decoration: none;
    transition: background 0.2s, transform 0.2s; border: none;
  }
  .evo-btn-lime:hover { background: #b8e87c; transform: translateY(-2px); text-decoration: none; color: #0e2240; }
  .evo-btn-outline-white {
    display: inline-flex; align-items: center; gap: 7px;
    background: transparent; color: #fff;
    padding: 13px 28px; border-radius: var(--button-border-radius, 6px);
    font-weight: 600; font-size: 0.93rem; text-decoration: none;
    border: 1.5px solid rgba(255,255,255,0.3); transition: border-color 0.2s, color 0.2s;
  }
  .evo-btn-outline-white:hover { border-color: #cff394; color: #cff394; text-decoration: none; }

  .evo-hero__pills {
    display: flex; gap: 10px; flex-wrap: wrap;
    padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08);
  }
  .evo-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(207,243,148,0.08);
    border: 1px solid rgba(207,243,148,0.18);
    border-radius: 50px; padding: 7px 14px;
    font-size: 0.8rem; font-weight: 600; color: #d8f0b0;
  }
  .evo-pill::before { content: '✓'; color: #cff394; font-weight: 700; }

  /* Hero — threat dashboard visual */
  .evo-threat-vis {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(230,57,70,0.2);
    border-radius: 14px; padding: 28px;
  }
  .evo-vis-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }
  .evo-vis-title { font-size: 0.75rem; font-weight: 700; color: rgba(230,57,70,0.8); text-transform: uppercase; letter-spacing: 0.1em; }
  .evo-vis-live {
    display: flex; align-items: center; gap: 5px;
    font-size: 0.72rem; font-weight: 600; color: #6ee07a;
  }
  .evo-threat-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #e63946; box-shadow: 0 0 8px #e63946;
    animation: cyberPulse 1.5s infinite;
  }
  .evo-threat-dot--ok { background: #6ee07a; box-shadow: 0 0 8px #6ee07a; }
  @keyframes cyberPulse { 0%,100%{opacity:1} 50%{opacity:.3} }
  .evo-threat-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 11px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 0.86rem;
  }
  .evo-threat-row:last-child { border-bottom: none; }
  .evo-threat-lbl { color: #8fa5bf; }
  .evo-threat-val-ok    { color: #6ee07a; font-weight: 600; }
  .evo-threat-val-warn  { color: #f4a261; font-weight: 600; }
  .evo-threat-val-alert { color: #e63946; font-weight: 600; }
  .evo-threat-val       { color: #e8f0fa; font-weight: 600; }
  .evo-threat-stat {
    margin-top: 20px; padding: 14px;
    background: rgba(230,57,70,0.08);
    border: 1px solid rgba(230,57,70,0.2); border-radius: 8px;
    text-align: center;
  }
  .evo-threat-stat__num { font-family: var(--heading-font); font-size: 1.7rem; font-weight: 700; color: #ff6b76; line-height: 1; }
  .evo-threat-stat__desc { font-size: 0.76rem; color: #8fa5bf; margin-top: 4px; line-height: 1.4; }

  /* ── TRUST BAR ────────────────────────────── */
  .evo-trust-bar {
    background: #f8f9fd;
    border-top: 1px solid #e2e4e8; border-bottom: 1px solid #e2e4e8;
    padding: 22px 0;
  }
  .evo-trust-bar__inner { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .evo-trust-bar__label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: #9aa3b0; white-space: nowrap; padding-right: 12px; border-right: 1px solid #e2e4e8; }
  .evo-trust-logos { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .evo-trust-badge { background: #fff; border: 1px solid #e2e4e8; border-radius: 6px; padding: 7px 16px; font-size: 0.8rem; font-weight: 700; color: #0e2240; white-space: nowrap; }

  /* ── SECTION HEADERS ──────────────────────── */
  .evo-section-head { text-align: center; max-width: 700px; margin: 0 auto 56px; }
  .evo-badge {
    display: inline-block; padding: 4px 14px; border-radius: 50px;
    border: 1.5px solid #0e2240; color: #0e2240;
    font-size: 0.73rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 16px;
  }
  .evo-badge--red  { border-color: #c8303c; background: var(--cyber-red-soft); color: #c8303c; }
  .evo-badge--lime { border-color: #5c7d26; background: rgba(207,243,148,0.15); color: #3a5a10; }
  .evo-badge--white { border-color: rgba(255,255,255,0.35); color: #fff; background: rgba(255,255,255,0.07); }
  .evo-section-head h2 { font-family: var(--heading-font); font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 700; color: #0e2240; line-height: 1.2; }
  .evo-section-head--light h2 { color: #fff; }
  .evo-section-head p { margin-top: 14px; font-size: 1rem; line-height: 1.7; color: #5e6979; }
  .evo-section-head--light p { color: #b8cce0; }

  /* ── THREAT REALITY SECTION ───────────────── */
  .evo-threats { background: #fff; padding: 88px 0; }
  .evo-threats__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .evo-threat-card {
    background: #fff; border: 1px solid #e2e4e8; border-radius: 10px;
    padding: 28px; transition: all 0.25s; position: relative; overflow: hidden;
  }
  .evo-threat-card::before {
    content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: var(--cyber-red); transform: scaleX(0); transform-origin: left; transition: transform 0.25s;
  }
  .evo-threat-card:hover { box-shadow: 0 8px 32px rgba(230,57,70,0.08); transform: translateY(-3px); }
  .evo-threat-card:hover::before { transform: scaleX(1); }
  .evo-threat-card__icon { font-size: 1.6rem; margin-bottom: 14px; display: block; }
  .evo-threat-card h3 { font-family: var(--heading-font); font-size: 1rem; font-weight: 700; color: #0e2240; margin-bottom: 8px; }
  .evo-threat-card p { font-size: 0.87rem; line-height: 1.65; color: #5e6979; margin: 0; }
  .evo-threat-card__stat {
    margin-top: 14px; padding: 10px 12px;
    background: var(--cyber-red-soft);
    border-radius: 6px; font-size: 0.8rem;
    color: #c8303c; font-weight: 600;
  }

  /* ── SERVICES GRID ────────────────────────── */
  .evo-services { padding: 88px 0; background: #f8f9fd; }
  .evo-services__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .evo-service-card {
    background: #fff; border: 1px solid #e2e4e8; border-radius: 10px;
    padding: 30px 28px; transition: all 0.28s; position: relative; overflow: hidden;
  }
  .evo-service-card::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
    background: #cff394; transform: scaleX(0); transform-origin: left; transition: transform 0.28s;
  }
  .evo-service-card:hover { box-shadow: 0 8px 32px rgba(14,34,64,0.09); transform: translateY(-3px); border-color: #c4d8a4; }
  .evo-service-card:hover::after { transform: scaleX(1); }
  .evo-service-icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: #f0f8e8; border: 1px solid #d6f0b0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; margin-bottom: 18px; flex-shrink: 0;
  }
  .evo-service-card h3 { font-family: var(--heading-font); font-size: 1.05rem; font-weight: 700; color: #0e2240; margin-bottom: 10px; line-height: 1.3; }
  .evo-service-card p { font-size: 0.88rem; line-height: 1.65; color: #5e6979; margin: 0; }
  .evo-service-link {
    display: inline-flex; align-items: center; gap: 5px; margin-top: 18px;
    font-size: 0.85rem; font-weight: 700; color: #0e2240; text-decoration: none; transition: gap 0.2s, color 0.2s;
  }
  .evo-service-link:hover { gap: 9px; color: #5c7d26; text-decoration: none; }

  /* ── MDR DEEP DIVE ────────────────────────── */
  .evo-mdr { background: #0e2240; padding: 88px 0; }
  .evo-mdr__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .evo-mdr__content h2 { font-family: var(--heading-font); font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 700; color: #fff; line-height: 1.2; margin-bottom: 16px; }
  .evo-mdr__content h2 span { color: #cff394; }
  .evo-mdr__content p { color: #b8cce0; font-size: 1rem; line-height: 1.7; }
  .evo-mdr__points { display: flex; flex-direction: column; gap: 16px; margin-top: 28px; }
  .evo-mdr-point {
    display: flex; gap: 14px; align-items: flex-start;
    background: rgba(255,255,255,0.05); border: 1px solid rgba(207,243,148,0.12);
    border-radius: 10px; padding: 18px;
  }
  .evo-mdr-point__icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 2px; }
  .evo-mdr-point h4 { font-family: var(--heading-font); font-size: 0.95rem; font-weight: 700; color: #fff; margin-bottom: 4px; }
  .evo-mdr-point p { font-size: 0.85rem; color: #8fa5bf; line-height: 1.55; margin: 0; }

  /* MDR vs Traditional table */
  .evo-mdr__comparison {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(207,243,148,0.15);
    border-radius: 14px; padding: 30px;
  }
  .evo-compare-title { font-family: var(--heading-font); font-size: 0.8rem; font-weight: 700; color: rgba(207,243,148,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 20px; }
  .evo-compare-row {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 0.84rem; gap: 8px; align-items: center;
  }
  .evo-compare-row:last-child { border-bottom: none; }
  .evo-compare-row--head .evo-col { font-weight: 700; color: rgba(255,255,255,0.5); font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .evo-col { color: #8fa5bf; }
  .evo-col--feat { color: #c5d3e8; font-weight: 600; }
  .evo-col--yes { color: #6ee07a; font-weight: 700; text-align: center; }
  .evo-col--no  { color: rgba(255,255,255,0.25); text-align: center; }
  .evo-col--mid { color: #f4a261; font-weight: 600; text-align: center; }

  /* ── ESSENTIAL EIGHT ──────────────────────── */
  .evo-e8 { background: #fff; padding: 88px 0; }
  .evo-e8__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start; }
  .evo-e8__intro h2 { font-family: var(--heading-font); font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 700; color: #0e2240; line-height: 1.2; margin-bottom: 16px; }
  .evo-e8__intro p { font-size: 1rem; line-height: 1.7; margin-bottom: 16px; }
  .evo-e8-stat {
    display: flex; gap: 16px; align-items: flex-start; margin-top: 24px;
    background: var(--cyber-red-soft);
    border: 1px solid rgba(230,57,70,0.2); border-radius: 10px; padding: 20px;
  }
  .evo-e8-stat__num { font-family: var(--heading-font); font-size: 2.4rem; font-weight: 700; color: #e63946; line-height: 1; }
  .evo-e8-stat__text h4 { font-family: var(--heading-font); font-size: 0.95rem; font-weight: 700; color: #0e2240; margin-bottom: 4px; }
  .evo-e8-stat__text p { font-size: 0.84rem; margin: 0; }
  .evo-e8-cta-box {
    background: #0e2240; border-radius: 10px; padding: 24px;
    margin-top: 24px;
  }
  .evo-e8-cta-box p { color: #b8cce0; font-size: 0.9rem; margin-bottom: 14px; }

  .evo-e8__controls { display: flex; flex-direction: column; gap: 12px; }
  .evo-e8-control {
    background: #f8f9fd; border: 1px solid #e2e4e8; border-radius: 10px; padding: 18px 20px;
    display: flex; gap: 14px; align-items: flex-start; transition: all 0.2s;
  }
  .evo-e8-control:hover { border-color: #cff394; background: #f0f8e8; }
  .evo-e8-num {
    width: 32px; height: 32px; border-radius: 6px; flex-shrink: 0;
    background: #0e2240; color: #cff394;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--heading-font); font-size: 0.85rem; font-weight: 700;
  }
  .evo-e8-control h4 { font-family: var(--heading-font); font-size: 0.93rem; font-weight: 700; color: #0e2240; margin-bottom: 3px; }
  .evo-e8-control p { font-size: 0.82rem; line-height: 1.5; margin: 0; }

  /* ── EMPLOYEE TRAINING ────────────────────── */
  .evo-training { background: #f8f9fd; padding: 88px 0; }
  .evo-training__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .evo-training__content h2 { font-family: var(--heading-font); font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 700; color: #0e2240; line-height: 1.2; margin-bottom: 16px; }
  .evo-training__content p { font-size: 1rem; line-height: 1.7; margin-bottom: 16px; }
  .evo-training-steps { display: flex; flex-direction: column; gap: 14px; margin-top: 24px; }
  .evo-training-step {
    display: flex; gap: 14px; align-items: flex-start;
    background: #fff; border: 1px solid #e2e4e8; border-radius: 10px; padding: 18px;
    transition: border-color 0.2s;
  }
  .evo-training-step:hover { border-color: #cff394; }
  .evo-step-icon { font-size: 1.2rem; flex-shrink: 0; margin-top: 2px; }
  .evo-training-step h4 { font-family: var(--heading-font); font-size: 0.93rem; font-weight: 700; color: #0e2240; margin-bottom: 3px; }
  .evo-training-step p { font-size: 0.84rem; line-height: 1.55; margin: 0; }

  .evo-training__visual {
    background: #0e2240; border-radius: 14px; padding: 36px;
  }
  .evo-training-vis-title { font-size: 0.75rem; font-weight: 700; color: rgba(207,243,148,0.7); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 22px; }
  .evo-phishing-sim {
    display: flex; flex-direction: column; gap: 12px;
  }
  .evo-sim-bar { display: flex; flex-direction: column; gap: 5px; }
  .evo-sim-label { display: flex; justify-content: space-between; font-size: 0.8rem; color: #8fa5bf; }
  .evo-sim-track {
