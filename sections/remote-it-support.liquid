  </section>

  {%- comment -%} TRUST STRIP {%- endcomment -%}
  <div class="evo-trust-strip">
    <div class="ic-container">
      <div class="evo-trust-strip__inner">
        <div class="evo-trust-item"><strong>15 Min</strong><span>Response Target</span></div>
        <div class="evo-trust-item"><strong>Perth</strong><span>Local Team</span></div>
        <div class="evo-trust-item"><strong>24/7</strong><span>Monitoring</span></div>
        <div class="evo-trust-item"><strong>Fixed</strong><span>Monthly Pricing</span></div>
        <div class="evo-trust-item"><strong>No</strong><span>Lock-In Contracts</span></div>
      </div>
    </div>
