  {%- comment -%} FEATURES {%- endcomment -%}
  <section class="evo-section">
    <div class="ic-container">
      <div class="evo-section-head">
        <span class="evo-badge">Remote Support</span>
        <h2>Our Remote IT Support Services</h2>
        <p>Comprehensive solutions for Perth businesses — from initial consultation through to ongoing support and management.</p>
      </div>
      <div class="evo-feat-grid">
        
        <div class="evo-feat-card">
