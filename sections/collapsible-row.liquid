<div class="collapsible-row-wrapper color-{{ section.settings.color_scheme }} gradient-enabled">
  <div class="ic-container ic-py-13">
    {% if section.settings.heading != empty or section.settings.content != empty %}
      <div class="ic-flex {{ section.settings.text_position }}">
        <div class="ic-flex-col-12 {{ section.settings.text_width }}">
          <div class="richtext-container ic-text-{{ section.settings.alignment }}">
            {% if section.settings.heading != empty %}
              <h2 class="title">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.content != empty %}
              <p>{{ section.settings.content }}</p>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    <div class="ic-flex {{ section.settings.content_position }} collapsible-container">
      <div class="ic-flex-col-12 {{ section.settings.content_width }}">
        <div class="collapsible-group ic-text-{{ section.settings.content_alignment }}" data-behaviour="{{ section.settings.content_type }}">
          {% liquid
            for block in section.blocks
            case block.type
              when 'collapsible_content'
              if forloop.index == 1 and section.settings.first_collapsible
              assign collapse_state = 'true'
              else
              assign collapse_state = 'false'
              endif
              render 'collapsible-content', class: 'content-collapse', attr: block.shopify_attributes, collapse_state: collapse_state, toggle_text: block.settings.collapse_toggle, collapse_content: block.settings.collapse_content, specifications: nil
            endcase
            endfor
          %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "t:sections.collapsible_row.name",
    "tag": "section",
    "class": "collapsible-row-section",
    "settings": [
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:settings_schema.general.settings.color_scheme.label",
        "default": "scheme_1"
      },
      {
        "type": "text",
        "id": "heading",
        "label": "t:sections.collapsible_row.settings.heading.label",
        "default": "Collapsible heading"
      },
      {
        "type": "textarea",
        "id": "content",
        "label": "t:sections.collapsible_row.settings.content.label",
        "default": "Use this space to provide a brief overview or description that complements the section, helping users understand its content at a glance."
      },
      {
        "type": "text_alignment",
        "id": "alignment",
        "label": "t:sections.collapsible_row.settings.text_alignment.label",
        "default": "center"
      },
      {
        "type":"select",
        "id":"text_width",
        "options":[
            {
                "value":"ic-flex-col-lg-8",
                "label":"t:sections.collapsible_row.settings.text_width.option_1.label"
            },
            {
                "value":"ic-flex-col-lg-10",
                "label":"t:sections.collapsible_row.settings.text_width.option_2.label"
            },
            {
                "value":"ic-flex-col-lg-12",
                "label":"t:sections.collapsible_row.settings.text_width.option_3.label"
            }
        ],
        "default":"ic-flex-col-lg-8",
        "label":"t:sections.collapsible_row.settings.text_width.label",
        "info": "t:sections.collapsible_row.settings.text_width.info"
    },
    {
        "type":"select",
        "id":"text_position",
        "options":[
            {
                "value":"ic-justify-content-start",
                "label":"t:sections.collapsible_row.settings.text_position.option_1.label"
            },
            {
                "value":"ic-justify-content-center",
                "label":"t:sections.collapsible_row.settings.text_position.option_2.label"
            },
            {
                "value":"ic-justify-content-end",
                "label":"t:sections.collapsible_row.settings.text_position.option_3.label"
            }
        ],
        "default":"ic-justify-content-center",
        "label":"t:sections.collapsible_row.settings.text_position.label",
        "info": "t:sections.collapsible_row.settings.text_position.info"
    },
    {
      "type": "header",
      "content": "t:sections.collapsible_row.settings.collapsible_content.content"
    },
    {
      "type": "checkbox",
      "id": "first_collapsible",
      "label": "t:sections.collapsible_row.settings.collapsible_content.open_first.label",
      "default": true,
      "info": "t:sections.collapsible_row.settings.collapsible_content.open_first.info"
    },
    {
      "type": "select",
      "id": "content_type",
      "label": "t:sections.collapsible_row.settings.collapsible_options.label",
      "options": [
        {
        "value": "group",
        "label": "t:sections.collapsible_row.settings.collapsible_options.option_1.label"
        },
        {
          "value": "independent",
          "label": "t:sections.collapsible_row.settings.collapsible_options.option_2.label"
        }
      ],
      "default": "group",
      "info": "t:sections.collapsible_row.settings.collapsible_options.info"
    },
    {
      "type": "text_alignment",
      "id": "content_alignment",
      "label": "t:sections.collapsible_row.settings.text_alignment.label",
      "default": "left"
    },
    {
      "type":"select",
      "id":"content_width",
      "options":[
          {
              "value":"ic-flex-col-lg-8",
              "label":"t:sections.collapsible_row.settings.content_width.option_1.label"
          },
          {
              "value":"ic-flex-col-lg-10",
              "label":"t:sections.collapsible_row.settings.content_width.option_2.label"
          },
          {
              "value":"ic-flex-col-lg-12",
              "label":"t:sections.collapsible_row.settings.content_width.option_3.label"
          }
      ],
      "default":"ic-flex-col-lg-8",
      "label":"t:sections.collapsible_row.settings.content_width.label",
      "info": "t:sections.collapsible_row.settings.content_width.info"
    },
    {
        "type":"select",
        "id":"content_position",
        "options":[
            {
                "value":"ic-justify-content-start",
                "label":"t:sections.collapsible_row.settings.content_position.option_1.label"
            },
            {
                "value":"ic-justify-content-center",
                "label":"t:sections.collapsible_row.settings.content_position.option_2.label"
            },
            {
                "value":"ic-justify-content-end",
                "label":"t:sections.collapsible_row.settings.content_position.option_3.label"
            }
        ],
        "default":"ic-justify-content-center",
        "label":"t:sections.collapsible_row.settings.content_position.label",
        "info": "t:sections.collapsible_row.settings.content_position.info"
    }
    ],
    "blocks": [
      {
        "type": "collapsible_content",
        "name": "t:sections.collapsible_row.blocks.collapsible_content.name",
        "settings": [
          {
            "type": "text",
            "id": "collapse_toggle",
            "default": "Collapse heading",
            "label": "t:sections.collapsible_row.blocks.collapsible_content.settings.heading.label"
          },
          {
            "type": "richtext",
            "id": "collapse_content",
            "default": "<p>Use this text to provide additional details or explanations related to the title, offering clear information to your customers.</p>",
            "label": "t:sections.collapsible_row.blocks.collapsible_content.settings.content.label"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "t:sections.collapsible_row.name",
        "blocks": [
            {
                "type": "collapsible_content"
            },
            {
                "type": "collapsible_content"
            },
            {
                "type": "collapsible_content"
            }
        ]
      }
    ],
    "disabled_on": {
        "groups": ["*"]
    }
  }
{% endschema %}
