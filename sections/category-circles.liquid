{% endcomment %}

<style>
  .cat-nav-wrapper {
    padding: 60px 0;
    background: #ffffff;
  }
  .cat-nav-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .cat-nav-header h2 {
    font-size: 32px;
    font-weight: 800;
    color: #0f172a;
    margin: 0;
  }
  .cat-scroll-container {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    padding: 20px;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: #008060 #f1f1f1;
  }
  .cat-scroll-container::-webkit-scrollbar {
    height: 6px;
  }
  .cat-scroll-container::-webkit-scrollbar-track {
    background: #f1f1f1;
  }
  .cat-scroll-container::-webkit-scrollbar-thumb {
    background: #008060;
    border-radius: 10px;
  }

  .cat-circle-item {
    flex: 0 0 140px;
    text-align: center;
    text-decoration: none;
    transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .cat-circle-item:hover {
    transform: translateY(-10px);
  }

  .cat-circle-img-wrap {
    width: 120px;
    height: 120px;
    margin: 0 auto 15px;
    background: #fff;
    border-radius: 50%;
    padding: 10px;
    box-shadow: 0 10px 25px rgba(0,0,0,0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #f1f1f1;
    overflow: hidden;
  }
  .cat-circle-img-wrap img {
    width: 85%;
    height: auto;
    object-fit: contain;
  }

  .cat-circle-label {
    font-size: 13px;
    font-weight: 700;
    color: #475569;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.2;
  }
  
  @media (max-width: 768px) {
    .cat-circle-item { flex: 0 0 110px; }
    .cat-circle-img-wrap { width: 90px; height: 90px; }
    .cat-circle-label { font-size: 11px; }
  }
</style>

