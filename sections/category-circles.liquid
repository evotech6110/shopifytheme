{% comment %}
  Updated Category Navigation - 20 Premium IT Categories
  Next-Gen Horizontal Scroll / High-Density Grid responsive design.
  Theme: Dark Premium with 3D Iconography & Glow Effects.
{% endcomment %}

<style>
  :root {
    --cat-glow-green: #a3e635;
    --cat-bg-dark: #000000;
    --cat-card-bg: #0a0f1a;
    --cat-border: #1f2937;
  }

  .cat-nav-wrapper {
    padding: 80px 0;
    background: var(--cat-bg-dark);
    overflow: hidden;
    position: relative;
  }

  .cat-nav-header {
    margin-bottom: 50px;
    padding: 0 20px;
  }

  .cat-nav-header .sub-title {
    display: block;
    font-size: 13px;
    font-weight: 800;
    color: var(--cat-glow-green);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 12px;
  }

  .cat-nav-header h2 {
    font-size: 52px;
    font-weight: 800;
    color: #ffffff;
    margin: 0;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }

  .cat-nav-header h2 span.highlight {
    color: var(--cat-glow-green);
  }

  .cat-scroll-outer {
    position: relative;
  }

  .cat-scroll-container {
    display: flex;
    gap: 35px;
    overflow-x: auto;
    padding: 20px 0 40px;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .cat-scroll-container::-webkit-scrollbar {
    display: none;
  }

  .cat-circle-item {
    flex: 0 0 165px;
    text-align: left;
    text-decoration: none;
    transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
    position: relative;
  }

  .cat-circle-item:hover {
    transform: translateY(-12px);
  }

  .cat-circle-img-wrap {
    width: 145px;
    height: 145px;
    margin-bottom: 22px;
    background: var(--cat-card-bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--cat-border);
    position: relative;
    transition: all 0.5s ease;
    overflow: hidden;
  }

  .cat-circle-item:hover .cat-circle-img-wrap {
    border-color: var(--cat-glow-green);
    box-shadow: 0 0 30px rgba(163, 230, 53, 0.15);
    background: #0f172a;
  }

  .cat-circle-img-wrap img {
    width: 70%;
    height: auto;
    object-fit: contain;
    transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    z-index: 2;
    filter: drop-shadow(0 10px 15px rgba(0,0,0,0.3));
  }

  .cat-circle-item:hover .cat-circle-img-wrap img {
    transform: scale(1.15) rotate(4deg);
  }

  .cat-circle-img-wrap::after {
    content: '';
    position: absolute;
    top: 50%; left: 50%;
    width: 100%; height: 100%;
    background: radial-gradient(circle, var(--cat-glow-green), transparent 75%);
    transform: translate(-50%, -50%);
    opacity: 0;
    z-index: 1;
    transition: opacity 0.5s ease;
  }

  .cat-circle-item:hover .cat-circle-img-wrap::after {
    opacity: 0.12;
  }

  .cat-circle-content {
    display: block;
    padding-left: 8px;
  }

  .cat-circle-label {
    display: block;
    font-size: 16px;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 5px;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .cat-sku-count {
    display: block;
    font-size: 11px;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .cat-circle-item:hover .cat-sku-count {
    color: var(--cat-glow-green);
  }

  /* Navigation Arrows */
  .cat-nav-controls {
    margin-top: 20px;
    display: flex;
    gap: 12px;
  }

  .cat-nav-btn {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #0f172a;
    border: 1px solid var(--cat-border);
    color: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .cat-nav-btn:hover {
    background: #1e293b;
    border-color: var(--cat-glow-green);
    color: var(--cat-glow-green);
    transform: scale(1.05);
  }

  @media (max-width: 1024px) {
    .cat-nav-header h2 { font-size: 42px; }
  }

  @media (max-width: 768px) {
    .cat-nav-header h2 { font-size: 34px; }
    .cat-circle-item { flex: 0 0 140px; }
    .cat-circle-img-wrap { width: 120px; height: 120px; }
    .cat-circle-label { font-size: 14px; }
    .cat-nav-wrapper { padding: 60px 0; }
  }
</style>

<div class="cat-nav-wrapper">
  <div class="ic-container">
    <div class="cat-nav-header">
      <span class="sub-title">Shop by Category • 4,800+ SKUs</span>
      <h2>Explore <span class="highlight">expertise</span> categories.</h2>
    </div>
    
    <div class="cat-scroll-outer">
      <div id="CatScrollContainer" class="cat-scroll-container">
        
        {%- liquid
          # Taxonomy Map: "Full Display Name|Collection Handle|Icon Filename"
          # Handles are derived from create_smart_collections.py logic
          assign cat_list = "Networking - Routers & Gateways|networking-routers-gateways|networking_icons_3d_v2,Networking - Switches & Hubs|networking-switches-hubs|networking_icons_3d_v2,Networking - Wireless Access Points|networking-wireless-access-points|networking_icons_3d_v2,Networking - SFP & Transceivers|networking-sfp-transceivers|networking_icons_3d_v2,Networking - Cables & Interconnects|networking-cables-interconnects|networking_icons_3d_v2,Storage - NAS Systems|storage-nas-systems|nas_icon_3d,Storage - Enterprise HDDs|storage-enterprise-hdds|storage_circle_icon,Storage - High-Speed SSDs|storage-high-speed-ssds|storage_circle_icon,Computing - Laptops|computing-laptops|laptop_icon_3d,Computing - Desktops & Workstations|computing-desktops-workstations|laptop_icon_3d,Components - Processors (CPU)|components-processors-cpu|cpu_icon_3d_v2,Components - Motherboards|components-motherboards|motherboard_icon_3d,Components - Graphics Cards (GPU)|components-graphics-cards-gpu|gpu_icon_3d,Components - Memory (RAM)|components-memory-ram|ram_icon_3d,Peripherals - Monitors & Displays|peripherals-monitors-displays|monitor_icon_3d,Peripherals - Input Devices (KB/Mouse)|peripherals-input-devices-kb-mouse|peripherals_icon_3d,Smart Home - Security & CCTV|smarthome-security-cctv|security_icon_3d,Smart Home - Automation|smarthome-automation|security_icon_3d,Audio - Professional Gear|audio-professional-gear|peripherals_icon_3d,Infrastructure - Power & Racks|infrastructure-power-racks|networking_icons_3d_v2" | split: ","
          
          assign icon_base = "https://cdn.shopify.com/s/files/1/0784/2303/2025/files/"
        -%}

        {% for cat_item in cat_list %}
          {% assign details = cat_item | split: "|" %}
          {% assign display_name = details[0] | split: " - " | last %}
          {% assign handle = details[1] %}
          {% assign icon_name = details[2] %}
          
          {% comment %} Attempt to fetch dynamic SKU count if collection exists {% endcomment %}
          {% assign sku_count = collections[handle].products_count | default: 0 %}

          <a href="/collections/{{ handle }}" class="cat-circle-item" id="CatItem-{{ forloop.index }}">
            <div class="cat-circle-img-wrap">
              {% comment %} 
                Integration Note: We use existing high-fidelity icons where possible.
                User should upload the 20 new generated icons to match these names.
              {% endcomment %}
              <img src="{{ icon_base }}{{ icon_name }}.png" alt="{{ display_name }}" loading="lazy">
            </div>
            <div class="cat-circle-content">
              <span class="cat-circle-label">{{ display_name }}</span>
              <span class="cat-sku-count">{% if sku_count > 0 %}{{ sku_count }}{% else %}Many{% endif %} SKUs</span>
            </div>
          </a>
        {% endfor %}
      </div>

      <div class="cat-nav-controls">
        <button class="cat-nav-btn prev" onclick="document.getElementById('CatScrollContainer').scrollBy({left: -320, behavior: 'smooth'})" aria-label="Previous categories">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
        </button>
        <button class="cat-nav-btn next" onclick="document.getElementById('CatScrollContainer').scrollBy({left: 320, behavior: 'smooth'})" aria-label="Next categories">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </button>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Expertise Categories 2.0",
  "settings": [],
  "presets": [
    {
      "name": "Expertise Categories 2.0"
    }
  ]
}
{% endschema %}
