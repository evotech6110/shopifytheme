<script>
  (function () {
    var root = document.getElementById('zpHero-{{ section.id }}');
    if (!root) return;
    var slides = Array.prototype.slice.call(root.querySelectorAll('.zp-slide'));
    if (!slides.length) return;
    var slideKeys = slides.map(function (s) { return s.getAttribute('data-slide'); });
    var idx = 0;
    var autoplayMs = {{ section.settings.autoplay_ms | default: 7000 }};
    var timer = null;
    function go(toIdx) {
      idx = (toIdx + slideKeys.length) % slideKeys.length;
      var key = slideKeys[idx];
      slides.forEach(function (el) { el.setAttribute('data-active', el.getAttribute('data-slide') === key ? 'true' : 'false'); });
      root.querySelectorAll('[data-tracker]').forEach(function (btn) { btn.setAttribute('aria-current', btn.getAttribute('data-tracker') === key ? 'true' : 'false'); });
      root.querySelectorAll('[data-slide-link]').forEach(function (a) { if (a.getAttribute('data-slide-link') === key) a.setAttribute('aria-current','page'); else a.removeAttribute('aria-current'); });
    }
    function restartAutoplay() { if (timer) clearInterval(timer); if (autoplayMs > 0) timer = setInterval(function () { go(idx + 1); }, autoplayMs); }
    root.querySelectorAll('[data-tracker]').forEach(function (btn) { btn.addEventListener('click', function () { go(slideKeys.indexOf(btn.getAttribute('data-tracker'))); restartAutoplay(); }); });
    root.querySelectorAll('[data-slide-link]').forEach(function (a) { a.addEventListener('click', function (e) { e.preventDefault(); go(slideKeys.indexOf(a.getAttribute('data-slide-link'))); restartAutoplay(); }); });
    var prevBtn = root.querySelector('[data-nav="prev"]'); var nextBtn = root.querySelector('[data-nav="next"]');
    if (prevBtn) prevBtn.addEventListener('click', function () { go(idx - 1); restartAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { go(idx + 1); restartAutoplay(); });
    root.addEventListener('mouseenter', function () { if (timer) { clearInterval(timer); timer = null; } });
    root.addEventListener('mouseleave', restartAutoplay);
    restartAutoplay();
  })();
</script>

