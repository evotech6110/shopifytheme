{%- comment -%}
  Evotech Zero-Point Hero
  -----------------------
  3-slide animated hero with:
  - Animated Evolve AI neural-engine brain in the header
  - Support pill linking to https://support.evotech.au (or any URL set in theme editor)
  - Starfield + moon ambient background
  - Ghost display-type behind each slide
  - Autoplay, tracker buttons, left/right arrow nav, keyboard arrows
  All slide copy, CTAs and right-column descriptions are editable in the theme editor.
{%- endcomment -%}

<link rel="preconnect" href="https://api.fontshare.com" crossorigin>
<link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700,800&f[]=satoshi@400,500,700&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&display=swap">

<style>
  .evo-zp-{{ section.id }} { --bg:#05040C; --bg-2:#0B0820; --bg-3:#14122B; --ink:#FFFFFF; --ink-dim:#B6B5C6; --ink-muted:#7A7A8F; --mint:#A8E898; --mint-2:#CDFFBF; --indigo:#3D2EDE; --indigo-2:#5B4DFF; --peach:#FF7A4A; --font-d:'Clash Display','Satoshi','Inter',sans-serif; --font-s:'Satoshi','Inter',system-ui,sans-serif; --font-m:'JetBrains Mono',ui-monospace,monospace; --ease:cubic-bezier(.21,.83,.33,1); position:relative; min-height:100vh; overflow:hidden; background:radial-gradient(1200px 600px at 20% 10%, rgba(61,46,222,0.22), transparent 55%),radial-gradient(900px 500px at 80% 20%, rgba(168,232,152,0.10), transparent 60%),linear-gradient(180deg,#05040C 0%,#0A0820 55%,#14122B 100%); font-family:var(--font-s); color:var(--ink); }
  .evo-zp-{{ section.id }} a { color:inherit; text-decoration:none; }
  .evo-zp-{{ section.id }}::before, .evo-zp-{{ section.id }}::after { content:""; position:absolute; inset:0; pointer-events:none; background-image:radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,.7), transparent),radial-gradient(1px 1px at 70% 50%, rgba(255,255,255,.55), transparent),radial-gradient(1.5px 1.5px at 45% 80%, rgba(255,255,255,.8), transparent),radial-gradient(1px 1px at 85% 20%, rgba(168,232,152,.65), transparent),radial-gradient(1px 1px at 10% 70%, rgba(255,255,255,.6), transparent),radial-gradient(2px 2px at 60% 15%, rgba(205,255,191,.7), transparent),radial-gradient(1px 1px at 30% 90%, rgba(255,255,255,.5), transparent),radial-gradient(1px 1px at 90% 85%, rgba(255,255,255,.7), transparent); background-size:800px 800px; background-repeat:repeat; opacity:.85; animation:zpTwinkle{{ section.id }} 6s linear infinite; }
  .evo-zp-{{ section.id }}::after { background-size:1100px 1100px; opacity:.45; animation-duration:11s; animation-direction:reverse; }
  @keyframes zpTwinkle{{ section.id }} { 0%,100%{opacity:.85} 50%{opacity:.55} }
  .evo-zp-{{ section.id }} .zp-moon { position:absolute; left:0; right:0; bottom:-40px; height:220px; background:radial-gradient(ellipse at 20% 10%, rgba(255,255,255,0.06), transparent 60%),radial-gradient(ellipse at 80% 30%, rgba(168,232,152,0.08), transparent 60%),radial-gradient(ellipse at 50% 100%, rgba(61,46,222,0.25), transparent 70%),linear-gradient(180deg, rgba(30,26,60,0.2), rgba(5,4,12,1)); filter:blur(1px); pointer-events:none; z-index:1; mask-image:radial-gradient(ellipse 120% 90% at 50% 100%, #000 60%, transparent 85%); -webkit-mask-image:radial-gradient(ellipse 120% 90% at 50% 100%, #000 60%, transparent 85%); }
  .evo-zp-{{ section.id }} .zp-header { position:relative; z-index:18; display:grid; grid-template-columns:1fr auto 1fr; align-items:center; padding:28px clamp(20px,4vw,56px) 24px; gap:20px; }
  .evo-zp-{{ section.id }} .zp-logo { display:inline-flex; align-items:center; gap:12px; justify-self:start; }
  .evo-zp-{{ section.id }} .zp-logo-mark { width:44px; height:44px; }
  .evo-zp-{{ section.id }} .zp-logo-wordmark { font-family:var(--font-d); font-weight:800; font-size:20px; letter-spacing:0.02em; color:#fff; line-height:1; }
  .evo-zp-{{ section.id }} .zp-logo-wordmark em { color:var(--mint); font-style:normal; }
  .evo-zp-{{ section.id }} .zp-logo-tagline { display:block; font-size:9px; letter-spacing:0.32em; text-transform:uppercase; color:var(--ink-muted); margin-top:4px; font-weight:500; }
  .evo-zp-{{ section.id }} .zp-brain { justify-self:center; display:inline-flex; flex-direction:column; align-items:center; gap:6px; padding:4px 18px; border:1px solid rgba(168,232,152,0.2); border-radius:999px; background:rgba(10,8,26,0.55); backdrop-filter:blur(6px); }
  .evo-zp-{{ section.id }} .zp-brain-viz { width:56px; height:40px; filter:drop-shadow(0 0 10px rgba(168,232,152,0.45)); animation:zpBrainBreath{{ section.id }} 4.5s ease-in-out infinite; }
  @keyframes zpBrainBreath{{ section.id }} { 0%,100%{transform:scale(1); filter:drop-shadow(0 0 6px rgba(168,232,152,0.35))} 50%{transform:scale(1.06); filter:drop-shadow(0 0 16px rgba(168,232,152,0.75))} }
  .evo-zp-{{ section.id }} .zp-brain-label { font-family:var(--font-m); font-size:10px; letter-spacing:0.28em; text-transform:uppercase; color:var(--mint); padding-bottom:4px; white-space:nowrap; }
  .evo-zp-{{ section.id }} .zp-brain-label .dim { color:var(--ink-muted); }
  .evo-zp-{{ section.id }} .brain-node { animation:zpBrainNode{{ section.id }} 2.2s ease-in-out infinite; transform-origin:center; }
  .evo-zp-{{ section.id }} .brain-node.n1{animation-delay:0} .evo-zp-{{ section.id }} .brain-node.n2{animation-delay:.3s} .evo-zp-{{ section.id }} .brain-node.n3{animation-delay:.6s} .evo-zp-{{ section.id }} .brain-node.n4{animation-delay:.9s} .evo-zp-{{ section.id }} .brain-node.n5{animation-delay:.15s} .evo-zp-{{ section.id }} .brain-node.n6{animation-delay:.45s} .evo-zp-{{ section.id }} .brain-node.n7{animation-delay:.75s} .evo-zp-{{ section.id }} .brain-node.n8{animation-delay:1.05s} .evo-zp-{{ section.id }} .brain-node.core{animation-duration:1.4s}
  @keyframes zpBrainNode{{ section.id }} { 0%,100%{opacity:.35} 50%{opacity:1} }
  .evo-zp-{{ section.id }} .brain-synapse line { stroke-dasharray:2 4; animation:zpBrainFlow{{ section.id }} 1.6s linear infinite; }
  .evo-zp-{{ section.id }} .brain-synapse line:nth-child(2n) { animation-duration:2.2s; animation-direction:reverse; }
  .evo-zp-{{ section.id }} .brain-synapse line:nth-child(3n) { animation-duration:1.9s; }
  @keyframes zpBrainFlow{{ section.id }} { from{stroke-dashoffset:0} to{stroke-dashoffset:-12} }
  .evo-zp-{{ section.id }} .brain-halo { transform-origin:center; animation:zpBrainHalo{{ section.id }} 3s ease-in-out infinite; }
  @keyframes zpBrainHalo{{ section.id }} { 0%,100%{opacity:.35; transform:scale(.85)} 50%{opacity:.9; transform:scale(1.1)} }
  .evo-zp-{{ section.id }} .zp-nav { justify-self:end; display:inline-flex; gap:2px; align-items:center; flex-wrap:wrap; justify-content:flex-end; }
  .evo-zp-{{ section.id }} .zp-nav a { font-family:var(--font-m); font-size:12px; letter-spacing:0.22em; color:#fff; padding:10px 14px; border:1px solid transparent; border-radius:6px; transition:color .2s var(--ease),border-color .2s var(--ease),background .2s var(--ease); }
  .evo-zp-{{ section.id }} .zp-nav a:hover, .evo-zp-{{ section.id }} .zp-nav a[aria-current="page"] { color:var(--mint); border-color:rgba(168,232,152,0.3); background:rgba(168,232,152,0.06); }
  .evo-zp-{{ section.id }} .zp-nav a.is-support { background:linear-gradient(90deg,#A8E898 0%,#CDFFBF 100%); color:#0A0A0A; margin-left:6px; font-weight:700; }
  .evo-zp-{{ section.id }} .zp-nav a.is-support:hover { background:linear-gradient(90deg,#CDFFBF 0%,#A8E898 100%); color:#0A0A0A; border-color:transparent; transform:translateY(-1px); }
  @media (max-width:1100px) { .evo-zp-{{ section.id }} .zp-header{grid-template-columns:1fr auto} .evo-zp-{{ section.id }} .zp-brain{grid-column:1/-1; order:3; margin:8px auto 0} .evo-zp-{{ section.id }} .zp-nav a{padding:8px 10px; font-size:11px; letter-spacing:0.16em} }
  @media (max-width:640px) { .evo-zp-{{ section.id }} .zp-nav a:not(.is-support){display:none} .evo-zp-{{ section.id }} .zp-nav a.is-support{display:inline-flex} }
  .evo-zp-{{ section.id }} .zp-stage { position:relative; z-index:5; min-height:calc(100vh - 140px); display:flex; align-items:center; justify-content:center; padding:0 clamp(20px,4vw,56px); }
  .evo-zp-{{ section.id }} .zp-slide { position:absolute; inset:0; display:grid; grid-template-columns:280px 1fr 280px; align-items:center; gap:36px; padding:0 clamp(20px,4vw,56px) 120px; opacity:0; transform:translateY(30px); transition:opacity .6s var(--ease),transform .6s var(--ease); pointer-events:none; }
  .evo-zp-{{ section.id }} .zp-slide[data-active="true"] { opacity:1; transform:translateY(0); pointer-events:auto; }
  @media (max-width:1050px) { .evo-zp-{{ section.id }} .zp-slide{grid-template-columns:1fr; gap:20px; text-align:center; padding-bottom:160px} }
  .evo-zp-{{ section.id }} .zp-ghost { position:absolute; left:50%; top:50%; transform:translate(-50%,-52%); font-family:var(--font-d); font-weight:800; font-size:clamp(18vw,22vw,28vw); letter-spacing:-0.04em; color:transparent; -webkit-text-stroke:1.5px rgba(255,255,255,0.07); white-space:nowrap; pointer-events:none; z-index:1; line-height:1; user-select:none; }
  .evo-zp-{{ section.id }} .zp-copy-left { position:relative; z-index:10; }
  .evo-zp-{{ section.id }} .zp-eyebrow { font-family:var(--font-m); font-size:11px; letter-spacing:0.24em; text-transform:uppercase; color:var(--ink-dim); margin-bottom:18px; }
  .evo-zp-{{ section.id }} .zp-chevrons { margin-top:26px; margin-bottom:28px; font-family:var(--font-m); font-size:18px; letter-spacing:0.22em; color:var(--mint); }
  .evo-zp-{{ section.id }} .zp-headline { font-family:var(--font-d); font-weight:800; font-size:clamp(22px,2vw,30px); line-height:1.1; letter-spacing:-0.01em; color:#fff; margin:0; text-transform:uppercase; }
  .evo-zp-{{ section.id }} .zp-cta { display:inline-flex; align-items:center; gap:10px; padding:16px 28px; font-family:var(--font-m); font-size:12px; letter-spacing:0.22em; text-transform:uppercase; font-weight:700; background:var(--peach); color:#110A04; border-radius:6px; transition:transform .25s var(--ease),background .25s var(--ease),box-shadow .25s var(--ease); box-shadow:0 8px 28px rgba(255,122,74,0.35); }
  .evo-zp-{{ section.id }} .zp-cta:hover { transform:translateY(-2px); background:#FF8E62; box-shadow:0 12px 36px rgba(255,122,74,0.55); }
  .evo-zp-{{ section.id }} .zp-visual { position:relative; display:flex; align-items:center; justify-content:center; min-height:clamp(360px,48vh,560px); z-index:5; }
  .evo-zp-{{ section.id }} .zp-visual svg { width:min(420px,55vw); height:auto; filter:drop-shadow(0 0 80px rgba(168,232,152,0.35)) drop-shadow(0 30px 60px rgba(0,0,0,.55)); animation:zpFloat{{ section.id }} 6s ease-in-out infinite; }
  @keyframes zpFloat{{ section.id }} { 0%,100%{transform:translateY(-6px) rotate(-2deg)} 50%{transform:translateY(8px) rotate(2deg)} }
  .evo-zp-{{ section.id }} .zp-orbit { position:absolute; inset:0; pointer-events:none; }
  .evo-zp-{{ section.id }} .zp-orbit span { position:absolute; width:10px; height:10px; border-radius:999px; background:var(--mint); box-shadow:0 0 18px var(--mint); animation:zpOrbit{{ section.id }} 9s linear infinite; }
  .evo-zp-{{ section.id }} .zp-orbit span:nth-child(1){top:10%; left:18%; width:14px; height:14px; background:var(--indigo-2); box-shadow:0 0 22px var(--indigo-2); animation-duration:13s}
  .evo-zp-{{ section.id }} .zp-orbit span:nth-child(2){top:28%; left:82%; width:10px; height:10px; animation-duration:10s; animation-direction:reverse}
  .evo-zp-{{ section.id }} .zp-orbit span:nth-child(3){top:70%; left:12%; width:8px; height:8px; background:#fff; box-shadow:0 0 12px #fff; animation-duration:15s}
  .evo-zp-{{ section.id }} .zp-orbit span:nth-child(4){top:78%; left:78%; width:12px; height:12px; background:var(--mint-2); box-shadow:0 0 20px var(--mint-2); animation-duration:11s; animation-direction:reverse}
  .evo-zp-{{ section.id }} .zp-orbit span:nth-child(5){top:42%; left:94%; width:6px; height:6px; background:#fff; opacity:.7; animation-duration:17s}
  @keyframes zpOrbit{{ section.id }} { 0%{transform:translate(0,0)} 25%{transform:translate(20px,-14px)} 50%{transform:translate(0,-24px)} 75%{transform:translate(-20px,-14px)} 100%{transform:translate(0,0)} }
  .evo-zp-{{ section.id }} .zp-copy-right { position:relative; z-index:10; font-family:var(--font-m); font-size:13px; line-height:1.7; color:var(--ink-dim); text-transform:uppercase; letter-spacing:0.06em; justify-self:end; text-align:right; max-width:260px; }
  @media (max-width:1050px) { .evo-zp-{{ section.id }} .zp-copy-right, .evo-zp-{{ section.id }} .zp-copy-left { text-align:center; justify-self:center; max-width:420px } }
  .evo-zp-{{ section.id }} .zp-tracker { position:absolute; z-index:20; left:clamp(20px,4vw,56px); bottom:32px; display:flex; flex-direction:column; gap:6px; }
  .evo-zp-{{ section.id }} .zp-tracker button { display:inline-flex; align-items:center; gap:10px; background:transparent; border:none; cursor:pointer; padding:6px 2px; color:var(--ink-muted); font-family:var(--font-m); font-size:13px; letter-spacing:0.22em; text-transform:uppercase; transition:color .2s var(--ease); text-align:left; }
  .evo-zp-{{ section.id }} .zp-tracker button::before { content:""; width:18px; height:1px; background:currentColor; opacity:.4; transition:width .3s var(--ease),opacity .3s var(--ease),background .3s var(--ease); }
  .evo-zp-{{ section.id }} .zp-tracker button:hover { color:var(--ink); }
  .evo-zp-{{ section.id }} .zp-tracker button[aria-current="true"] { color:#fff; font-weight:700; }
  .evo-zp-{{ section.id }} .zp-tracker button[aria-current="true"]::before { width:36px; opacity:1; background:var(--mint); }
  .evo-zp-{{ section.id }} .zp-social { position:absolute; z-index:20; right:clamp(20px,4vw,56px); bottom:32px; display:inline-flex; gap:6px; }
  .evo-zp-{{ section.id }} .zp-social a { display:inline-flex; align-items:center; justify-content:center; width:38px; height:38px; border:1px solid rgba(255,255,255,0.15); border-radius:4px; font-family:var(--font-m); font-size:11px; letter-spacing:0.1em; color:var(--ink-dim); transition:color .2s var(--ease),border-color .2s var(--ease),background .2s var(--ease); }
  .evo-zp-{{ section.id }} .zp-social a:hover { color:var(--mint); border-color:rgba(168,232,152,0.5); background:rgba(168,232,152,0.06); }
  .evo-zp-{{ section.id }} .zp-arrow { position:absolute; z-index:15; top:50%; transform:translateY(-50%); width:44px; height:44px; border-radius:999px; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.12); color:#fff; cursor:pointer; transition:background .2s var(--ease),border-color .2s var(--ease),transform .2s var(--ease); }
  .evo-zp-{{ section.id }} .zp-arrow:hover { background:rgba(168,232,152,0.1); border-color:rgba(168,232,152,0.5); transform:translateY(-50%) scale(1.05); }
  .evo-zp-{{ section.id }} .zp-arrow--prev { left:clamp(10px,2vw,28px); }
  .evo-zp-{{ section.id }} .zp-arrow--next { right:clamp(10px,2vw,28px); }
  .evo-zp-{{ section.id }} .zp-arrow svg { width:16px; height:16px; }
</style>

<section class="evo-zp-{{ section.id }}" id="zpHero-{{ section.id }}" aria-label="{{ section.settings.aria_label | default: 'Evotech homepage hero' }}">
  <div class="zp-moon" aria-hidden="true"></div>

  <header class="zp-header">
    <a href="{{ routes.root_url }}" class="zp-logo" aria-label="{{ shop.name | escape }} home">
      <svg class="zp-logo-mark" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="zpLogoGrad-{{ section.id }}" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
            <stop offset="0" stop-color="#A8E898"/>
            <stop offset="1" stop-color="#3D2EDE"/>
          </linearGradient>
        </defs>
        <rect x="3" y="3" width="34" height="34" rx="9" fill="url(#zpLogoGrad-{{ section.id }})"/>
        <path d="M20 9 L31 20 L20 31 L9 20 Z" fill="rgba(5,4,12,0.94)"/>
        <circle cx="20" cy="20" r="3.4" fill="#A8E898"/>
      </svg>
      <span>
        <span class="zp-logo-wordmark">EVO<em>TECH</em></span>
        <span class="zp-logo-tagline">{{ section.settings.logo_tagline | default: 'INSPIRE · AUTOMATE · EVOLVE' }}</span>
      </span>
    </a>

    <div class="zp-brain" role="img" aria-label="{{ section.settings.brain_aria | default: 'Evolve AI neural engine — live' }}">
      <svg class="zp-brain-viz" viewBox="0 0 100 72" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <linearGradient id="brainOutline-{{ section.id }}" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0" stop-color="#A8E898"/>
            <stop offset="1" stop-color="#3D2EDE"/>
          </linearGradient>
          <radialGradient id="brainGlow-{{ section.id }}" cx="50%" cy="50%" r="55%">
            <stop offset="0" stop-color="#CDFFBF" stop-opacity="0.65"/>
            <stop offset="1" stop-color="#CDFFBF" stop-opacity="0"/>
          </radialGradient>
        </defs>
        <circle class="brain-halo" cx="50" cy="36" r="32" fill="url(#brainGlow-{{ section.id }})"/>
        <path d="M48 8 Q28 8 22 22 Q10 26 12 40 Q10 54 22 58 Q30 68 48 64 Z" fill="none" stroke="url(#brainOutline-{{ section.id }})" stroke-width="1.8" stroke-linejoin="round"/>
        <path d="M52 8 Q72 8 78 22 Q90 26 88 40 Q90 54 78 58 Q70 68 52 64 Z" fill="none" stroke="url(#brainOutline-{{ section.id }})" stroke-width="1.8" stroke-linejoin="round"/>
        <line x1="50" y1="10" x2="50" y2="64" stroke="#A8E898" stroke-width="0.8" stroke-dasharray="2 3" opacity="0.6"/>
        <path d="M24 28 Q34 30 30 40 Q24 50 34 54" fill="none" stroke="#A8E898" stroke-width="0.9" stroke-opacity="0.45"/>
        <path d="M76 28 Q66 30 70 40 Q76 50 66 54" fill="none" stroke="#A8E898" stroke-width="0.9" stroke-opacity="0.45"/>
        <g class="brain-synapse" stroke="#A8E898" stroke-width="0.8" stroke-opacity="0.55" fill="none">
          <line x1="28" y1="24" x2="40" y2="34"/><line x1="40" y1="34" x2="50" y2="36"/><line x1="50" y1="36" x2="60" y2="34"/><line x1="60" y1="34" x2="72" y2="24"/>
          <line x1="22" y1="42" x2="40" y2="34"/><line x1="78" y1="42" x2="60" y2="34"/><line x1="36" y1="52" x2="50" y2="36"/><line x1="64" y1="52" x2="50" y2="36"/>
        </g>
        <circle class="brain-node n1" cx="28" cy="24" r="1.8" fill="#CDFFBF"/>
        <circle class="brain-node n2" cx="40" cy="34" r="1.8" fill="#A8E898"/>
        <circle class="brain-node n3" cx="22" cy="42" r="1.8" fill="#A8E898"/>
        <circle class="brain-node n4" cx="36" cy="52" r="1.8" fill="#CDFFBF"/>
        <circle class="brain-node n5" cx="72" cy="24" r="1.8" fill="#CDFFBF"/>
        <circle class="brain-node n6" cx="60" cy="34" r="1.8" fill="#A8E898"/>
        <circle class="brain-node n7" cx="78" cy="42" r="1.8" fill="#A8E898"/>
        <circle class="brain-node n8" cx="64" cy="52" r="1.8" fill="#CDFFBF"/>
        <circle class="brain-node core" cx="50" cy="36" r="3" fill="#5B4DFF" stroke="#CDFFBF" stroke-width="0.8"/>
      </svg>
      <span class="zp-brain-label">{{ section.settings.brain_label | default: 'EVOLVE AI' }} <span class="dim">· {{ section.settings.brain_sublabel | default: 'NEURAL ENGINE' }}</span></span>
    </div>

    <nav class="zp-nav" aria-label="Primary">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}"{% if link.current %} aria-current="page"{% endif %}>{{ link.title | upcase }}</a>
      {%- else -%}
        <a href="#" data-slide-link="solutions" aria-current="page">SOLUTIONS</a>
        <a href="#" data-slide-link="services">SERVICES</a>
        <a href="#" data-slide-link="products">PRODUCTS</a>
        <a href="/pages/contact">CONTACT</a>
      {%- endfor -%}
      {%- if section.settings.support_url != blank -%}
        <a href="{{ section.settings.support_url }}" class="is-support" target="_blank" rel="noopener">{{ section.settings.support_label | default: 'SUPPORT →' }}</a>
      {%- endif -%}
    </nav>
  </header>

  <div class="zp-stage" id="zpStage-{{ section.id }}">
    {%- assign slide_index = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}
        {%- assign slide_key = block.settings.slide_key | default: block.id -%}
        <article class="zp-slide" data-slide="{{ slide_key }}" {% if slide_index == 0 %}data-active="true"{% endif %} aria-label="{{ block.settings.aria | default: block.settings.eyebrow }}" {{ block.shopify_attributes }}>
          <div class="zp-ghost" aria-hidden="true">{{ block.settings.ghost_text | default: block.settings.eyebrow | upcase }}</div>
          <div class="zp-copy-left">
            <div class="zp-eyebrow">{{ block.settings.eyebrow }}</div>
