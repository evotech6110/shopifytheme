{%- comment -%}
  EvoTech — Header
  Sticky indigo-gradient header with mega-menu support.
  Renders the store's NATIVE main menu (linklists[section.settings.menu]).
  Merchants edit nav items in: Online Store → Navigation → Main menu.
  Nested links automatically become mega-menu dropdowns.
{%- endcomment -%}

{%- assign nav = linklists[section.settings.menu] -%}
{%- if nav == blank -%}
  {%- assign nav = linklists['main-menu'] -%}
{%- endif -%}

<header class="evo evo-header" data-evo-sticky role="banner">
  <div class="evo-container evo-header__inner">

    {% render 'evotech-logo' %}

    <nav aria-label="Primary">
      <ul class="evo-nav">
        {%- for link in nav.links -%}
          {%- if link.links != blank -%}
            <li class="evo-nav__item evo-nav__item--has-children" data-evo-menu>
              <a href="{{ link.url }}" class="evo-nav__link evo-menu__trigger"{% if link.active or link.child_active %} aria-current="page"{% endif %}>
                {{ link.title }}
                <svg class="evo-nav__caret" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
              <ul class="evo-nav__submenu" role="menu">
                {%- for child in link.links -%}
                  <li class="evo-nav__submenu-item" role="none">
                    <a href="{{ child.url }}" role="menuitem"{% if child.active %} aria-current="page"{% endif %}>
                      <div class="evo-nav__submenu-title">{{ child.title }}</div>
                    </a>
                  </li>
                {%- endfor -%}
              </ul>
            </li>
          {%- else -%}
            <li class="evo-nav__item">
              <a href="{{ link.url }}" class="evo-nav__link"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </nav>

    <div class="evo-header__icons">
      <a href="/search" class="evo-icon-btn" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
      <a href="/cart" class="evo-icon-btn" aria-label="Cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      </a>
      <a href="/account" class="evo-icon-btn" aria-label="Account">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="evo-btn evo-btn--primary evo-header__cta" style="margin-left:8px;">{{ section.settings.cta_text }}</a>
      {%- endif -%}
      <button class="evo-icon-btn evo-burger" data-evo-drawer-toggle aria-label="Menu" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </div>
</header>

<aside class="evo-drawer" data-evo-drawer aria-hidden="true">
  <button class="evo-drawer__close" data-evo-drawer-toggle aria-label="Close menu">×</button>
  <ul>
    {%- for link in nav.links -%}
      <li>
        <a href="{{ link.url }}">{{ link.title }}</a>
        {%- if link.links != blank -%}
          <ul style="padding-left:16px;">
            {%- for child in link.links -%}
              <li><a href="{{ child.url }}" style="font-size:16px;">{{ child.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
</aside>

{% schema %}
{
  "name": "EvoTech — Header",
  "tag": "section",
  "class": "evo-section-header",
  "settings": [
    { "type": "header", "content": "Menu" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu",
      "info": "Edit items in Online Store → Navigation → Main menu. Nested items automatically become mega-menu dropdowns." },
    { "type": "header", "content": "Header CTA button" },
    { "type": "text", "id": "cta_text", "label": "CTA button text", "default": "Start free trial" },
    { "type": "url",  "id": "cta_link", "label": "CTA button link" }
  ],
  "presets": [ { "name": "EvoTech — Header" } ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
