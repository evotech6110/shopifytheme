{%- comment -%}
  EvoTech — Animated Header v2
  Features:
  · Glassmorphism scroll effect (transparent → frosted glass on scroll)
  · Smooth dropdown mega-menu with slide+fade animation
  · Animated hamburger → X burger icon
  · Full-screen mobile drawer with staggered link animations
  · Animated underline on nav links
  · "Get Support" CTA with pulse glow effect
{%- endcomment -%}

{%- assign nav = linklists[section.settings.menu] -%}
{%- if nav == blank -%}{%- assign nav = linklists['main-menu'] -%}{%- endif -%}

<style>
/* ─── EvoTech Header v2 ─────────────────────────── */
.evoh {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  font-family: 'Satoshi','Inter',system-ui,sans-serif;
  transition: background 0.4s ease, backdrop-filter 0.4s ease, box-shadow 0.4s ease;
}
.evoh--scrolled {
  background: rgba(5, 4, 12, 0.82);
  backdrop-filter: blur(18px) saturate(1.6);
  -webkit-backdrop-filter: blur(18px) saturate(1.6);
  box-shadow: 0 1px 0 rgba(168,232,152,0.08), 0 8px 32px rgba(0,0,0,0.4);
}
.evoh__inner {
  max-width: 1320px; margin: 0 auto;
  padding: 0 clamp(16px, 3vw, 40px);
  height: 68px;
  display: flex; align-items: center; gap: 32px;
}

/* ─── Logo ── */
.evoh__logo {
  display: flex; align-items: center; gap: 10px;
  text-decoration: none; flex-shrink: 0;
  transition: opacity 0.2s;
}
.evoh__logo:hover { opacity: 0.85; }
.evoh__logo-icon {
  width: 36px; height: 36px;
  display: flex; align-items: center; justify-content: center;
}
.evoh__logo-text { display: flex; flex-direction: column; line-height: 1; }
.evoh__logo-name {
  font-family: 'Clash Display','Satoshi','Inter',sans-serif;
  font-weight: 700; font-size: 20px; letter-spacing: -0.01em;
  color: #fff;
}
.evoh__logo-sub {
  font-family: 'JetBrains Mono',ui-monospace,monospace;
  font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
  color: rgba(168,232,152,0.7); margin-top: 3px;
}

/* ─── Desktop Nav ── */
.evoh__nav { display: flex; align-items: center; gap: 2px; margin: 0 auto; list-style: none; padding: 0; }
@media (max-width: 900px) { .evoh__nav { display: none; } }

.evoh__nav-item { position: relative; }

.evoh__nav-link {
  display: flex; align-items: center; gap: 4px;
  padding: 8px 14px;
  font-size: 14.5px; font-weight: 500;
  color: rgba(255,255,255,0.82);
  text-decoration: none;
  border-radius: 8px;
  transition: color 0.2s, background 0.2s;
  position: relative;
  white-space: nowrap;
}
.evoh__nav-link::after {
  content: '';
  position: absolute; bottom: 4px; left: 14px; right: 14px; height: 1.5px;
  background: #A8E898;
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.25s cubic-bezier(0.4,0,0.2,1);
  border-radius: 2px;
}
.evoh__nav-link:hover { color: #fff; background: rgba(255,255,255,0.06); }
.evoh__nav-link:hover::after { transform: scaleX(1); }
.evoh__nav-link[aria-current="page"] { color: #A8E898; }
.evoh__nav-link[aria-current="page"]::after { transform: scaleX(1); }

/* Caret */
.evoh__caret {
  width: 10px; height: 10px; opacity: 0.6;
  transition: transform 0.25s ease;
}
.evoh__nav-item--drop:hover .evoh__caret,
.evoh__nav-item--drop[data-open] .evoh__caret { transform: rotate(180deg); }

/* ─── Dropdown ── */
.evoh__drop {
  position: absolute; top: calc(100% + 8px); left: 50%; transform: translateX(-50%);
  min-width: 220px;
  background: rgba(10, 8, 28, 0.95);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 14px;
  padding: 8px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.5), 0 0 0 1px rgba(168,232,152,0.06);
  list-style: none;
  opacity: 0; visibility: hidden; pointer-events: none;
  transform: translateX(-50%) translateY(-8px);
  transition: opacity 0.22s ease, transform 0.22s cubic-bezier(0.4,0,0.2,1), visibility 0.22s;
}
.evoh__nav-item--drop:hover .evoh__drop {
  opacity: 1; visibility: visible; pointer-events: auto;
  transform: translateX(-50%) translateY(0);
}
.evoh__drop-link {
  display: block; padding: 10px 14px;
  font-size: 14px; color: rgba(255,255,255,0.75);
  text-decoration: none; border-radius: 8px;
  transition: background 0.15s, color 0.15s, padding-left 0.15s;
  position: relative;
}
.evoh__drop-link::before {
  content: '›';
  position: absolute; left: 6px; top: 50%; transform: translateY(-50%);
  color: #A8E898; opacity: 0;
  transition: opacity 0.15s, left 0.15s;
  font-size: 16px;
}
.evoh__drop-link:hover {
  background: rgba(168,232,152,0.08); color: #fff; padding-left: 22px;
}
.evoh__drop-link:hover::before { opacity: 1; left: 8px; }

/* Dropdown arrow pointer */
.evoh__drop::before {
  content: '';
  position: absolute; top: -6px; left: 50%; transform: translateX(-50%);
  border-left: 6px solid transparent; border-right: 6px solid transparent;
  border-bottom: 6px solid rgba(255,255,255,0.1);
}

/* ─── Icons + CTA ── */
.evoh__actions { display: flex; align-items: center; gap: 4px; flex-shrink: 0; }

.evoh__icon-btn {
  display: flex; align-items: center; justify-content: center;
  width: 38px; height: 38px; border-radius: 10px;
  color: rgba(255,255,255,0.7);
  text-decoration: none; background: transparent; border: none; cursor: pointer;
  transition: background 0.2s, color 0.2s, transform 0.15s;
}
.evoh__icon-btn:hover { background: rgba(255,255,255,0.08); color: #fff; transform: scale(1.08); }
@media (max-width: 900px) { .evoh__icon-btn--desktop-only { display: none !important; } }

.evoh__cta {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 20px; border-radius: 10px; margin-left: 6px;
  font-size: 14px; font-weight: 600; letter-spacing: 0.01em;
  color: #05040C; text-decoration: none;
  background: linear-gradient(135deg, #A8E898 0%, #7FD96A 100%);
  box-shadow: 0 0 0 0 rgba(168,232,152,0.4);
  transition: transform 0.2s, box-shadow 0.2s, background 0.2s;
  animation: evoh-pulse 3s ease-in-out infinite;
}
.evoh__cta:hover {
  transform: translateY(-1px) scale(1.02);
  box-shadow: 0 4px 20px rgba(168,232,152,0.35);
  animation: none;
}
@keyframes evoh-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(168,232,152,0.3); }
  50%       { box-shadow: 0 0 0 8px rgba(168,232,152,0); }
}
@media (max-width: 640px) { .evoh__cta { display: none; } }

/* ─── Burger ── */
.evoh__burger {
  display: none; width: 38px; height: 38px;
  align-items: center; justify-content: center;
  border: none; background: rgba(255,255,255,0.07); border-radius: 10px;
  cursor: pointer; padding: 0; color: #fff; transition: background 0.2s;
}
.evoh__burger:hover { background: rgba(255,255,255,0.14); }
@media (max-width: 900px) { .evoh__burger { display: flex; } }
.evoh__burger-bar {
  display: flex; flex-direction: column; gap: 5px; width: 18px;
  transition: transform 0.3s;
}
.evoh__burger-bar span {
  display: block; height: 2px; background: #fff; border-radius: 2px;
  transition: transform 0.3s, opacity 0.3s, width 0.3s;
}
.evoh__burger[aria-expanded="true"] .evoh__burger-bar span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.evoh__burger[aria-expanded="true"] .evoh__burger-bar span:nth-child(2) { opacity: 0; transform: scaleX(0); }
.evoh__burger[aria-expanded="true"] .evoh__burger-bar span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ─── Mobile Drawer ── */
.evoh__drawer {
  position: fixed; inset: 0; z-index: 999;
  display: flex; flex-direction: column;
  background: rgba(5, 4, 12, 0.97);
  backdrop-filter: blur(24px);
  transform: translateX(100%);
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
  padding: 80px 28px 40px;
  overflow-y: auto;
}
.evoh__drawer--open { transform: translateX(0); }

.evoh__drawer-nav { list-style: none; padding: 0; margin: 0; }
.evoh__drawer-item {
  border-bottom: 1px solid rgba(255,255,255,0.07);
  opacity: 0; transform: translateX(24px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}
.evoh__drawer--open .evoh__drawer-item {
  opacity: 1; transform: translateX(0);
}
/* Stagger */
.evoh__drawer--open .evoh__drawer-item:nth-child(1) { transition-delay: 0.05s; }
.evoh__drawer--open .evoh__drawer-item:nth-child(2) { transition-delay: 0.10s; }
.evoh__drawer--open .evoh__drawer-item:nth-child(3) { transition-delay: 0.15s; }
.evoh__drawer--open .evoh__drawer-item:nth-child(4) { transition-delay: 0.20s; }
.evoh__drawer--open .evoh__drawer-item:nth-child(5) { transition-delay: 0.25s; }
.evoh__drawer--open .evoh__drawer-item:nth-child(6) { transition-delay: 0.30s; }
.evoh__drawer--open .evoh__drawer-item:nth-child(7) { transition-delay: 0.35s; }

.evoh__drawer-link {
  display: block; padding: 18px 0;
  font-size: 22px; font-weight: 600;
  color: rgba(255,255,255,0.85); text-decoration: none;
  letter-spacing: -0.01em;
  transition: color 0.2s, padding-left 0.2s;
}
.evoh__drawer-link:hover { color: #A8E898; padding-left: 6px; }

.evoh__drawer-children { list-style: none; padding: 0 0 8px 16px; margin: 0; }
.evoh__drawer-child {
  display: flex; align-items: center; gap: 6px;
  padding: 9px 0; font-size: 14px;
  color: rgba(255,255,255,0.55); text-decoration: none;
  transition: color 0.15s;
}
.evoh__drawer-child::before { content: '›'; color: #A8E898; font-size: 18px; }
.evoh__drawer-child:hover { color: #A8E898; }

.evoh__drawer-cta {
  margin-top: 32px; padding: 16px;
  background: linear-gradient(135deg, #A8E898 0%, #7FD96A 100%);
  border-radius: 14px; text-align: center;
  font-size: 16px; font-weight: 700;
  color: #05040C; text-decoration: none;
  display: block;
  transition: transform 0.2s, box-shadow 0.2s;
}
.evoh__drawer-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(168,232,152,0.3); }

.evoh__drawer-close {
  position: absolute; top: 20px; right: 20px;
  width: 40px; height: 40px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid rgba(255,255,255,0.12); border-radius: 10px;
  background: rgba(255,255,255,0.06); color: #fff;
  cursor: pointer; font-size: 20px; transition: background 0.2s;
}
.evoh__drawer-close:hover { background: rgba(255,255,255,0.12); }

/* Drawer overlay */
.evoh__overlay {
  position: fixed; inset: 0; z-index: 998;
  background: rgba(0,0,0,0.5);
  opacity: 0; pointer-events: none;
  transition: opacity 0.35s;
}
.evoh__overlay--visible { opacity: 1; pointer-events: auto; }

/* Main content offset */
body { padding-top: 68px; }
</style>

{%- comment -%} Overlay {%- endcomment -%}
<div class="evoh__overlay" id="evoh-overlay" aria-hidden="true"></div>

<header class="evoh" id="evoh" role="banner">
  <div class="evoh__inner">

    {%- comment -%} Logo {%- endcomment -%}
    <a href="/" class="evoh__logo" aria-label="{{ shop.name }} home">
      <div class="evoh__logo-icon">
        {% render 'evotech-logo' %}
      </div>
      <div class="evoh__logo-text">
        <span class="evoh__logo-name">EVOTECH</span>
        <span class="evoh__logo-sub">INSPIRE · AUTOMATE · EVOLVE</span>
      </div>
    </a>

    {%- comment -%} Desktop Nav {%- endcomment -%}
    <ul class="evoh__nav" role="list">
      {%- for link in nav.links -%}
        {%- if link.links != blank -%}
          <li class="evoh__nav-item evoh__nav-item--drop">
            <a href="{{ link.url }}" class="evoh__nav-link"
               {% if link.active or link.child_active %}aria-current="page"{% endif %}>
              {{ link.title }}
              <svg class="evoh__caret" viewBox="0 0 12 8" fill="none" aria-hidden="true">
                <path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
            <ul class="evoh__drop" role="menu">
              {%- for child in link.links -%}
                <li role="none">
                  <a href="{{ child.url }}" class="evoh__drop-link" role="menuitem"
                     {% if child.active %}aria-current="page"{% endif %}>
                    {{ child.title }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </li>
        {%- else -%}
          <li class="evoh__nav-item">
            <a href="{{ link.url }}" class="evoh__nav-link"
               {% if link.active %}aria-current="page"{% endif %}>
              {{ link.title }}
            </a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    {%- comment -%} Actions {%- endcomment -%}
    <div class="evoh__actions">
      <a href="/search" class="evoh__icon-btn evoh__icon-btn--desktop-only" aria-label="Search">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </a>
      <a href="/cart" class="evoh__icon-btn evoh__icon-btn--desktop-only" aria-label="Cart">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      </a>
      <a href="/account" class="evoh__icon-btn evoh__icon-btn--desktop-only" aria-label="Account">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </a>

      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="evoh__cta" id="evoh-cta-btn">
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}

      <button class="evoh__burger" id="evoh-burger" aria-label="Open menu" aria-expanded="false" aria-controls="evoh-drawer">
        <div class="evoh__burger-bar">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </button>
    </div>

  </div>
</header>

{%- comment -%} Mobile Drawer {%- endcomment -%}
<nav class="evoh__drawer" id="evoh-drawer" aria-label="Mobile navigation" aria-hidden="true">
  <button class="evoh__drawer-close" id="evoh-drawer-close" aria-label="Close menu">×</button>

  <ul class="evoh__drawer-nav">
    {%- for link in nav.links -%}
      <li class="evoh__drawer-item">
        <a href="{{ link.url }}" class="evoh__drawer-link">{{ link.title }}</a>
        {%- if link.links != blank -%}
          <ul class="evoh__drawer-children">
            {%- for child in link.links -%}
              <li><a href="{{ child.url }}" class="evoh__drawer-child">{{ child.title }}</a></li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>

  {%- if section.settings.cta_text != blank -%}
    <a href="{{ section.settings.cta_link }}" class="evoh__drawer-cta">
      {{ section.settings.cta_text }} →
    </a>
  {%- endif -%}
</nav>

<script>
(function () {
  'use strict';
  var header  = document.getElementById('evoh');
  var burger  = document.getElementById('evoh-burger');
  var drawer  = document.getElementById('evoh-drawer');
  var overlay = document.getElementById('evoh-overlay');
  var closeBtn = document.getElementById('evoh-drawer-close');

  /* ── Scroll: glassmorphism ── */
  function onScroll() {
    if (window.scrollY > 20) {
      header.classList.add('evoh--scrolled');
    } else {
      header.classList.remove('evoh--scrolled');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  /* ── Drawer open/close ── */
  function openDrawer() {
    drawer.classList.add('evoh__drawer--open');
    overlay.classList.add('evoh__overlay--visible');
    drawer.setAttribute('aria-hidden', 'false');
    burger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    drawer.classList.remove('evoh__drawer--open');
    overlay.classList.remove('evoh__overlay--visible');
    drawer.setAttribute('aria-hidden', 'true');
    burger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  burger.addEventListener('click', function () {
    drawer.classList.contains('evoh__drawer--open') ? closeDrawer() : openDrawer();
  });
  closeBtn.addEventListener('click', closeDrawer);
  overlay.addEventListener('click', closeDrawer);

  /* Close on Escape */
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer.classList.contains('evoh__drawer--open')) closeDrawer();
  });

  /* ── Close drawer on nav link click ── */
  drawer.querySelectorAll('a').forEach(function (a) {
    a.addEventListener('click', closeDrawer);
  });
})();
</script>

{% schema %}
{
  "name": "EvoTech — Header",
  "tag": "section",
  "class": "evo-section-header",
  "settings": [
    { "type": "header", "content": "Menu" },
    { "type": "link_list", "id": "menu", "label": "Navigation menu", "default": "main-menu",
      "info": "Edit items in Online Store → Navigation → Main menu. Nested items automatically become mega-menu dropdowns." },
    { "type": "header", "content": "Header CTA button" },
    { "type": "text", "id": "cta_text", "label": "CTA button text", "default": "Get Support" },
    { "type": "url",  "id": "cta_link", "label": "CTA button link" },
    { "type": "header", "content": "Custom CSS" },
    { "type": "textarea", "id": "custom_css", "label": "Custom CSS" }
  ],
  "presets": [ { "name": "EvoTech — Header" } ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
