{%- comment -%}
  Evotech "Sanity-Inspired" Neural Header
  Features:
  - Transparent-to-Glass transition on scroll
  - Pulsing CTA for "Get Support"
  - Clean, modern mega-menu
  - SVG Logo with subtle glow
{%- endcomment -%}

{%- assign nav = linklists[section.settings.menu] -%}
{%- if nav == blank -%}{%- assign nav = linklists['main-menu'] -%}{%- endif -%}

{%- assign utility = linklists[section.settings.utility_menu] -%}
{%- if utility == blank -%}{%- assign utility = linklists['top-utility'] -%}{%- endif -%}

<header class="evo-header-root" id="EvoHeader" role="banner">
  {%- comment -%} Top Utility Bar {%- endcomment -%}
  <div class="evo-header-util">
    <div class="evo-header-container">
      <div class="evo-header-util-inner">
        <div class="evo-header-util-msg">
          <span class="evo-header-util-dot"></span>
          <span>Australian Hosted AI Multi-Model API</span>
        </div>
        <nav class="evo-header-util-nav">
          {%- for link in utility.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
          {%- if shop.customer_accounts_enabled -%}
            <a href="/account">{% if customer %}Account{% else %}Login{% endif %}</a>
          {%- endif -%}
        </nav>
      </div>
    </div>
  </div>

  {%- comment -%} Main Header {%- endcomment -%}
  <div class="evo-header-main">
    <div class="evo-header-container">
      <div class="evo-header-main-inner">
        {%- comment -%} Logo {%- endcomment -%}
        <a href="/" class="evo-header-logo">
          <div class="evo-header-logo-mark">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect width="40" height="40" rx="10" fill="url(#evoLogoGrad)"/>
              <path d="M20 10L28.6603 25H11.3397L20 10Z" fill="white" opacity="0.9"/>
              <defs>
                <linearGradient id="evoLogoGrad" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
                  <stop stop-color="#A8E898"/>
                  <stop offset="1" stop-color="#3D2EDE"/>
                </linearGradient>
              </defs>
            </svg>
          </div>
          <div class="evo-header-logo-text">
            <span class="evo-header-logo-name">EVO<em>TECH</em></span>
            <span class="evo-header-logo-tag">AI ECOSYSTEM</span>
          </div>
        </a>

        {%- comment -%} Desktop Nav {%- endcomment -%}
        <nav class="evo-header-nav" aria-label="Main Navigation">
          <ul class="evo-header-nav-list">
            {%- for link in nav.links -%}
              <li class="evo-header-nav-item {% if link.links != blank %}has-dropdown{% endif %}">
                <a href="{{ link.url }}" class="evo-header-nav-link">
                  {{ link.title }}
                  {% if link.links != blank %}
                    <svg class="evo-header-nav-caret" width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2 4L5 7L8 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {% endif %}
                </a>
                {% if link.links != blank %}
                  <div class="evo-header-dropdown">
                    <div class="evo-header-dropdown-inner">
                      {% for child in link.links %}
                        <div class="evo-header-dropdown-col">
                          <a href="{{ child.url }}" class="evo-header-dropdown-title">{{ child.title }}</a>
                          {% if child.links != blank %}
                            <ul class="evo-header-dropdown-list">
                              {% for grandchild in child.links %}
                                <li><a href="{{ grandchild.url }}">{{ grandchild.title }}</a></li>
                              {% endfor %}
                            </ul>
                          {% endif %}
                        </div>
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}
              </li>
            {%- endfor -%}
          </ul>
        </nav>

        {%- comment -%} Actions {%- endcomment -%}
        <div class="evo-header-actions">
          <a href="/search" class="evo-header-icon-btn" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </a>
          <a href="/cart" class="evo-header-icon-btn" aria-label="Cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            <span class="evo-header-cart-count">{{ cart.item_count }}</span>
          </a>
          <a href="{{ section.settings.cta_link | default: 'https://support.evotech.au' }}" class="evo-header-cta pulse-btn">
            {{ section.settings.cta_text | default: 'Get Support' }}
          </a>
          <button class="evo-header-burger" aria-label="Open Menu" id="EvoBurger">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

{%- comment -%} Mobile Drawer {%- endcomment -%}
<div class="evo-header-drawer" id="EvoDrawer">
  <div class="evo-header-drawer-overlay" id="EvoDrawerOverlay"></div>
  <div class="evo-header-drawer-content">
    <div class="evo-header-drawer-header">
      <span class="evo-header-logo-name">EVOTECH</span>
      <button class="evo-header-drawer-close" id="EvoDrawerClose">&times;</button>
    </div>
    <nav class="evo-header-drawer-nav">
      {% for link in nav.links %}
        <div class="evo-header-drawer-item">
          <a href="{{ link.url }}">{{ link.title }}</a>
          {% if link.links != blank %}
            <div class="evo-header-drawer-sub">
              {% for child in link.links %}
                <a href="{{ child.url }}">{{ child.title }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </nav>
  </div>
</div>

<style>
  .evo-header-root {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    font-family: 'Satoshi', sans-serif;
    color: #fff;
  }

  .evo-header-root.is-scrolled {
    background: rgba(5, 4, 12, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .evo-header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Utility Bar */
  .evo-header-util {
    background: rgba(255, 255, 255, 0.03);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    height: 36px;
    display: flex;
    align-items: center;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .is-scrolled .evo-header-util {
    transform: translateY(-100%);
    opacity: 0;
    pointer-events: none;
    height: 0;
  }

  .evo-header-util-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
  }

  .evo-header-util-msg {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .evo-header-util-dot {
    width: 6px;
    height: 6px;
    background: #A8E898;
    border-radius: 50%;
    box-shadow: 0 0 8px #A8E898;
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
    100% { opacity: 0.5; transform: scale(1); }
  }

  .evo-header-util-nav {
    display: flex;
    gap: 20px;
  }

  .evo-header-util-nav a:hover {
    color: #fff;
  }

  /* Main Header */
  .evo-header-main {
    height: 80px;
    display: flex;
    align-items: center;
    transition: height 0.3s ease;
  }

  .is-scrolled .evo-header-main {
    height: 70px;
  }

  .evo-header-main-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  /* Logo */
  .evo-header-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .evo-header-logo-mark {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }

  .evo-header-logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .evo-header-logo-name {
    font-family: 'Clash Display', sans-serif;
    font-weight: 700;
    font-size: 20px;
    letter-spacing: 0.02em;
  }

  .evo-header-logo-name em {
    color: #A8E898;
    font-style: normal;
  }

  .evo-header-logo-tag {
    font-size: 9px;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
  }

  /* Navigation */
  .evo-header-nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  @media (max-width: 1024px) {
    .evo-header-nav { display: none; }
  }

  .evo-header-nav-list {
    display: flex;
    list-style: none;
    padding: 0;
    margin: 0;
    gap: 10px;
  }

  .evo-header-nav-link {
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    border-radius: 100px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .evo-header-nav-link:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.05);
  }

  .evo-header-nav-caret {
    transition: transform 0.2s ease;
  }

  .has-dropdown:hover .evo-header-nav-caret {
    transform: rotate(180deg);
  }

  /* Dropdown / Mega Menu */
  .evo-header-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #0B0820;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 20px;
    padding: 30px;
    min-width: 600px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .has-dropdown:hover .evo-header-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(10px);
  }

  .evo-header-dropdown-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .evo-header-dropdown-title {
    font-family: 'Clash Display', sans-serif;
    font-weight: 600;
    font-size: 15px;
    color: #A8E898;
    margin-bottom: 15px;
    display: block;
  }

  .evo-header-dropdown-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .evo-header-dropdown-list a {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .evo-header-dropdown-list a:hover {
    color: #fff;
  }

  /* Actions */
  .evo-header-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .evo-header-icon-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.7);
    border-radius: 50%;
    transition: all 0.2s ease;
    position: relative;
  }

  .evo-header-icon-btn:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  .evo-header-cart-count {
    position: absolute;
    top: 5px;
    right: 5px;
    background: #FF7A4A;
    color: #fff;
    font-size: 9px;
    font-weight: 700;
    min-width: 15px;
    height: 15px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 4px;
  }

  .evo-header-cta {
    background: #FF7A4A;
    color: #05040C;
    padding: 12px 24px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 14px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(255, 122, 74, 0.3);
  }

  .evo-header-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 122, 74, 0.5);
    background: #FF8E62;
  }

  .pulse-btn {
    animation: btn-pulse 3s infinite;
  }

  @keyframes btn-pulse {
    0% { box-shadow: 0 0 0 0 rgba(255, 122, 74, 0.5); }
    70% { box-shadow: 0 0 0 10px rgba(255, 122, 74, 0); }
    100% { box-shadow: 0 0 0 0 rgba(255, 122, 74, 0); }
  }

  /* Burger */
  .evo-header-burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 5px;
  }

  @media (max-width: 1024px) {
    .evo-header-burger { display: flex; }
    .evo-header-cta { display: none; }
  }

  .evo-header-burger span {
    width: 24px;
    height: 2px;
    background: #fff;
    border-radius: 2px;
  }

  /* Mobile Drawer */
  .evo-header-drawer {
    position: fixed;
    inset: 0;
    z-index: 2000;
    visibility: hidden;
    pointer-events: none;
  }

  .evo-header-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }

  .evo-header-drawer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(10px);
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .is-open .evo-header-drawer-overlay {
    opacity: 1;
  }

  .evo-header-drawer-content {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 400px;
    background: #05040C;
    padding: 40px;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .is-open .evo-header-drawer-content {
    transform: translateX(0);
  }

  .evo-header-drawer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 40px;
  }

  .evo-header-drawer-close {
    background: transparent;
    border: none;
    color: #fff;
    font-size: 32px;
    cursor: pointer;
  }

  .evo-header-drawer-nav {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .evo-header-drawer-item a {
    font-family: 'Clash Display', sans-serif;
    font-size: 24px;
    font-weight: 600;
    color: #fff;
    text-decoration: none;
  }

  .evo-header-drawer-sub {
    margin-top: 15px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-left: 20px;
    border-left: 1px solid rgba(255,255,255,0.1);
  }

  .evo-header-drawer-sub a {
    font-family: 'Satoshi', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: rgba(255,255,255,0.6);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const header = document.getElementById('EvoHeader');
    const burger = document.getElementById('EvoBurger');
    const drawer = document.getElementById('EvoDrawer');
    const close = document.getElementById('EvoDrawerClose');
    const overlay = document.getElementById('EvoDrawerOverlay');

    // Scroll effect
    window.addEventListener('scroll', function() {
      if (window.scrollY > 50) {
        header.classList.add('is-scrolled');
      } else {
        header.classList.remove('is-scrolled');
      }
    });

    // Mobile menu
    function toggleMenu() {
      drawer.classList.toggle('is-open');
      document.body.classList.toggle('no-scroll');
    }

    if (burger) burger.addEventListener('click', toggleMenu);
    if (close) close.addEventListener('click', toggleMenu);
    if (overlay) overlay.addEventListener('click', toggleMenu);
  });
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "section-header",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Custom logo" },

    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "menu", "label": "Main menu", "default": "main-menu" },
    { "type": "link_list", "id": "utility_menu", "label": "Utility bar links", "default": "top-utility" },

    { "type": "header", "content": "CTA button" },
    { "type": "text", "id": "cta_text", "label": "CTA button text", "default": "Get Support" },
    { "type": "url",  "id": "cta_link", "label": "CTA button link" }
  ],
  "enabled_on": { "groups": ["header"] }
}
{% endschema %}
