{% comment %}
  ============================================================
  CLOUD MIGRATION SERVICES — Full-Page SEO Section
  For: evotech.au/pages/cloud-migration-services
  Brand Colors: #0e2240 (navy), #cff394 (lime-green), #ffffff
  ============================================================
{% endcomment %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "EvoTech Digital",
  "description": "Move your business to the cloud with zero downtime. Expert cloud migration services in Perth. Azure, AWS, and Hybrid Cloud solutions.",
  "url": "{{ shop.url }}",
  "telephone": "+61466911816",
  "email": "info@evotech.au",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Perth",
    "addressRegion": "WA",
    "addressCountry": "AU"
  }
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"How long does a cloud migration take?","acceptedAnswer":{"@type":"Answer","text":"A small business migration typically takes 2–4 weeks. Larger environments with complex dependencies may take 2–3 months. We always start with a scoping engagement to give you an accurate timeline."}},
    {"@type":"Question","name":"Will there be downtime during migration?","acceptedAnswer":{"@type":"Answer","text":"We design migrations to minimize downtime. For most workloads, we achieve zero-downtime cutover using replication and staged migration techniques."}},
    {"@type":"Question","name":"Azure or AWS — which is right for us?","acceptedAnswer":{"@type":"Answer","text":"If you're already using Microsoft 365, Azure is the natural choice. AWS is often preferred for custom applications. We'll assess your environment and recommend the best fit."}}
  ]
}
</script>

<style>
  .evo-page { font-family: var(--body-font, 'Inter', sans-serif); color: #5e6979; background: #fff; }

  .evo-announce {
    background: #0e2240; color: #cff394; text-align: center;
    padding: 10px 20px; font-size: 0.85rem; font-weight: 600; letter-spacing: 0.02em;
  }
  .evo-announce a { color: #fff; text-decoration: underline; }

  .evo-hero {
    background: #0e2240; position: relative; overflow: hidden; padding: 80px 0 70px;
  }
  .evo-hero::before {
    content: ''; position: absolute; top: 0; right: 0; bottom: 0; width: 55%;
    background: radial-gradient(ellipse at 80% 50%, rgba(207,243,148,0.08) 0%, transparent 65%);
    pointer-events: none;
  }
  .evo-hero__grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 56px; align-items: center; position: relative; z-index: 1;
  }
  .evo-hero__eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(207,243,148,0.12); border: 1px solid rgba(207,243,148,0.3);
    color: #cff394; border-radius: 20px; padding: 5px 14px; font-size: 0.78rem; font-weight: 600;
    letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 18px;
  }
  .evo-hero__title { color: #fff; font-size: clamp(1.9rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; margin-bottom: 18px; }
  .evo-hero__title span { color: #cff394; }
  .evo-hero__lead { color: #a8b8cc; font-size: 1.05rem; line-height: 1.65; margin-bottom: 30px; }
  .evo-hero__btns { display: flex; gap: 12px; flex-wrap: wrap; }
  .evo-hero__cta-primary {
    background: #cff394; color: #0e2240; padding: 14px 28px; border-radius: 8px;
    text-decoration: none; font-weight: 700; font-size: 0.95rem; transition: background 0.2s, transform 0.15s;
  }
  .evo-hero__cta-primary:hover { background: #b8e070; transform: translateY(-1px); }
  .evo-hero__cta-secondary {
    background: rgba(255,255,255,0.08); color: #fff; padding: 14px 28px; border-radius: 8px;
    text-decoration: none; font-weight: 600; font-size: 0.95rem; border: 1px solid rgba(255,255,255,0.2);
    transition: background 0.2s;
  }
  .evo-hero__cta-secondary:hover { background: rgba(255,255,255,0.14); }

  .evo-hero__card-group { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .evo-hero__card {
    background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.12);
    border-radius: 12px; padding: 18px; transition: background 0.2s;
  }
  .evo-hero__card:hover { background: rgba(255,255,255,0.11); }
  .evo-hero__card-icon { font-size: 1.6rem; margin-bottom: 8px; }
  .evo-hero__card-title { color: #fff; font-weight: 700; font-size: 0.9rem; margin-bottom: 4px; }
  .evo-hero__card-desc { color: #8a9ab0; font-size: 0.8rem; line-height: 1.5; }

  .evo-section { padding: 80px 0; }
  .evo-section--gray { background: #f8fafb; }
  .evo-section-head { text-align: center; margin-bottom: 48px; }
  .evo-badge {
    display: inline-block; background: #cff394; color: #0e2240;
    border-radius: 20px; padding: 4px 14px; font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.05em; text-transform: uppercase; margin-bottom: 12px;
  }
  .evo-section-head h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); color: #0e2240; font-weight: 800; margin: 0 auto; max-width: 680px; }
  .evo-section-head p { color: #5e6979; max-width: 620px; margin: 12px auto 0; font-size: 1.05rem; line-height: 1.65; }

  .evo-feat-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .evo-feat-card {
    background: #fff; border: 1px solid #e5eaf2; border-radius: 12px; padding: 28px;
    transition: box-shadow 0.2s, transform 0.15s;
  }
  .evo-feat-card:hover { box-shadow: 0 8px 28px rgba(14,34,64,0.1); transform: translateY(-2px); }
  .evo-feat-icon { font-size: 1.8rem; margin-bottom: 14px; }
  .evo-feat-card h3 { color: #0e2240; font-size: 1rem; font-weight: 700; margin-bottom: 8px; }
  .evo-feat-card p { color: #5e6979; font-size: 0.9rem; line-height: 1.6; margin: 0; }

  .evo-services-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .evo-mega-col-title { color: #0e2240; font-weight: 700; font-size: 0.95rem; margin-bottom: 14px; padding-bottom: 8px; border-bottom: 2px solid #cff394; }
  .evo-service-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
  .evo-service-list li { color: #5e6979; font-size: 0.9rem; padding-left: 16px; position: relative; }
  .evo-service-list li::before { content: '›'; color: #a8e060; font-weight: 700; position: absolute; left: 0; }

  .evo-trust-strip {
    background: #0e2240; padding: 40px 0;
  }
  .evo-trust-strip__inner { display: flex; justify-content: space-around; flex-wrap: wrap; gap: 24px; }
  .evo-trust-item { text-align: center; }
  .evo-trust-item strong { display: block; color: #cff394; font-size: 1.9rem; font-weight: 800; }
  .evo-trust-item span { color: #a8b8cc; font-size: 0.85rem; }

  .evo-faq__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  .evo-faq-item {
    background: #fff; border: 1px solid #e5eaf2; border-radius: 12px; padding: 24px;
  }
  .evo-faq-item h4 { color: #0e2240; font-size: 0.95rem; font-weight: 700; margin: 0 0 10px; }
  .evo-faq-item p { color: #5e6979; font-size: 0.88rem; line-height: 1.65; margin: 0; }

  .evo-cta { background: #0e2240; padding: 80px 0; }
  .evo-cta__inner { display: grid; grid-template-columns: 1fr auto; gap: 48px; align-items: center; }
  .evo-cta h2 { color: #fff; font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 10px 0 16px; }
  .evo-cta p { color: #a8b8cc; font-size: 1rem; line-height: 1.65; }
  .evo-cta__checks { display: flex; flex-direction: column; gap: 8px; margin-top: 20px; }
  .evo-cta__check { color: #cff394; font-size: 0.88rem; font-weight: 600; padding-left: 20px; position: relative; }
  .evo-cta__check::before { content: '✓'; position: absolute; left: 0; }
  .evo-cta__btns { display: flex; flex-direction: column; gap: 12px; min-width: 220px; }
  .evo-btn-cta {
    display: block; text-align: center; padding: 14px 24px; border-radius: 8px;
    text-decoration: none; font-weight: 700; font-size: 0.92rem; transition: all 0.2s;
  }
  .evo-btn-cta--lime { background: #cff394; color: #0e2240; }
  .evo-btn-cta--lime:hover { background: #b8e070; }
  .evo-btn-cta--outline { background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,0.3); }
  .evo-btn-cta--outline:hover { background: rgba(255,255,255,0.08); }

  .ic-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  @media (max-width: 900px) {
    .evo-hero__grid, .evo-feat-grid, .evo-services-grid, .evo-faq__grid, .evo-cta__inner { grid-template-columns: 1fr; }
    .evo-hero__card-group { grid-template-columns: 1fr 1fr; }
    .evo-trust-strip__inner { flex-direction: row; justify-content: center; }
  }
  @media (max-width: 560px) {
    .evo-hero__card-group { grid-template-columns: 1fr; }
    .evo-hero { padding: 50px 0 40px; }
    .evo-section { padding: 50px 0; }
  }
</style>

<div class="evo-page">

  {% if section.settings.show_announce %}
  <div class="evo-announce">
    🏆 Perth's Trusted IT Partner — <a href="{{ section.settings.cta_primary_link }}">Free Cloud Migration Consultation →</a>
  </div>
  {% endif %}

  {%- comment -%} HERO {%- endcomment -%}
  <section class="evo-hero">
    <div class="ic-container">
      <div class="evo-hero__grid">
        <div>
          <div class="evo-hero__eyebrow">📍 Perth, Western Australia</div>
          <h1 class="evo-hero__title">Cloud Migration Services <span>Perth</span></h1>
          <p class="evo-hero__lead">Zero-downtime migration to Azure, AWS & hybrid cloud for Perth businesses. Trusted by Perth businesses for fast, reliable, expert support.</p>
          <div class="evo-hero__btns">
            <a href="{{ section.settings.cta_primary_link }}" class="evo-hero__cta-primary">Plan My Migration</a>
            <a href="tel:{{ section.settings.phone_number | remove: ' ' }}" class="evo-hero__cta-secondary">📞 {{ section.settings.phone_number }}</a>
          </div>
        </div>
        <div class="evo-hero__card-group">
          <div class="evo-hero__card">
            <div class="evo-hero__card-icon">🔍</div>
            <div class="evo-hero__card-title">Cloud Readiness Assessment</div>
            <div class="evo-hero__card-desc">Evaluate your current infrastructure and design the optimal migration ...</div>
          </div>
          <div class="evo-hero__card">
            <div class="evo-hero__card-icon">📋</div>
            <div class="evo-hero__card-title">Migration Strategy</div>
            <div class="evo-hero__card-desc">Lift-and-shift, re-platform, or full cloud-native rebuild — we choose ...</div>
          </div>
          <div class="evo-hero__card">
            <div class="evo-hero__card-icon">⚡</div>
            <div class="evo-hero__card-title">Zero Hardware Maintenance</div>
            <div class="evo-hero__card-desc">Eliminate aging servers and reduce your physical IT footprint....</div>
          </div>
          <div class="evo-hero__card">
            <div class="evo-hero__card-icon">📈</div>
            <div class="evo-hero__card-title">Scalable Infrastructure</div>
            <div class="evo-hero__card-desc">Scale up or down instantly as your Perth business grows or contracts....</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} TRUST STRIP {%- endcomment -%}
  <div class="evo-trust-strip">
    <div class="ic-container">
      <div class="evo-trust-strip__inner">
        <div class="evo-trust-item"><strong>15 Min</strong><span>Response Target</span></div>
        <div class="evo-trust-item"><strong>Perth</strong><span>Local Team</span></div>
        <div class="evo-trust-item"><strong>24/7</strong><span>Monitoring</span></div>
        <div class="evo-trust-item"><strong>Fixed</strong><span>Monthly Pricing</span></div>
        <div class="evo-trust-item"><strong>No</strong><span>Lock-In Contracts</span></div>
      </div>
    </div>
  </div>

  {%- comment -%} FEATURES {%- endcomment -%}
  <section class="evo-section">
    <div class="ic-container">
      <div class="evo-section-head">
        <span class="evo-badge">Cloud Migration</span>
        <h2>Our Cloud Migration Services Services</h2>
        <p>Comprehensive solutions for Perth businesses — from initial consultation through to ongoing support and management.</p>
      </div>
      <div class="evo-feat-grid">
        
        <div class="evo-feat-card">
          <div class="evo-feat-icon">🔍</div>
          <h3>Cloud Readiness Assessment</h3>
          <p>Evaluate your current infrastructure and design the optimal migration pathway.</p>
        </div>
        <div class="evo-feat-card">
          <div class="evo-feat-icon">📋</div>
          <h3>Migration Strategy</h3>
          <p>Lift-and-shift, re-platform, or full cloud-native rebuild — we choose what's right.</p>
        </div>
        <div class="evo-feat-card">
          <div class="evo-feat-icon">⚡</div>
          <h3>Zero Hardware Maintenance</h3>
          <p>Eliminate aging servers and reduce your physical IT footprint.</p>
        </div>
        <div class="evo-feat-card">
          <div class="evo-feat-icon">📈</div>
          <h3>Scalable Infrastructure</h3>
          <p>Scale up or down instantly as your Perth business grows or contracts.</p>
        </div>
        <div class="evo-feat-card">
          <div class="evo-feat-icon">🌐</div>
          <h3>Azure & AWS Expertise</h3>
          <p>Certified expertise across Microsoft Azure and Amazon Web Services platforms.</p>
        </div>
        <div class="evo-feat-card">
          <div class="evo-feat-icon">🔄</div>
          <h3>Hybrid Cloud Solutions</h3>
          <p>Keep sensitive workloads on-premise while leveraging cloud for the rest.</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} SERVICES BREAKDOWN {%- endcomment -%}
  <section class="evo-section evo-section--gray">
    <div class="ic-container">
      <div class="evo-section-head">
        <span class="evo-badge">What's Included</span>
        <h2>Everything Covered in Our Cloud Migration Services Package</h2>
      </div>
      <div class="evo-services-grid">
        
            <div>
              <div class="evo-mega-col-title">Azure Services</div>
              <ul class="evo-service-list">
                <li>Azure Virtual Machines</li>
                <li>Azure Storage</li>
                <li>Azure Active Directory</li>
                <li>Azure Backup</li>
              </ul>
            </div>
            <div>
              <div class="evo-mega-col-title">AWS Services</div>
              <ul class="evo-service-list">
                <li>EC2 Instances</li>
                <li>S3 Storage</li>
                <li>RDS Databases</li>
                <li>AWS CloudWatch</li>
              </ul>
            </div>
            <div>
              <div class="evo-mega-col-title">Migration Process</div>
              <ul class="evo-service-list">
                <li>Discovery & Scoping</li>
                <li>Pilot Migration</li>
                <li>Full Cutover</li>
                <li>Post-Migration Review</li>
              </ul>
            </div>
      </div>
    </div>
  </section>

  {%- comment -%} FAQ {%- endcomment -%}
  <section class="evo-section">
    <div class="ic-container">
      <div class="evo-section-head">
        <span class="evo-badge">FAQ</span>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="evo-faq__grid">
        
        <div class="evo-faq-item">
          <h4>How long does a cloud migration take?</h4>
          <p>A small business migration typically takes 2–4 weeks. Larger environments with complex dependencies may take 2–3 months. We always start with a scoping engagement to give you an accurate timeline.</p>
        </div>
        <div class="evo-faq-item">
          <h4>Will there be downtime during migration?</h4>
          <p>We design migrations to minimize downtime. For most workloads, we achieve zero-downtime cutover using replication and staged migration techniques.</p>
        </div>
        <div class="evo-faq-item">
          <h4>Azure or AWS — which is right for us?</h4>
          <p>If you're already using Microsoft 365, Azure is the natural choice. AWS is often preferred for custom applications. We'll assess your environment and recommend the best fit.</p>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} CTA {%- endcomment -%}
  <section class="evo-cta">
    <div class="ic-container">
      <div class="evo-cta__inner">
        <div>
          <span class="evo-badge evo-badge--white" style="background:rgba(207,243,148,0.15);color:#cff394;">Get Started Today</span>
          <h2>Ready to Get Started with Cloud Migration Services?</h2>
          <p>Book a <strong style="color:#cff394">free, no-obligation consultation</strong> with EvoTech Digital. Perth-based experts ready to help your business.</p>
          <div class="evo-cta__checks">
            <div class="evo-cta__check">Free consultation — no obligation, no pressure</div>
            <div class="evo-cta__check">Custom quote within 24 hours</div>
            <div class="evo-cta__check">Perth-based team, not an overseas call centre</div>
          </div>
        </div>
        <div class="evo-cta__btns">
          <a href="{{ section.settings.cta_primary_link }}" class="evo-btn-cta evo-btn-cta--lime">📧 Plan My Migration</a>
          <a href="tel:{{ section.settings.phone_number | remove: ' ' }}" class="evo-btn-cta evo-btn-cta--outline">📞 {{ section.settings.phone_number }}</a>
          <a href="mailto:{{ section.settings.email_address }}" class="evo-btn-cta evo-btn-cta--outline">✉️ {{ section.settings.email_address }}</a>
        </div>
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Cloud Migration Services",
  "tag": "section",
  "class": "evo-service-section",
  "settings": [
    { "type": "header", "content": "Contact Details" },
    { "type": "text", "id": "phone_number", "label": "Phone Number", "default": "0466 911 816" },
    { "type": "text", "id": "email_address", "label": "Email Address", "default": "info@evotech.au" },
    { "type": "header", "content": "Call-to-Action" },
    { "type": "url", "id": "cta_primary_link", "label": "Primary CTA Link" },
    { "type": "header", "content": "Page Options" },
    { "type": "checkbox", "id": "show_announce", "label": "Show Announcement Bar", "default": true }
  ],
  "presets": [{ "name": "Cloud Migration Services" }]
}
{% endschema %}
