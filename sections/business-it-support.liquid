<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"What is business IT support in Perth?","acceptedAnswer":{"@type":"Answer","text":"Business IT support in Perth means having a dedicated local technician to handle your technology needs — resolving computer issues, managing networks, implementing cybersecurity and sourcing hardware. EvoTech Digital is a Perth-based IT support provider focused on helping small businesses get reliable, practical technology support without the overhead of a large IT department."}},
    {"@type":"Question","name":"How does EvoTech handle IT support requests?","acceptedAnswer":{"@type":"Answer","text":"EvoTech Digital handles support requests via phone, email, and an online ticketing system. Most issues are resolved remotely on the same business day. For hardware or network issues that require a physical visit, on-site support is available across the Perth metropolitan area by appointment."}},
    {"@type":"Question","name":"What does IT support cost for businesses in Perth?","acceptedAnswer":{"@type":"Answer","text":"Business IT support in Perth typically ranges from $80–$150 per user per month for managed support agreements, or $120–$180 per hour for break-fix services. EvoTech Digital offers transparent, flat-rate pricing with no hidden call-out fees. Contact us for a quote tailored to your business size."}},
    {"@type":"Question","name":"Does EvoTech provide on-site IT support across Perth?","acceptedAnswer":{"@type":"Answer","text":"Yes. EvoTech Digital provides both remote and on-site IT support across all Perth metropolitan suburbs. Our technicians can visit your office for hardware issues, network problems, server failures, new equipment installations and regular proactive site visits."}},
    {"@type":"Question","name":"What is the difference between managed IT and break-fix IT support?","acceptedAnswer":{"@type":"Answer","text":"Break-fix IT support means you call when something goes wrong and pay per incident. Managed IT support is proactive — EvoTech monitors your systems 24/7, fixes issues before they cause downtime, and provides unlimited helpdesk for a flat monthly fee. Most Perth businesses save money and lose far less time with managed IT."}},
    {"@type":"Question","name":"Can EvoTech support Microsoft 365 and cloud services for my Perth business?","acceptedAnswer":{"@type":"Answer","text":"Yes. EvoTech Digital provides full Microsoft 365 support including setup, migration, security hardening, Teams configuration, SharePoint and OneDrive management. With Microsoft's Perth data centre now live, local Azure adoption is also faster and more compliant than ever."}},
    {"@type":"Question","name":"Do you provide IT support for small businesses in Perth?","acceptedAnswer":{"@type":"Answer","text":"EvoTech Digital specialises in IT support for Perth small businesses. Working directly with the business owner, we provide practical, jargon-free support — whether that's a one-off fix, ongoing monthly support, or help setting up your cloud environment. No large call centres, just straightforward help from someone who knows your setup."}},
    {"@type":"Question","name":"What IT support services does EvoTech provide in Perth?","acceptedAnswer":{"@type":"Answer","text":"EvoTech Digital provides remote helpdesk support, on-site IT support, Microsoft 365 management, network monitoring, cybersecurity (Essential Eight), hardware procurement, cloud migration, backup and disaster recovery, and strategic IT consulting (vCIO) for Perth businesses."}}
  ]
}
</script>

<style>
  /* ═══════════════════════════════════════════════
     EVOTECH BUSINESS IT SUPPORT PAGE — DESIGN SYSTEM
     Brand:  #0e2240 (navy)  |  #cff394 (lime)
     Accent: #3b82f6 (support blue)
     Inherits theme fonts via var(--body-font) / var(--heading-font)
  ═══════════════════════════════════════════════ */

  .evo-page { font-family: var(--body-font); color: #5e6979; background: #fff; }

  :root {
    --support-blue: #3b82f6;
    --support-blue-soft: rgba(59,130,246,0.10);
  }

  /* ── ANNOUNCE BAR ─────────────────────────── */
  .evo-announce {
    background: #0e2240;
    color: #cff394;
    text-align: center;
    padding: 10px 20px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .evo-announce a { color: #fff; text-decoration: underline; }
  .evo-announce strong { color: #fff; }

  /* ── HERO ─────────────────────────────────── */
  .evo-hero {
    background: #0e2240;
    position: relative;
    overflow: hidden;
    padding: 80px 0 70px;
  }
  .evo-hero::before {
    content: '';
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(59,130,246,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(59,130,246,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    pointer-events: none;
  }
  .evo-hero::after {
    content: '';
    position: absolute;
    top: -80px; right: -120px;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(207,243,148,0.07) 0%, transparent 60%);
    pointer-events: none;
  }
  .evo-hero__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: center;
    position: relative;
    z-index: 1;
  }
  .evo-hero__eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    color: #cff394;
    font-size: 0.78rem; font-weight: 700; letter-spacing: 0.12em;
    text-transform: uppercase; margin-bottom: 18px;
  }
  .evo-hero__eyebrow::before {
    content: ''; display: inline-block; width: 24px; height: 2px;
    background: #cff394; flex-shrink: 0;
  }
  .evo-hero h1 {
    font-family: var(--heading-font);
    font-size: clamp(1.9rem, 4.5vw, 3.2rem);
    font-weight: 700; color: #fff; line-height: 1.13; margin-bottom: 20px;
  }
  .evo-hero h1 span { color: #cff394; }
  .evo-hero__lead { font-size: 1.05rem; color: #c5d3e8; line-height: 1.75; margin-bottom: 28px; }

  /* Response badge */
  .evo-response-badge {
    display: inline-flex; align-items: center; gap: 12px;
    background: rgba(59,130,246,0.15);
    border: 1px solid rgba(59,130,246,0.35);
    border-radius: 8px; padding: 12px 18px; margin-bottom: 28px;
  }
  .evo-response-badge__num {
    font-family: var(--heading-font); font-size: 1.6rem; font-weight: 700; color: #60a5fa; line-height: 1;
  }
  .evo-response-badge__text { font-size: 0.88rem; color: #c5d3e8; line-height: 1.3; }
  .evo-response-badge__text strong { color: #fff; display: block; }

  .evo-hero__actions { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 32px; }
  .evo-btn-lime {
    display: inline-flex; align-items: center; gap: 7px;
    background: #cff394; color: #0e2240;
    padding: 14px 28px; border-radius: var(--button-border-radius, 6px);
    font-weight: 700; font-size: 0.93rem; text-decoration: none;
    transition: background 0.2s, transform 0.2s; border: none;
  }
  .evo-btn-lime:hover { background: #b8e87c; transform: translateY(-2px); text-decoration: none; color: #0e2240; }
  .evo-btn-outline-white {
    display: inline-flex; align-items: center; gap: 7px;
    background: transparent; color: #fff;
    padding: 13px 28px; border-radius: var(--button-border-radius, 6px);
    font-weight: 600; font-size: 0.93rem; text-decoration: none;
    border: 1.5px solid rgba(255,255,255,0.3); transition: border-color 0.2s, color 0.2s;
  }
  .evo-btn-outline-white:hover { border-color: #cff394; color: #cff394; text-decoration: none; }

  .evo-hero__pills {
    display: flex; gap: 10px; flex-wrap: wrap;
    padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.08);
  }
  .evo-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(207,243,148,0.08);
    border: 1px solid rgba(207,243,148,0.18);
    border-radius: 50px; padding: 7px 14px;
    font-size: 0.8rem; font-weight: 600; color: #d8f0b0;
  }
  .evo-pill::before { content: '✓'; color: #cff394; font-weight: 700; }

  /* Hero visual — helpdesk dashboard */
  .evo-helpdesk-vis {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(59,130,246,0.2);
    border-radius: 14px; padding: 28px;
  }
  .evo-vis-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 20px;
  }
  .evo-vis-title { font-size: 0.75rem; font-weight: 700; color: rgba(96,165,250,0.8); text-transform: uppercase; letter-spacing: 0.1em; }
  .evo-vis-live {
    display: flex; align-items: center; gap: 5px;
    font-size: 0.72rem; font-weight: 600; color: #6ee07a;
  }
  .evo-status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: #6ee07a; box-shadow: 0 0 8px #6ee07a;
    animation: statusPulse 2s infinite;
  }
  @keyframes statusPulse { 0%,100%{opacity:1} 50%{opacity:.35} }

  .evo-ticket-row {
    display: flex; align-items: center; gap: 14px;
    padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .evo-ticket-row:last-child { border-bottom: none; }
  .evo-ticket-icon {
    width: 38px; height: 38px; border-radius: 8px; flex-shrink: 0;
    background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.25);
    display: flex; align-items: center; justify-content: center; font-size: 1rem;
  }
  .evo-ticket-info { flex: 1; min-width: 0; }
  .evo-ticket-name { font-size: 0.87rem; font-weight: 600; color: #e8f0fa; }
  .evo-ticket-meta { font-size: 0.72rem; color: #7a90a8; margin-top: 2px; display: flex; gap: 8px; }
  .evo-ticket-badge {
    margin-left: auto; border-radius: 4px; padding: 3px 10px;
    font-size: 0.7rem; font-weight: 700; white-space: nowrap; flex-shrink: 0;
  }
  .evo-badge--resolved { background: rgba(110,224,122,0.15); border: 1px solid rgba(110,224,122,0.3); color: #6ee07a; }
  .evo-badge--active   { background: rgba(59,130,246,0.18); border: 1px solid rgba(59,130,246,0.35); color: #93c5fd; }
  .evo-badge--onsite   { background: rgba(251,191,36,0.15); border: 1px solid rgba(251,191,36,0.3); color: #fbbf24; }

  .evo-vis-stat {
    margin-top: 20px; padding: 14px;
    background: rgba(207,243,148,0.07);
    border: 1px solid rgba(207,243,148,0.14); border-radius: 8px;
    display: flex; gap: 20px; justify-content: space-around; text-align: center;
  }
  .evo-vis-stat__num { font-family: var(--heading-font); font-size: 1.4rem; font-weight: 700; color: #cff394; line-height: 1; }
  .evo-vis-stat__label { font-size: 0.7rem; color: #8fa5bf; margin-top: 3px; }

  /* ── PARTNERS / TRUST BAR ─────────────────── */
  .evo-partners {
    background: #f8f9fd;
    border-top: 1px solid #e2e4e8; border-bottom: 1px solid #e2e4e8;
    padding: 22px 0;
  }
  .evo-partners__inner { display: flex; align-items: center; gap: 16px; flex-wrap: wrap; }
  .evo-partners__label {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; color: #9aa3b0;
    white-space: nowrap; padding-right: 12px; border-right: 1px solid #e2e4e8;
  }
  .evo-partners__logos { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .evo-partner-badge {
    background: #fff; border: 1px solid #e2e4e8; border-radius: 6px;
    padding: 7px 16px; font-size: 0.8rem; font-weight: 700; color: #0e2240; white-space: nowrap;
  }

  /* ── SECTION HEADERS ──────────────────────── */
  .evo-section-head { text-align: center; max-width: 700px; margin: 0 auto 56px; }
  .evo-badge {
    display: inline-block; padding: 4px 14px; border-radius: 50px;
    border: 1.5px solid #0e2240; color: #0e2240;
    font-size: 0.73rem; font-weight: 700; letter-spacing: 0.1em;
    text-transform: uppercase; margin-bottom: 16px;
  }
  .evo-badge--lime  { border-color: #5c7d26; background: rgba(207,243,148,0.15); color: #3a5a10; }
  .evo-badge--blue  { border-color: #2563eb; background: rgba(59,130,246,0.1); color: #1d4ed8; }
  .evo-badge--white { border-color: rgba(255,255,255,0.35); color: #fff; background: rgba(255,255,255,0.07); }
  .evo-section-head h2 {
    font-family: var(--heading-font);
    font-size: clamp(1.6rem, 3vw, 2.4rem); font-weight: 700; color: #0e2240; line-height: 1.2;
  }
  .evo-section-head--light h2 { color: #fff; }
  .evo-section-head p { margin-top: 14px; font-size: 1rem; line-height: 1.7; color: #5e6979; }
  .evo-section-head--light p { color: #b8cce0; }

  /* ── SERVICES GRID ────────────────────────── */
  .evo-services { padding: 88px 0; background: #fff; }
  .evo-services__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .evo-service-card {
    background: #fff; border: 1px solid #e2e4e8; border-radius: 10px;
    padding: 30px 28px; transition: all 0.28s; position: relative; overflow: hidden;
  }
  .evo-service-card::after {
    content: ''; position: absolute; bottom: 0; left: 0; right: 0; height: 3px;
    background: #cff394; transform: scaleX(0); transform-origin: left; transition: transform 0.28s;
  }
  .evo-service-card:hover { box-shadow: 0 8px 32px rgba(14,34,64,0.09); transform: translateY(-3px); border-color: #c4d8a4; }
  .evo-service-card:hover::after { transform: scaleX(1); }
  .evo-service-icon {
    width: 48px; height: 48px; border-radius: 10px;
    background: #f0f8e8; border: 1px solid #d6f0b0;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; margin-bottom: 18px; flex-shrink: 0;
  }
  .evo-service-card h3 { font-family: var(--heading-font); font-size: 1.05rem; font-weight: 700; color: #0e2240; margin-bottom: 10px; line-height: 1.3; }
  .evo-service-card p { font-size: 0.88rem; line-height: 1.65; color: #5e6979; margin: 0; }
  .evo-service-link {
    display: inline-flex; align-items: center; gap: 5px; margin-top: 18px;
    font-size: 0.85rem; font-weight: 700; color: #0e2240; text-decoration: none; transition: gap 0.2s, color 0.2s;
  }
  .evo-service-link:hover { gap: 9px; color: #5c7d26; text-decoration: none; }

  /* ── WHY EVOTECH ──────────────────────────── */
  .evo-why { background: #f8f9fd; padding: 88px 0; }
  .evo-why__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .evo-why__content h2 { font-family: var(--heading-font); font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 700; color: #0e2240; line-height: 1.2; margin-bottom: 16px; }
  .evo-why__content p { color: #5e6979; font-size: 1rem; line-height: 1.7; }
  .evo-why__points { display: flex; flex-direction: column; gap: 14px; margin-top: 28px; }
  .evo-why-item {
    display: flex; gap: 16px; align-items: flex-start;
    background: #fff; border: 1px solid #e2e4e8; border-radius: 10px;
    padding: 20px; transition: border-color 0.2s;
  }
  .evo-why-item:hover { border-color: #cff394; }
  .evo-why-num {
    font-family: var(--heading-font); font-size: 1.6rem; font-weight: 700;
    color: #a8d87a; line-height: 1; min-width: 36px; padding-top: 3px;
  }
  .evo-why-item h4 { font-family: var(--heading-font); font-size: 0.97rem; font-weight: 700; color: #0e2240; margin-bottom: 5px; }
  .evo-why-item p { font-size: 0.87rem; line-height: 1.6; margin: 0; }

  /* Value box */
  .evo-value-box { background: #0e2240; border-radius: 14px; padding: 36px; }
  .evo-value-box__title {
    font-family: var(--heading-font); font-size: 1.1rem; font-weight: 700;
    color: #cff394; margin-bottom: 22px; line-height: 1.3;
  }
  .evo-value-list { display: flex; flex-direction: column; gap: 14px; }
  .evo-value-item {
    display: flex; gap: 14px; align-items: flex-start;
    padding: 16px; background: rgba(255,255,255,0.05);
    border: 1px solid rgba(207,243,148,0.12); border-radius: 8px;
  }
  .evo-value-icon {
    width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0;
    background: rgba(59,130,246,0.15);
    display: flex; align-items: center; justify-content: center; font-size: 1rem;
  }
  .evo-value-label { font-size: 0.9rem; font-weight: 700; color: #e8f0fa; margin-bottom: 3px; }
  .evo-value-desc { font-size: 0.8rem; color: #7a90a8; line-height: 1.5; }
  .evo-cta-inset {
    margin-top: 22px; padding: 18px;
    background: rgba(207,243,148,0.08);
    border: 1px solid rgba(207,243,148,0.2); border-radius: 10px; text-align: center;
  }
  .evo-cta-inset p { color: #b8cce0; font-size: 0.88rem; margin-bottom: 14px; }

  /* ── RESPONSE TIME ────────────────────────── */
  .evo-response-sec { background: #0e2240; padding: 88px 0; }
  .evo-response-sec__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; margin-top: 16px; }
  .evo-response-card {
    background: rgba(255,255,255,0.04); border: 1px solid rgba(59,130,246,0.2);
    border-radius: 12px; padding: 32px 22px; text-align: center; transition: all 0.25s;
  }
  .evo-response-card:hover { background: rgba(59,130,246,0.08); border-color: rgba(59,130,246,0.45); transform: translateY(-3px); }
  .evo-response-icon {
    width: 58px; height: 58px; border-radius: 50%;
    background: rgba(59,130,246,0.15); border: 2px solid #3b82f6;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.5rem; margin: 0 auto 18px;
  }
  .evo-response-time {
    font-family: var(--heading-font); font-size: 1.6rem; font-weight: 700; color: #60a5fa; line-height: 1; margin-bottom: 8px;
  }
  .evo-response-card h3 { font-family: var(--heading-font); font-size: 0.9rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
  .evo-response-card p { font-size: 0.82rem; color: #8fa5bf; margin: 0; line-height: 1.55; }

  /* ── MANAGED vs BREAK-FIX ─────────────────── */
  .evo-compare { background: #fff; padding: 88px 0; }
  .evo-compare__grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .evo-compare__content h2 { font-family: var(--heading-font); font-size: clamp(1.6rem, 3vw, 2.3rem); font-weight: 700; color: #0e2240; line-height: 1.2; margin-bottom: 16px; }
  .evo-compare__content h2 span { color: #3b82f6; }
  .evo-compare__content p { color: #5e6979; font-size: 1rem; line-height: 1.7; }
  .evo-compare__points { display: flex; flex-direction: column; gap: 14px; margin-top: 26px; }
  .evo-compare-point {
    display: flex; gap: 14px; align-items: flex-start;
    background: #f8f9fd; border: 1px solid #e2e4e8; border-radius: 10px; padding: 18px; transition: all 0.2s;
  }
  .evo-compare-point:hover { border-color: #cff394; background: #f0f8e8; }
  .evo-compare-point__icon { font-size: 1.1rem; flex-shrink: 0; margin-top: 2px; }
  .evo-compare-point h4 { font-family: var(--heading-font); font-size: 0.95rem; font-weight: 700; color: #0e2240; margin-bottom: 4px; }
  .evo-compare-point p { font-size: 0.85rem; color: #5e6979; line-height: 1.55; margin: 0; }

  /* Comparison table */
  .evo-ctable {
    background: #f8f9fd; border: 1px solid #e2e4e8; border-radius: 14px; overflow: hidden;
  }
  .evo-ctable-title {
    font-size: 0.75rem; font-weight: 700; color: #5c7d26; text-transform: uppercase;
    letter-spacing: 0.1em; padding: 18px 24px 14px;
    border-bottom: 1px solid #e2e4e8;
  }
  .evo-crow {
    display: grid; grid-template-columns: 1.6fr 1fr 1fr;
    border-bottom: 1px solid #e2e4e8;
  }
  .evo-crow:last-child { border-bottom: none; }
  .evo-crow--head { background: #0e2240; }
  .evo-crow--head .evo-ccell { color: rgba(255,255,255,0.7); font-weight: 700; font-size: 0.76rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .evo-crow--head .evo-ccell--evo { color: #cff394; }
  .evo-ccell { padding: 14px 20px; font-size: 0.87rem; color: #5e6979; }
  .evo-ccell--feat { font-weight: 600; color: #0e2240; }
  .evo-ccell--yes { color: #22c55e; font-weight: 700; text-align: center; }
  .evo-ccell--no  { color: #94a3b8; text-align: center; }
  .evo-ccell--mid { color: #f59e0b; font-weight: 600; text-align: center; font-size: 0.82rem; }
