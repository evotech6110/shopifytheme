{%- comment -%}
  EvoTech — Header (v2, Elevare-pattern)
  Structure:
    ┌─ Top utility bar ─ About | wishlist | account | cart ─┐
    │                                                        │
    │   Logo     Main mega-menu       Search bar           │
    └────────────────────────────────────────────────────────┘
  Mega menu uses nested links from Shopify Navigation → main-menu.
  Search bar uses Shopify's built-in /search endpoint.
{%- endcomment -%}

{%- assign nav = linklists[section.settings.menu] -%}
{%- if nav == blank -%}{%- assign nav = linklists['main-menu'] -%}{%- endif -%}

{%- assign utility = linklists[section.settings.utility_menu] -%}
{%- if utility == blank -%}{%- assign utility = linklists['top-utility'] -%}{%- endif -%}

<header class="evo2 evo2-header" role="banner">
  {%- comment -%} ============ TOP UTILITY BAR ============ {%- endcomment -%}
  <div class="evo2-util">
    <div class="evo2-util__inner">
      <ul class="evo2-util__nav" aria-label="Utility">
        {%- if utility != blank and utility.links.size > 0 -%}
          {%- for link in utility.links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
        {%- else -%}
          <li><a href="/pages/about">About</a></li>
          <li><a href="/pages/contact">Support</a></li>
          <li><a href="/blogs/news">Blog</a></li>
        {%- endif -%}
      </ul>
      <div class="evo2-util__icons">
        {%- if shop.customer_accounts_enabled -%}
          {%- if customer -%}
            <a href="/account" class="evo2-util__link" aria-label="Account">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>{{ customer.first_name | default: 'Account' }}</span>
            </a>
            <a href="/account/logout" class="evo2-util__link">Log out</a>
          {%- else -%}
            <a href="/account/login" class="evo2-util__link">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
              <span>Log in</span>
            </a>
            <a href="/account/register" class="evo2-util__link">Register</a>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ============ MAIN HEADER ============ {%- endcomment -%}
  <div class="evo2-main">
    <div class="evo2-main__inner">
      <a href="/" class="evo2-logo" aria-label="{{ shop.name }} home">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 180 | image_tag: loading: 'eager', alt: shop.name, class: 'evo2-logo__img' }}
        {%- else -%}
          <svg class="evo2-logo__mark" viewBox="0 0 40 40" fill="none" aria-hidden="true">
            <defs>
              <linearGradient id="evo2LogoGrad" x1="0" y1="0" x2="40" y2="40" gradientUnits="userSpaceOnUse">
                <stop offset="0" stop-color="#A8E898"/>
                <stop offset="1" stop-color="#3D2EDE"/>
              </linearGradient>
            </defs>
            <rect x="3" y="3" width="34" height="34" rx="9" fill="url(#evo2LogoGrad)"/>
            <path d="M20 9 L31 20 L20 31 L9 20 Z" fill="rgba(5,4,12,0.94)"/>
            <circle cx="20" cy="20" r="3.4" fill="#A8E898"/>
          </svg>
          <span class="evo2-logo__text">
            <span class="evo2-logo__name">EVO<em>TECH</em></span>
            <span class="evo2-logo__tag">INSPIRE · AUTOMATE · EVOLVE</span>
          </span>
        {%- endif -%}
      </a>

      {%- comment -%} ============ MEGA MENU ============ {%- endcomment -%}
      <nav class="evo2-nav" aria-label="Primary">
        <ul class="evo2-nav__list">
          {%- for link in nav.links -%}
            {%- if link.links != blank -%}
              <li class="evo2-nav__item evo2-nav__item--mega" data-evo2-mega>
                <a href="{{ link.url }}" class="evo2-nav__link"{% if link.active or link.child_active %} aria-current="page"{% endif %}>
                  {{ link.title }}
                  <svg class="evo2-nav__caret" viewBox="0 0 12 12" aria-hidden="true"><path d="M3 5l3 3 3-3" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </a>
                <div class="evo2-mega" role="menu">
                  <div class="evo2-mega__grid">
                    {%- for child in link.links -%}
                      <div class="evo2-mega__col">
                        <a href="{{ child.url }}" class="evo2-mega__col-title">{{ child.title }}</a>
                        {%- if child.links != blank -%}
                          <ul class="evo2-mega__sublist">
                            {%- for grandchild in child.links -%}
                              <li><a href="{{ grandchild.url }}">{{ grandchild.title }}</a></li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}
                      </div>
                    {%- endfor -%}
                  </div>
                  {%- if section.settings.mega_promo_image != blank or section.settings.mega_promo_title != blank -%}
                    <aside class="evo2-mega__promo">
                      {%- if section.settings.mega_promo_image != blank -%}
                        {{ section.settings.mega_promo_image | image_url: width: 480 | image_tag: loading: 'lazy', alt: section.settings.mega_promo_title, class: 'evo2-mega__promo-img' }}
                      {%- endif -%}
                      {%- if section.settings.mega_promo_title != blank -%}
                        <h4 class="evo2-mega__promo-title">{{ section.settings.mega_promo_title }}</h4>
                      {%- endif -%}
                      {%- if section.settings.mega_promo_cta_text != blank -%}
                        <a href="{{ section.settings.mega_promo_cta_link | default: '/pages/contact' }}" class="evo2-mega__promo-cta">{{ section.settings.mega_promo_cta_text }} →</a>
                      {%- endif -%}
                    </aside>
                  {%- endif -%}
                </div>
              </li>
            {%- else -%}
              <li class="evo2-nav__item">
                <a href="{{ link.url }}" class="evo2-nav__link"{% if link.active %} aria-current="page"{% endif %}>{{ link.title }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </nav>

      {%- comment -%} ============ SEARCH + ACTIONS ============ {%- endcomment -%}
      <div class="evo2-actions">
        <form action="/search" method="get" class="evo2-search" role="search">
          <input type="hidden" name="type" value="product">
          <label for="EvoHeaderSearch" class="visually-hidden">Search</label>
          <svg class="evo2-search__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input id="EvoHeaderSearch" type="search" name="q" class="evo2-search__input" placeholder="Search products, brands, services…" autocomplete="off">
          <button type="submit" class="evo2-search__btn" aria-label="Search">Search</button>
        </form>

        <a href="/cart" class="evo2-iconbtn" aria-label="Cart" data-evo2-cart>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          <span class="evo2-iconbtn__count" aria-label="Cart items">{{ cart.item_count }}</span>
        </a>

        {%- if section.settings.cta_text != blank -%}
          <a href="{{ section.settings.cta_link | default: '/pages/contact' }}" class="evo2-cta">{{ section.settings.cta_text }}</a>
        {%- endif -%}

        <button class="evo2-iconbtn evo2-burger" type="button" aria-label="Menu" aria-expanded="false" data-evo2-drawer>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>
</header>

{%- comment -%} ============ MOBILE DRAWER ============ {%- endcomment -%}
<aside class="evo2-drawer" data-evo2-drawer-panel aria-hidden="true">
  <div class="evo2-drawer__inner">
    <button class="evo2-drawer__close" data-evo2-drawer aria-label="Close menu">&times;</button>
    <form action="/search" method="get" class="evo2-drawer__search">
      <input type="hidden" name="type" value="product">
      <input type="search" name="q" placeholder="Search…" aria-label="Search">
      <button type="submit">Go</button>
    </form>
    <ul class="evo2-drawer__nav">
      {%- for link in nav.links -%}
        <li>
          <a href="{{ link.url }}">{{ link.title }}</a>
          {%- if link.links != blank -%}
            <ul class="evo2-drawer__sub">
              {%- for child in link.links -%}
                <li><a href="{{ child.url }}">{{ child.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
    <ul class="evo2-drawer__util">
      <li><a href="/pages/contact">Contact / Support</a></li>
      {%- if shop.customer_accounts_enabled -%}
        {%- if customer -%}
          <li><a href="/account">My account</a></li>
          <li><a href="/account/logout">Log out</a></li>
        {%- else -%}
          <li><a href="/account/login">Log in</a></li>
          <li><a href="/account/register">Register</a></li>
        {%- endif -%}
      {%- endif -%}
      <li><a href="/cart">Cart ({{ cart.item_count }})</a></li>
    </ul>
  </div>
</aside>

<style>
  :root { --evo2-peach: #FF7A4A; --evo2-mint: #A8E898; --evo2-bg: #05040C; --evo2-bg2: #0B0820; --evo2-dim: #B6B5C6; --evo2-muted: #7A7A8F; --evo2-line: rgba(255,255,255,.08); }
  .visually-hidden { position: absolute !important; width: 1px !important; height: 1px !important; padding: 0 !important; margin: -1px !important; overflow: hidden !important; clip: rect(0,0,0,0) !important; white-space: nowrap !important; border: 0 !important; }
  .evo2-header { position: sticky; top: 0; z-index: 200; font-family: 'Satoshi', system-ui, sans-serif; color: #fff; background: rgba(5,4,12,.88); backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px); border-bottom: 1px solid var(--evo2-line); }

  /* ==== TOP UTILITY BAR ==== */
  .evo2-util { background: rgba(11,8,32,.55); border-bottom: 1px solid var(--evo2-line); }
  .evo2-util__inner { max-width: 1400px; margin: 0 auto; padding: 8px 24px; display: flex; justify-content: space-between; align-items: center; gap: 18px; font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 11px; letter-spacing: .12em; text-transform: uppercase; }
  .evo2-util__nav { list-style: none; margin: 0; padding: 0; display: flex; gap: 22px; }
  .evo2-util__nav a { color: var(--evo2-dim); text-decoration: none; transition: color .2s; }
  .evo2-util__nav a:hover { color: var(--evo2-mint); }
  .evo2-util__icons { display: flex; gap: 14px; align-items: center; }
  .evo2-util__link { display: inline-flex; gap: 6px; align-items: center; color: var(--evo2-dim); text-decoration: none; transition: color .2s; }
  .evo2-util__link:hover { color: var(--evo2-mint); }
  @media (max-width: 760px) { .evo2-util__inner { padding: 6px 16px; font-size: 10px; gap: 10px; } .evo2-util__nav { gap: 14px; } .evo2-util__nav li:nth-child(n+3) { display: none; } }

  /* ==== MAIN HEADER ROW ==== */
  .evo2-main__inner { max-width: 1400px; margin: 0 auto; padding: 16px 24px; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 28px; }
  @media (max-width: 1024px) { .evo2-main__inner { grid-template-columns: auto 1fr auto; gap: 14px; } }
  @media (max-width: 760px) { .evo2-main__inner { padding: 12px 16px; } }

  /* Logo */
  .evo2-logo { display: inline-flex; align-items: center; gap: 10px; color: #fff; text-decoration: none; }
  .evo2-logo__mark { width: 40px; height: 40px; flex-shrink: 0; }
  .evo2-logo__img { max-height: 44px; width: auto; }
  .evo2-logo__text { display: flex; flex-direction: column; line-height: 1; }
  .evo2-logo__name { font-family: 'Clash Display', sans-serif; font-size: 20px; font-weight: 700; letter-spacing: 0.01em; }
  .evo2-logo__name em { color: var(--evo2-mint); font-style: normal; }
  .evo2-logo__tag { font-family: 'JetBrains Mono', monospace; font-size: 8.5px; letter-spacing: 0.18em; color: var(--evo2-muted); margin-top: 4px; text-transform: uppercase; }
  @media (max-width: 760px) { .evo2-logo__tag { display: none; } }

  /* Nav */
  .evo2-nav { display: flex; justify-content: center; }
  @media (max-width: 1024px) { .evo2-nav { display: none; } }
  .evo2-nav__list { list-style: none; margin: 0; padding: 0; display: flex; gap: 6px; }
  .evo2-nav__item { position: relative; }
  .evo2-nav__link { display: inline-flex; align-items: center; gap: 6px; padding: 10px 14px; color: #fff; text-decoration: none; font-size: 14px; font-weight: 500; border-radius: 999px; transition: background .2s, color .2s; }
  .evo2-nav__link:hover, .evo2-nav__link[aria-current="page"] { background: rgba(168,232,152,.1); color: var(--evo2-mint); }
  .evo2-nav__caret { width: 10px; height: 10px; transition: transform .2s; }
  .evo2-nav__item--mega:hover .evo2-nav__caret { transform: rotate(180deg); }

  /* Mega menu */
  .evo2-mega { position: absolute; top: calc(100% + 8px); left: 50%; transform: translateX(-50%) translateY(8px); opacity: 0; visibility: hidden; pointer-events: none; min-width: 640px; background: var(--evo2-bg2); border: 1px solid rgba(168,232,152,.18); border-radius: 18px; padding: 28px; box-shadow: 0 24px 60px rgba(0,0,0,.5); display: grid; grid-template-columns: 1fr; gap: 24px; transition: opacity .2s ease, transform .2s ease; z-index: 100; }
  .evo2-nav__item--mega:hover .evo2-mega,
  .evo2-nav__item--mega:focus-within .evo2-mega { opacity: 1; visibility: visible; pointer-events: auto; transform: translateX(-50%) translateY(0); }
  .evo2-mega__grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 24px 36px; }
  .evo2-mega__col-title { display: block; font-family: 'Clash Display', sans-serif; font-size: 15px; color: var(--evo2-mint); text-decoration: none; font-weight: 600; margin-bottom: 10px; letter-spacing: .01em; }
  .evo2-mega__col-title:hover { color: #fff; }
  .evo2-mega__sublist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .evo2-mega__sublist a { color: var(--evo2-dim); text-decoration: none; font-size: 13.5px; line-height: 1.45; transition: color .15s; }
  .evo2-mega__sublist a:hover { color: var(--evo2-mint); }
  .evo2-mega__promo { border-top: 1px solid var(--evo2-line); padding-top: 16px; display: flex; align-items: center; gap: 14px; }
  .evo2-mega__promo-img { width: 80px; height: 80px; object-fit: cover; border-radius: 10px; }
  .evo2-mega__promo-title { margin: 0; font-family: 'Clash Display', sans-serif; font-size: 15px; color: #fff; }
  .evo2-mega__promo-cta { margin-left: auto; color: var(--evo2-mint); font-family: 'JetBrains Mono', monospace; font-size: 12px; text-decoration: none; letter-spacing: .08em; }

  /* Actions (search + icons + CTA) */
  .evo2-actions { display: flex; align-items: center; gap: 12px; justify-self: end; }
  .evo2-search { display: flex; align-items: center; gap: 8px; background: rgba(255,255,255,.05); border: 1px solid var(--evo2-line); border-radius: 999px; padding: 6px 14px 6px 14px; min-width: 280px; max-width: 360px; transition: border-color .2s, background .2s; }
  .evo2-search:focus-within { border-color: var(--evo2-mint); background: rgba(168,232,152,.06); }
  .evo2-search__icon { color: var(--evo2-dim); flex-shrink: 0; }
  .evo2-search__input { flex: 1; border: 0; background: transparent; color: #fff; font-family: inherit; font-size: 13.5px; outline: none; min-width: 0; }
  .evo2-search__input::placeholder { color: var(--evo2-muted); }
  .evo2-search__btn { border: 0; background: var(--evo2-mint); color: #0A0A0A; padding: 6px 14px; border-radius: 999px; font-family: 'JetBrains Mono', monospace; font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; cursor: pointer; }
  .evo2-search__btn:hover { background: #CDFFBF; }
  @media (max-width: 1200px) { .evo2-search { min-width: 220px; } }
  @media (max-width: 1024px) { .evo2-search { display: none; } }

  .evo2-iconbtn { position: relative; width: 40px; height: 40px; display: inline-grid; place-items: center; border-radius: 50%; background: transparent; border: 1px solid transparent; color: #fff; text-decoration: none; cursor: pointer; transition: background .2s, border-color .2s; }
  .evo2-iconbtn:hover { background: rgba(168,232,152,.1); border-color: rgba(168,232,152,.3); color: var(--evo2-mint); }
  .evo2-iconbtn__count { position: absolute; top: -2px; right: -2px; min-width: 18px; height: 18px; padding: 0 5px; background: var(--evo2-peach); color: #0A0A0A; font-family: 'JetBrains Mono', monospace; font-size: 10px; font-weight: 700; border-radius: 999px; display: inline-grid; place-items: center; }

  .evo2-cta { display: inline-flex; align-items: center; padding: 11px 20px; background: var(--evo2-peach); color: #0A0A0A; font-weight: 700; text-decoration: none; border-radius: 999px; font-size: 13.5px; transition: background .2s; }
  .evo2-cta:hover { background: #ff9068; }
  @media (max-width: 760px) { .evo2-cta { padding: 9px 14px; font-size: 12px; } }

  .evo2-burger { display: none; }
  @media (max-width: 1024px) { .evo2-burger { display: inline-grid; } }

  /* ==== MOBILE DRAWER ==== */
  .evo2-drawer { position: fixed; top: 0; right: 0; bottom: 0; width: min(88vw, 380px); background: var(--evo2-bg); border-left: 1px solid var(--evo2-line); z-index: 400; transform: translateX(100%); transition: transform .3s ease; overflow-y: auto; }
  .evo2-drawer[data-open="true"] { transform: translateX(0); }
  .evo2-drawer__inner { padding: 72px 24px 32px; color: #fff; }
  .evo2-drawer__close { position: absolute; top: 18px; right: 18px; width: 40px; height: 40px; border: 1px solid var(--evo2-line); background: transparent; color: #fff; border-radius: 50%; font-size: 28px; line-height: 1; cursor: pointer; }
  .evo2-drawer__search { display: flex; gap: 8px; margin-bottom: 24px; }
  .evo2-drawer__search input { flex: 1; background: rgba(255,255,255,.05); border: 1px solid var(--evo2-line); color: #fff; padding: 10px 14px; border-radius: 10px; font-family: inherit; }
  .evo2-drawer__search button { background: var(--evo2-mint); color: #0A0A0A; border: 0; border-radius: 10px; padding: 10px 18px; font-weight: 700; cursor: pointer; }
  .evo2-drawer__nav, .evo2-drawer__util { list-style: none; margin: 0; padding: 0; }
  .evo2-drawer__nav > li { border-bottom: 1px solid var(--evo2-line); padding: 12px 0; }
  .evo2-drawer__nav > li > a { display: block; color: #fff; text-decoration: none; font-weight: 600; font-size: 16px; }
  .evo2-drawer__sub { list-style: none; margin: 8px 0 0; padding: 0 0 0 12px; }
  .evo2-drawer__sub a { display: block; padding: 6px 0; color: var(--evo2-dim); text-decoration: none; font-size: 14px; }
  .evo2-drawer__util { margin-top: 24px; padding-top: 20px; border-top: 1px solid var(--evo2-line); }
  .evo2-drawer__util li { padding: 8px 0; }
  .evo2-drawer__util a { color: var(--evo2-dim); text-decoration: none; font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; }
</style>

<script>
(function(){
  var drawer = document.querySelector('[data-evo2-drawer-panel]');
  var toggles = document.querySelectorAll('[data-evo2-drawer]');
  function toggle(state){
    var open = state !== undefined ? state : drawer.getAttribute('data-open') !== 'true';
    drawer.setAttribute('data-open', open ? 'true' : 'false');
    drawer.setAttribute('aria-hidden', open ? 'false' : 'true');
    toggles.forEach(function(t){ t.setAttribute('aria-expanded', open ? 'true' : 'false'); });
    document.body.style.overflow = open ? 'hidden' : '';
  }
  if (drawer) { toggles.forEach(function(t){ t.addEventListener('click', function(){ toggle(); }); }); }
})();
</script>

{% schema %}
{
  "name": "Header",
  "tag": "section",
  "class": "section-header",
  "settings": [
    { "type": "header", "content": "Brand" },
    { "type": "image_picker", "id": "logo", "label": "Custom logo (optional — replaces SVG)" },

    { "type": "header", "content": "Navigation" },
    { "type": "link_list", "id": "menu", "label": "Main menu (mega menu)", "default": "main-menu",
      "info": "Edit items in Online Store → Navigation → Main menu. Nested items automatically become mega menu columns." },
    { "type": "link_list", "id": "utility_menu", "label": "Utility bar menu (top-right)", "default": "top-utility",
      "info": "Small links shown above the main nav. Create a 'top-utility' menu in Navigation, or leave blank for defaults (About · Support · Blog)." },

    { "type": "header", "content": "Mega menu promo (optional)" },
    { "type": "image_picker", "id": "mega_promo_image", "label": "Promo image" },
    { "type": "text",         "id": "mega_promo_title", "label": "Promo title" },
    { "type": "text",         "id": "mega_promo_cta_text", "label": "Promo CTA text", "default": "Talk to us" },
    { "type": "url",          "id": "mega_promo_cta_link", "label": "Promo CTA link", "default": "/pages/contact" },

    { "type": "header", "content": "Header CTA button" },
    { "type": "text", "id": "cta_text", "label": "CTA button text", "default": "Support" },
    { "type": "url",  "id": "cta_link", "label": "CTA button link", "default": "/pages/contact" }
  ],
  "presets": [{ "name": "EvoTech — Header" }]
}
{% endschema %}
