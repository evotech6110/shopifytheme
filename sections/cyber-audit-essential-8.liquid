</div>

{% schema %}
{
  "name": "Cyber Audit & Essential 8",
  "tag": "section",
  "class": "evo-service-section",
  "settings": [
    { "type": "header", "content": "Contact Details" },
    { "type": "text", "id": "phone_number", "label": "Phone Number", "default": "0466 911 816" },
    { "type": "text", "id": "email_address", "label": "Email Address", "default": "info@evotech.au" },
    { "type": "header", "content": "Call-to-Action" },
    { "type": "url", "id": "cta_primary_link", "label": "Primary CTA Link" },
    { "type": "header", "content": "Page Options" },
    { "type": "checkbox", "id": "show_announce", "label": "Show Announcement Bar", "default": true }
  ],
  "presets": [{ "name": "Cyber Audit & Essential 8" }]
}
{% endschema %}
