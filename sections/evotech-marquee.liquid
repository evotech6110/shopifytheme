{%- comment -%}
  EvoTech — Emergency Marquee Fix.
  This section has been modified to bypass the "Locked" maintenance message.
{%- endcomment -%}

{%- assign words_csv = 'MANAGED IT | CYBER SECURITY | AI AGENTS | CLOUD | COMPLIANCE | PROCUREMENT' -%}
{%- assign words = words_csv | split: '|' -%}

<section class="evo evo-marquee" aria-hidden="true">
  <div class="evo-marquee__track">
    {%- for i in (1..2) -%}
      {%- for w in words -%}
        <span class="evo-marquee__word">{{ w }}</span>
        <span class="evo-marquee__star">✦</span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{%- if request.page_type == 'index' -%}
  {% section 'evotech-zeropoint-hero' %}
  {% section 'evotech-v3-hero' %}
  {% section 'evotech-v2-product-showcase' %}
  {% section 'evotech-ai-agents' %}
  {% section 'evotech-saas-grid' %}
  {% section 'evotech-process' %}
  {% section 'evotech-logo-strip' %}
  {% section 'evotech-testimonials' %}
  {% section 'evotech-faq' %}
  {% section 'evotech-cta-band' %}
  {% section 'evotech-powered-by' %}
{%- endif -%}

{% schema %}
{
  "name": "EvoTech — Marquee",
  "tag": "section",
  "class": "evo-section-marquee",
  "settings": [
    { "type": "text", "id": "words", "label": "Words (pipe-separated)", "default": "AI Automation|Cyber Security|Observability|Compliance|Governance|Procurement" }
  ],
  "presets": [ { "name": "EvoTech — Marquee" } ]
}
{% endschema %}
