{% comment %}
  EvoTech Digital — Business Account Application Form
  Section file:  sections/business-account-application.liquid
  Template file: templates/page.business-account-application.json
  Sends to:      info@evotech.au via Shopify {% form 'contact' %}
{% endcomment %}

<style>
  /* ── EvoTech Brand Variables (from theme settings_data.json) ── */
  :root {
    --et-navy:        #0e2240;
    --et-navy-deep:   #09172d;
    --et-lime:        #cff394;
    --et-lime-dark:   #5c7d26;
    --et-lime-mid:    #a8d96a;
    --et-lime-bg:     #f2fce8;
    --et-white:       #ffffff;
    --et-bg-light:    #f8f9fd;
    --et-border:      #e2e4e8;
    --et-text:        #5e6979;
    --et-heading:     #0e2240;
    --et-price:       #2b419b;
    --et-error:       #9e3737;
    --et-success:     #0d8226;
    --et-required:    #FF0F0F;
    --et-radius:      8px;
    --et-radius-lg:   12px;
    --et-radius-input: 10px;
  }

  .baf-wrap {
    max-width: 860px;
    margin: 0 auto;
    padding: 40px 20px 80px;
    font-family: 'Merriweather', Georgia, serif;
    color: var(--et-text);
    font-size: 14px;
    line-height: 1.6;
  }

  /* ── Page header ── */
  .baf-page-header {
    background: var(--et-navy);
    border-radius: var(--et-radius-lg);
    padding: 40px 40px 32px;
    margin-bottom: 32px;
    position: relative;
    overflow: hidden;
  }
  .baf-page-header::after {
    content: '';
    position: absolute;
    right: -40px; top: -40px;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: rgba(207,243,148,.08);
    pointer-events: none;
  }
  .baf-header-badge {
    display: inline-block;
    background: var(--et-lime);
    color: var(--et-navy);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 14px;
    font-family: inherit;
  }
  .baf-page-header h1 {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-size: 36px;
    font-weight: 600;
    color: var(--et-white);
    margin: 0 0 10px;
    line-height: 1.15;
  }
  .baf-page-header p {
    color: rgba(255,255,255,.75);
    font-size: 14px;
    max-width: 520px;
    margin: 0;
    line-height: 1.7;
  }
  .baf-header-meta {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid rgba(255,255,255,.15);
    font-size: 12px;
  }
  .baf-header-meta span {
    color: rgba(255,255,255,.65);
  }
  .baf-header-meta strong {
    color: var(--et-lime);
    display: block;
    font-size: 13px;
  }

  /* ── Info notice ── */
  .baf-notice {
    background: var(--et-lime-bg);
    border: 1px solid #b8e084;
    border-left: 4px solid var(--et-lime-dark);
    border-radius: var(--et-radius);
    padding: 14px 18px;
    margin-bottom: 28px;
    font-size: 13px;
    color: #3b5a1a;
  }
  .baf-notice strong { font-weight: 700; color: var(--et-lime-dark); }

  /* ── Section cards ── */
  .baf-section {
    background: var(--et-white);
    border: 1px solid var(--et-border);
    border-radius: var(--et-radius-lg);
    margin-bottom: 24px;
    overflow: hidden;
  }
  .baf-section-head {
    background: var(--et-bg-light);
    border-bottom: 1px solid var(--et-border);
    padding: 18px 28px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .baf-section-icon {
    width: 36px; height: 36px;
    background: var(--et-navy);
    border-radius: var(--et-radius);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 17px;
    flex-shrink: 0;
  }
  .baf-section-head h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 20px;
    font-weight: 600;
    color: var(--et-heading);
    margin: 0 0 2px;
  }
  .baf-section-head p {
    font-size: 12px;
    color: var(--et-text);
    margin: 0;
  }
  .baf-section-body {
    padding: 28px;
  }

  /* ── Sub-heading ── */
  .baf-sub-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--et-navy);
    margin: 24px 0 14px;
    padding-bottom: 8px;
    border-bottom: 2px solid var(--et-lime);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .baf-sub-heading:first-child { margin-top: 0; }

  /* ── Form grid ── */
  .baf-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 16px;
  }
  .baf-row.full { grid-template-columns: 1fr; }
  .baf-row.thirds { grid-template-columns: 1fr 1fr 1fr; }
  .baf-row.auto { grid-template-columns: auto; }

  /* ── Field ── */
  .baf-field {
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .baf-field label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .7px;
    color: var(--et-heading);
    font-family: inherit;
  }
  .baf-field label .req {
    color: var(--et-required);
    font-size: 12px;
    margin-left: 2px;
  }
  .baf-field input,
  .baf-field select,
  .baf-field textarea {
    border: 1px solid var(--et-border);
    border-radius: var(--et-radius-input);
    background: var(--et-white);
    padding: 11px 14px;
    font-family: inherit;
    font-size: 14px;
    color: var(--et-heading);
    width: 100%;
    transition: border-color .15s, box-shadow .15s;
    box-shadow: 0 1px 3px rgba(0,0,0,.05);
  }
  .baf-field input:focus,
  .baf-field select:focus,
  .baf-field textarea:focus {
    outline: none;
    border-color: var(--et-navy);
    box-shadow: 0 0 0 3px rgba(14,34,64,.1);
  }
  .baf-field textarea { resize: vertical; min-height: 80px; }
  .baf-field .hint {
    font-size: 11px;
    color: var(--et-text);
    line-height: 1.5;
  }

  /* ── Divider ── */
  .baf-divider {
    height: 1px;
    background: var(--et-border);
    margin: 24px 0;
  }

  /* ── Same-address toggle ── */
  .baf-checkbox-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    cursor: pointer;
  }
  .baf-checkbox-row input[type="checkbox"] {
    width: 18px; height: 18px;
    accent-color: var(--et-navy);
    flex-shrink: 0;
    cursor: pointer;
  }
  .baf-checkbox-row label {
    font-size: 13px;
    color: var(--et-heading);
    cursor: pointer;
    font-weight: 500;
  }

  /* ── Business type selector ── */
  .baf-type-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 20px;
  }
  .baf-type-btn {
    border: 2px solid var(--et-border);
    border-radius: var(--et-radius);
    padding: 12px 8px;
    text-align: center;
    cursor: pointer;
    font-size: 12px;
    font-weight: 600;
    color: var(--et-text);
    background: var(--et-white);
    transition: all .15s;
    font-family: inherit;
  }
  .baf-type-btn.selected,
  .baf-type-btn:hover {
    border-color: var(--et-navy);
    background: var(--et-bg-light);
    color: var(--et-navy);
  }
  .baf-type-btn .type-icon { font-size: 20px; display: block; margin-bottom: 5px; }

  /* ── T&C ── */
  .baf-tc-scroll {
    background: var(--et-bg-light);
    border: 1px solid var(--et-border);
    border-radius: var(--et-radius);
    height: 240px;
    overflow-y: auto;
    padding: 18px 20px;
    font-size: 12px;
    line-height: 1.75;
    color: #4a5261;
    margin-bottom: 18px;
    scroll-behavior: smooth;
  }
  .baf-tc-scroll::-webkit-scrollbar { width: 6px; }
  .baf-tc-scroll::-webkit-scrollbar-thumb { background: var(--et-border); border-radius: 3px; }
  .baf-tc-scroll::-webkit-scrollbar-thumb:hover { background: #b0b5be; }
  .baf-tc-scroll h4 {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .5px;
    color: var(--et-heading);
    margin: 16px 0 5px;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 14px;
  }
  .baf-tc-scroll h4:first-child { margin-top: 0; }
  .baf-tc-scroll p { margin-bottom: 10px; }
  .baf-tc-scroll ul { margin: 6px 0 10px 18px; }
  .baf-tc-scroll ul li { margin-bottom: 4px; }

  .baf-tc-read-notice {
    background: var(--et-lime-bg);
    border: 1px solid #b8e084;
    border-radius: var(--et-radius);
    padding: 10px 14px;
    font-size: 12px;
    color: var(--et-lime-dark);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .baf-agree-row {
    display: flex;
    gap: 10px;
    margin-bottom: 12px;
    align-items: flex-start;
  }
  .baf-agree-row input[type="checkbox"] {
    width: 18px; height: 18px;
    accent-color: var(--et-navy);
    flex-shrink: 0;
    margin-top: 2px;
    cursor: pointer;
  }
  .baf-agree-row label {
    font-size: 13px;
    line-height: 1.5;
    color: var(--et-heading);
    cursor: pointer;
  }
  .baf-agree-row label a {
    color: var(--et-lime-dark);
    text-decoration: underline;
  }
  .baf-agree-row label .req { color: var(--et-required); }

  /* ── Submit button ── */
  .baf-submit-wrap {
    margin-top: 24px;
    padding-top: 24px;
    border-top: 1px solid var(--et-border);
  }
  .baf-submit-btn {
    background: var(--et-navy);
    color: var(--et-white);
    border: 2px solid var(--et-navy);
    border-radius: var(--et-radius);
    padding: 14px 2rem;
    font-family: inherit;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: .3px;
    cursor: pointer;
    width: 100%;
    transition: background .2s, border-color .2s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
  }
  .baf-submit-btn:hover {
    background: var(--et-navy-deep);
    border-color: var(--et-navy-deep);
  }
  .baf-submit-btn:disabled {
    background: #b0b8c5;
    border-color: #b0b8c5;
    cursor: not-allowed;
  }
  .baf-submit-footer {
    font-size: 11px;
    color: var(--et-text);
    text-align: center;
    margin-top: 12px;
    line-height: 1.6;
  }

  /* ── Success state ── */
  .baf-success {
    display: none;
    background: var(--et-white);
    border: 1px solid var(--et-border);
    border-radius: var(--et-radius-lg);
    padding: 48px 32px;
    text-align: center;
  }
  .baf-success.show { display: block; }
  .baf-success-icon {
    width: 64px; height: 64px;
    background: var(--et-lime);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px;
    font-size: 28px;
  }
  .baf-success h2 {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 28px;
    color: var(--et-heading);
    margin-bottom: 10px;
  }
  .baf-success p { font-size: 14px; color: var(--et-text); max-width: 440px; margin: 0 auto 10px; line-height: 1.7; }
  .baf-ref-box {
    display: inline-block;
    background: var(--et-bg-light);
    border: 1px dashed var(--et-border);
    border-radius: var(--et-radius);
    padding: 10px 24px;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 22px;
    color: var(--et-navy);
    letter-spacing: 2px;
    margin: 14px auto 20px;
  }

  /* ── Error messages ── */
  .baf-field-error {
    font-size: 11px;
    color: var(--et-error);
    margin-top: 3px;
    display: none;
  }
  .baf-field.has-error input,
  .baf-field.has-error select,
  .baf-field.has-error textarea {
    border-color: var(--et-error);
    box-shadow: 0 0 0 3px rgba(158,55,55,.1);
  }
  .baf-field.has-error .baf-field-error { display: block; }

  /* ── Responsive ── */
  @media (max-width: 680px) {
    .baf-page-header { padding: 28px 22px 24px; }
    .baf-page-header h1 { font-size: 26px; }
    .baf-section-body { padding: 20px; }
    .baf-row { grid-template-columns: 1fr; }
    .baf-row.thirds { grid-template-columns: 1fr 1fr; }
    .baf-type-grid { grid-template-columns: 1fr 1fr; }
    .baf-header-meta { gap: 14px; }
  }
  @media (max-width: 420px) {
    .baf-row.thirds { grid-template-columns: 1fr; }
    .baf-type-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<div class="baf-wrap">

  <!-- PAGE HEADER -->
  <div class="baf-page-header">
    <div class="baf-header-badge">Business Account Application</div>
    <h1>Open a Business Account<br>with EvoTech Digital</h1>
    <p>Establish a trading account for your organisation to submit purchase requests for IT hardware, software licences, managed services, and network solutions.</p>
    <div class="baf-header-meta">
      <span><strong>Perth WA 6000</strong>Head Office</span>
      <span><strong>+61 466 911 816</strong>Sales Team</span>
      <span><strong>info@evotech.au</strong>Accounts</span>
      <span><strong>ABN 72 375 743 898</strong>EvoTech Digital</span>
    </div>
  </div>

  <div class="baf-notice">
    <strong>How this works:</strong> Complete this form to open a business account. Once approved, your team can submit purchase requests which EvoTech will quote and process. Payment terms (including deposit and balance structure) are negotiated individually for each order — we do not offer automatic credit lines.
  </div>

  <!-- MAIN FORM — uses Shopify contact form, sends to store email -->
  {% form 'contact', id: 'baf-form' %}

    {% if form.errors %}
      <div class="baf-notice" style="border-left-color: var(--et-error); background:#fdf2f2; color: var(--et-error);">
        <strong>Please correct the following:</strong> {{ form.errors | default_errors }}
      </div>
    {% endif %}

    {% if form.posted_successfully? %}
      <div class="baf-success show">
        <div class="baf-success-icon">✓</div>
        <h2>Application Submitted!</h2>
        <div class="baf-ref-box" id="baf-ref-display">BAF-2026-{{ 'now' | date: '%s' | modulo: 9000 | plus: 1000 }}</div>
        <p>Thank you — your business account application has been received by EvoTech Digital's accounts team. We'll review your details and respond to <strong>{{ form.email }}</strong> within 1–2 business days AWST.</p>
        <p style="font-size:12px; color: var(--et-text);">Questions? Call <strong>+61 466 911 816</strong> or email <strong>info@evotech.au</strong><br>Mon–Fri 8:00am–6:00pm AWST</p>
      </div>

    {% else %}

    <!-- HIDDEN: marks this as business account app so we can identify in inbox -->
    <input type="hidden" name="contact[tags]" value="business-account-application">
    <input type="hidden" name="contact[subject]" value="Business Account Application — EvoTech Digital">

    <!-- ═══════════════════════════════════════════ -->
    <!-- SECTION 1 — COMPANY DETAILS                 -->
    <!-- ═══════════════════════════════════════════ -->
    <div class="baf-section">
      <div class="baf-section-head">
        <div class="baf-section-icon">🏢</div>
        <div>
          <h2>Company Details</h2>
          <p>Your organisation's information — all fields marked * are required</p>
        </div>
      </div>
      <div class="baf-section-body">

        <div class="baf-sub-heading">Business type</div>

        <div class="baf-type-grid" id="bizTypeGrid">
          <button type="button" class="baf-type-btn" onclick="setBizType(this,'Sole Trader')">
            <span class="type-icon">👤</span>Sole Trader
          </button>
          <button type="button" class="baf-type-btn" onclick="setBizType(this,'Partnership')">
            <span class="type-icon">🤝</span>Partnership
          </button>
          <button type="button" class="baf-type-btn selected" onclick="setBizType(this,'Company / Pty Ltd')">
            <span class="type-icon">🏛</span>Company / Pty Ltd
          </button>
          <button type="button" class="baf-type-btn" onclick="setBizType(this,'Other')">
            <span class="type-icon">📋</span>Other
          </button>
        </div>
        <input type="hidden" name="contact[business_type]" id="bizTypeInput" value="Company / Pty Ltd">

        <div class="baf-sub-heading">Company information</div>

        <div class="baf-row">
          <div class="baf-field" id="field-company">
            <label>Company / Trading Name <span class="req">*</span></label>
            <input type="text" name="contact[company_name]" required placeholder="e.g. Acme Corporation Pty Ltd">
            <span class="baf-field-error">Company name is required</span>
          </div>
          <div class="baf-field">
            <label>ABN / ACN</label>
            <input type="text" name="contact[abn]" placeholder="e.g. 30 000 000 000" maxlength="14">
            <span class="hint">Your Australian Business Number or Company Number</span>
          </div>
        </div>

        <div class="baf-row">
          <div class="baf-field">
            <label>Industry / Sector</label>
            <select name="contact[industry]">
              <option value="">Select your industry</option>
              <option>Construction & Infrastructure</option>
              <option>Mining & Resources</option>
              <option>Government / Local Council</option>
              <option>Healthcare & Medical</option>
              <option>Education</option>
              <option>Professional Services (Legal, Finance, Accounting)</option>
              <option>Retail & Wholesale</option>
              <option>Hospitality & Tourism</option>
              <option>Transport & Logistics</option>
              <option>Manufacturing</option>
              <option>Not-for-Profit / NDIS</option>
              <option>Technology</option>
              <option>Other</option>
            </select>
          </div>
          <div class="baf-field">
            <label>Number of Employees</label>
            <select name="contact[employee_count]">
              <option value="">Select range</option>
              <option>1–10</option>
              <option>11–50</option>
              <option>51–200</option>
              <option>201–500</option>
              <option>500+</option>
            </select>
          </div>
        </div>

        <div class="baf-row">
          <div class="baf-field" id="field-website">
            <label>Company Website</label>
            <input type="url" name="contact[website]" placeholder="https://www.yourcompany.com.au">
          </div>
          <div class="baf-field">
            <label>Years in Business</label>
            <input type="number" name="contact[years_in_business]" min="0" max="200" placeholder="e.g. 25">
          </div>
        </div>

        <div class="baf-divider"></div>
        <div class="baf-sub-heading">Primary contact</div>

        <div class="baf-row">
          <div class="baf-field" id="field-contact-name">
            <label>Contact Name <span class="req">*</span></label>
            <input type="text" name="contact[name]" required placeholder="First and last name">
            <span class="baf-field-error">Contact name is required</span>
          </div>
          <div class="baf-field" id="field-job-title">
            <label>Job Title <span class="req">*</span></label>
            <input type="text" name="contact[job_title]" required placeholder="e.g. Purchasing Manager">
            <span class="baf-field-error">Job title is required</span>
          </div>
        </div>

        <div class="baf-row">
          <div class="baf-field" id="field-email">
            <label>Email Address <span class="req">*</span></label>
            <input type="email" name="contact[email]" required placeholder="you@yourcompany.com.au">
            <span class="baf-field-error">A valid email address is required</span>
          </div>
          <div class="baf-field" id="field-phone">
            <label>Phone Number <span class="req">*</span></label>
            <input type="tel" name="contact[phone]" required placeholder="e.g. +61 8 9XXX XXXX">
            <span class="baf-field-error">Phone number is required</span>
          </div>
        </div>

        <div class="baf-row">
          <div class="baf-field">
            <label>Accounts Payable Email</label>
            <input type="email" name="contact[ap_email]" placeholder="accounts@yourcompany.com.au">
            <span class="hint">Where invoices should be sent (if different to above)</span>
          </div>
          <div class="baf-field">
            <label>Accounts Payable Phone</label>
            <input type="tel" name="contact[ap_phone]" placeholder="e.g. +61 8 9XXX XXXX">
          </div>
        </div>

        <div class="baf-divider"></div>
        <div class="baf-sub-heading">Billing address</div>

        <div class="baf-row full">
          <div class="baf-field" id="field-billing-street">
            <label>Street Address <span class="req">*</span></label>
            <input type="text" name="contact[billing_street]" required placeholder="e.g. Level 3, 123 St Georges Terrace">
            <span class="baf-field-error">Billing street address is required</span>
          </div>
        </div>
        <div class="baf-row thirds">
          <div class="baf-field" id="field-billing-city">
            <label>City / Suburb <span class="req">*</span></label>
            <input type="text" name="contact[billing_city]" required>
            <span class="baf-field-error">City is required</span>
          </div>
          <div class="baf-field" id="field-billing-state">
            <label>State <span class="req">*</span></label>
            <select name="contact[billing_state]" required>
              <option value="">Select</option>
              <option>WA</option>
              <option>VIC</option>
              <option>NSW</option>
              <option>QLD</option>
              <option>SA</option>
              <option>TAS</option>
              <option>ACT</option>
              <option>NT</option>
            </select>
            <span class="baf-field-error">State is required</span>
          </div>
          <div class="baf-field" id="field-billing-postcode">
