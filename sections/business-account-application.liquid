</div><!-- /baf-wrap -->

<script>
(function() {

  /* ── Today's date ── */
  var today = new Date();
  var iso = today.toISOString().split('T')[0];
  var sd = document.getElementById('signDate');
  if (sd) sd.value = iso;

  /* ── Business type selector ── */
  window.setBizType = function(btn, val) {
    document.querySelectorAll('.baf-type-btn').forEach(function(b) { b.classList.remove('selected'); });
    btn.classList.add('selected');
    document.getElementById('bizTypeInput').value = val;
  };

  /* ── Delivery address toggle ── */
  window.toggleDelivery = function() {
    var cb = document.getElementById('sameAsBilling');
    var fields = document.getElementById('deliveryFields');
    var delInputs = fields.querySelectorAll('input, select');
    if (cb.checked) {
      fields.style.display = 'none';
      delInputs.forEach(function(el) { el.removeAttribute('required'); });
    } else {
      fields.style.display = 'block';
      delInputs.forEach(function(el) {
        var parentId = el.closest('.baf-field') ? el.closest('.baf-field').id : '';
        if (parentId && parentId.indexOf('del-') === 0) el.setAttribute('required', '');
      });
    }
  };

  /* ── T&C scroll detection ── */
  var tcScroll = document.getElementById('tc-scroll');
  var tcNotice = document.getElementById('tc-read-notice');
  if (tcScroll && tcNotice) {
    tcScroll.addEventListener('scroll', function() {
      var atBottom = (tcScroll.scrollTop + tcScroll.clientHeight) >= (tcScroll.scrollHeight - 30);
      if (atBottom) tcNotice.style.display = 'flex';
    });
  }

  /* ── Build body summary for Shopify email ── */
  function buildBody() {
    var form = document.getElementById('baf-form');
    if (!form) return;
    var fields = form.querySelectorAll('input:not([type=hidden]):not([type=checkbox]):not([type=submit]), select, textarea');
    var lines = ['=== EvoTech Digital — Business Account Application ===', ''];
    fields.forEach(function(f) {
      if (!f.name || f.name === 'contact[body]') return;
      var label = f.name.replace('contact[', '').replace(']', '').replace(/_/g, ' ');
      var val = f.value || '—';
      lines.push(label.toUpperCase() + ': ' + val);
    });
    lines.push('');
    lines.push('--- Agreements ---');
    ['agree1','agree2','agree3'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) {
        var lbl = el.nextElementSibling ? el.nextElementSibling.textContent.trim().substring(0,80) + '...' : id;
        lines.push((el.checked ? '[YES] ' : '[NO]  ') + lbl);
      }
    });
    lines.push('');
    lines.push('Submitted: ' + new Date().toLocaleString('en-AU', {timeZone:'Australia/Perth'}));
    lines.push('Source: evotech.au/pages/business-account-application');
    var bodyEl = document.getElementById('baf-body-hidden');
    if (bodyEl) bodyEl.value = lines.join('\n');
  }

  /* ── Submit handler ── */
  var form = document.getElementById('baf-form');
  if (form) {
    form.addEventListener('submit', function(e) {
      var ok = true;

      /* Check required checkboxes */
      ['agree1','agree2'].forEach(function(id) {
        var el = document.getElementById(id);
        if (el && !el.checked) {
          el.closest('.baf-agree-row').style.outline = '2px solid var(--et-error)';
          el.closest('.baf-agree-row').style.borderRadius = '4px';
          ok = false;
        } else if (el) {
          el.closest('.baf-agree-row').style.outline = '';
        }
      });

      if (!ok) {
        e.preventDefault();
        window.scrollTo({ top: document.getElementById('tc-scroll').offsetTop - 80, behavior: 'smooth' });
        return;
      }

      buildBody();
    });
  }

})();
</script>


