{%- comment -%}
  Evotech Product Showcase
  -------------------------
  Two-part dynamic product section:

  1) FEATURED HERO — a large "Flagship pick" product card bound to a
     Shopify product picked in the theme editor, plus 2-3 side tiles
     (Smart Ecosystems / IronWolf / PC Parts) that link anywhere.

  2) BEST-SELLER GRID — automatically populates from a collection
     (default `best-sellers`) sorted by best-selling, showing rank
     ribbons, live "sold this week" counter, stock state, ratings
     and price comparison.

  Uses product.featured_image when available; falls back to the
  stylised SVG placeholders from the preview.
{%- endcomment -%}

<link rel="preconnect" href="https://api.fontshare.com" crossorigin>
<link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700,800&f[]=satoshi@400,500,700&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Caveat:wght@400;500&family=JetBrains+Mono:wght@400;500;600&display=swap">

<style>
  .evo-ps-{{ section.id }} { --mint:#A8E898; --mint-2:#CDFFBF; --indigo-2:#5B4DFF; --peach:#FF7A4A; --amber:#FFC566; --red:#FF5A6A; --ink:#FFFFFF; --ink-dim:#B6B5C6; --ink-muted:#7A7A8F; --line:rgba(255,255,255,0.08); --font-d:'Clash Display','Satoshi','Inter',sans-serif; --font-s:'Satoshi','Inter',system-ui,sans-serif; --font-m:'JetBrains Mono',ui-monospace,monospace; --ease:cubic-bezier(.21,.83,.33,1); position:relative; padding:clamp(60px,8vw,110px) 0; background:radial-gradient(1200px 500px at 15% -10%, rgba(61,46,222,0.16), transparent 55%),radial-gradient(900px 400px at 85% 110%, rgba(168,232,152,0.08), transparent 60%),linear-gradient(180deg,#05040C 0%,#0A0820 100%); overflow:hidden; color:var(--ink); font-family:var(--font-s); }
  .evo-ps-{{ section.id }} a { color:inherit; text-decoration:none; }
  .evo-ps-{{ section.id }} button { font:inherit; cursor:pointer; }
  .evo-ps-{{ section.id }} .ps-wrap { max-width:1320px; margin:0 auto; padding:0 clamp(20px,4vw,48px); }
  .evo-ps-{{ section.id }} .ps-head { display:grid; grid-template-columns:1fr auto; gap:24px; align-items:end; margin-bottom:clamp(32px,4vw,56px); }
  .evo-ps-{{ section.id }} .ps-eyebrow { font-family:var(--font-m); font-size:11px; letter-spacing:0.3em; text-transform:uppercase; color:var(--mint); margin:0 0 14px 0; }
  .evo-ps-{{ section.id }} .ps-title { font-family:var(--font-d); font-weight:700; font-size:clamp(32px,4.2vw,60px); line-height:1.04; letter-spacing:-0.02em; color:#fff; margin:0; }
  .evo-ps-{{ section.id }} .ps-title em { color:var(--mint); font-style:normal; font-family:'Caveat',cursive; font-weight:500; }
  .evo-ps-{{ section.id }} .ps-head-link { display:inline-flex; align-items:center; gap:8px; font-family:var(--font-m); font-size:12px; letter-spacing:0.2em; text-transform:uppercase; color:var(--mint); border-bottom:1px solid rgba(168,232,152,0.4); padding-bottom:4px; align-self:start; }
  @media (max-width:860px) { .evo-ps-{{ section.id }} .ps-head{grid-template-columns:1fr} }

  .evo-ps-{{ section.id }} .ps-feat { display:grid; grid-template-columns:1.1fr 1fr; gap:28px; align-items:stretch; }
  @media (max-width:980px) { .evo-ps-{{ section.id }} .ps-feat{grid-template-columns:1fr} }
  .evo-ps-{{ section.id }} .ps-hero { position:relative; min-height:540px; border-radius:28px; overflow:hidden; background:radial-gradient(1000px 500px at 80% 100%, rgba(61,46,222,0.35), transparent 60%),radial-gradient(500px 300px at 20% 20%, rgba(168,232,152,0.14), transparent 60%),linear-gradient(145deg,#0F0C2A 0%,#06041A 100%); border:1px solid var(--line); padding:clamp(28px,3vw,44px); display:flex; flex-direction:column; justify-content:space-between; isolation:isolate; }
  .evo-ps-{{ section.id }} .ps-hero::before { content:""; position:absolute; inset:0; z-index:-1; pointer-events:none; background-image:radial-gradient(1px 1px at 15% 25%, rgba(255,255,255,.5), transparent),radial-gradient(1px 1px at 75% 65%, rgba(168,232,152,.4), transparent),radial-gradient(1.5px 1.5px at 50% 85%, rgba(205,255,191,.5), transparent); background-size:800px 800px; opacity:.45; }
  .evo-ps-{{ section.id }} .ps-hero-top { display:flex; justify-content:space-between; align-items:flex-start; gap:16px; position:relative; z-index:2; }
  .evo-ps-{{ section.id }} .ps-kicker { font-family:var(--font-m); font-size:11px; letter-spacing:0.26em; text-transform:uppercase; color:var(--ink-muted); margin:0 0 10px 0; }
  .evo-ps-{{ section.id }} .ps-name { font-family:var(--font-d); font-weight:800; font-size:clamp(32px,3.6vw,56px); line-height:1.02; letter-spacing:-0.02em; margin:0 0 18px 0; color:#fff; }
  .evo-ps-{{ section.id }} .ps-desc { max-width:480px; color:var(--ink-dim); font-size:15px; line-height:1.6; margin:0; }
  .evo-ps-{{ section.id }} .ps-badge { display:inline-flex; align-items:center; gap:6px; background:linear-gradient(90deg,#A8E898 0%,#CDFFBF 100%); color:#0A0A0A; font-family:var(--font-m); font-size:10px; letter-spacing:0.24em; text-transform:uppercase; font-weight:700; padding:6px 12px; border-radius:999px; box-shadow:0 4px 20px rgba(168,232,152,0.35); white-space:nowrap; }
  .evo-ps-{{ section.id }} .ps-badge--live::before { content:""; width:6px; height:6px; border-radius:50%; background:#0A0A0A; animation:psBlinkLive{{ section.id }} 1.2s ease-in-out infinite; }
  @keyframes psBlinkLive{{ section.id }} { 0%,100%{opacity:.3} 50%{opacity:1} }
  .evo-ps-{{ section.id }} .ps-viz { position:relative; z-index:2; margin:28px 0; display:flex; align-items:center; justify-content:center; min-height:220px; }
  .evo-ps-{{ section.id }} .ps-viz img, .evo-ps-{{ section.id }} .ps-viz svg { width:min(340px,70%); height:auto; filter:drop-shadow(0 40px 60px rgba(0,0,0,0.5)); animation:psFeatFloat{{ section.id }} 6s ease-in-out infinite; border-radius:18px; }
  @keyframes psFeatFloat{{ section.id }} { 0%,100%{transform:translateY(-6px)} 50%{transform:translateY(10px)} }
  .evo-ps-{{ section.id }} .ps-meta { position:relative; z-index:2; display:grid; grid-template-columns:1fr auto; gap:18px; align-items:end; }
  .evo-ps-{{ section.id }} .ps-price-row { display:flex; align-items:baseline; gap:14px; flex-wrap:wrap; }
  .evo-ps-{{ section.id }} .ps-price { font-family:var(--font-d); font-weight:800; font-size:clamp(32px,3vw,44px); color:var(--mint); line-height:1; }
  .evo-ps-{{ section.id }} .ps-price-compare { font-family:var(--font-s); font-size:18px; color:var(--ink-muted); text-decoration:line-through; }
  .evo-ps-{{ section.id }} .ps-gst { font-family:var(--font-m); font-size:10px; letter-spacing:0.2em; color:var(--ink-muted); text-transform:uppercase; }
  .evo-ps-{{ section.id }} .ps-cta-row { display:inline-flex; gap:10px; align-items:center; }
  .evo-ps-{{ section.id }} .ps-btn-primary { display:inline-flex; align-items:center; gap:10px; padding:14px 22px; font-family:var(--font-m); font-size:12px; letter-spacing:0.2em; text-transform:uppercase; font-weight:700; background:var(--peach); color:#110A04; border:none; border-radius:10px; transition:transform .2s var(--ease),background .2s var(--ease),box-shadow .2s var(--ease); box-shadow:0 6px 22px rgba(255,122,74,0.3); }
  .evo-ps-{{ section.id }} .ps-btn-primary:hover { transform:translateY(-2px); background:#FF8E62; box-shadow:0 12px 30px rgba(255,122,74,0.5); }
  .evo-ps-{{ section.id }} .ps-btn-ghost { display:inline-flex; align-items:center; justify-content:center; width:44px; height:44px; border:1px solid rgba(255,255,255,0.15); background:transparent; color:#fff; border-radius:10px; transition:background .2s var(--ease),border-color .2s var(--ease),color .2s var(--ease); }
  .evo-ps-{{ section.id }} .ps-btn-ghost:hover { background:rgba(168,232,152,0.08); border-color:rgba(168,232,152,0.5); color:var(--mint); }
  .evo-ps-{{ section.id }} .ps-btn-ghost svg { width:18px; height:18px; }
  .evo-ps-{{ section.id }} .ps-ticker { position:relative; z-index:2; margin-top:18px; padding-top:18px; border-top:1px solid var(--line); display:flex; gap:22px; flex-wrap:wrap; font-family:var(--font-m); font-size:11px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-dim); }
  .evo-ps-{{ section.id }} .ps-ticker-item { display:inline-flex; align-items:center; gap:8px; }
  .evo-ps-{{ section.id }} .ps-ticker-item svg { width:14px; height:14px; color:var(--mint); flex-shrink:0; }
  .evo-ps-{{ section.id }} .ps-ticker-item .dot { width:7px; height:7px; border-radius:50%; background:var(--mint); box-shadow:0 0 10px var(--mint); animation:psLivePulse{{ section.id }} 1.8s ease-in-out infinite; }
  @keyframes psLivePulse{{ section.id }} { 0%,100%{transform:scale(1); opacity:.85} 50%{transform:scale(1.25); opacity:1} }

  .evo-ps-{{ section.id }} .ps-side { display:grid; grid-template-rows:1fr 1fr; gap:28px; }
  .evo-ps-{{ section.id }} .ps-tile { position:relative; border-radius:28px; overflow:hidden; border:1px solid var(--line); background:radial-gradient(800px 400px at 100% 0%, rgba(168,232,152,0.12), transparent 55%),linear-gradient(160deg,#120E2E 0%,#06041A 100%); padding:clamp(24px,2.4vw,36px); min-height:240px; display:flex; flex-direction:column; justify-content:space-between; transition:transform .35s var(--ease),border-color .35s var(--ease); }
  .evo-ps-{{ section.id }} .ps-tile:hover { transform:translateY(-4px); border-color:rgba(168,232,152,0.35); }
  .evo-ps-{{ section.id }} .ps-tile-row-2 { display:grid; grid-template-columns:1fr 1fr; gap:28px; }
  @media (max-width:640px) { .evo-ps-{{ section.id }} .ps-tile-row-2{grid-template-columns:1fr} }
  .evo-ps-{{ section.id }} .ps-tile-top { display:flex; justify-content:space-between; align-items:flex-start; gap:12px; }
  .evo-ps-{{ section.id }} .ps-tile-name { font-family:var(--font-d); font-weight:700; font-size:clamp(22px,2.2vw,30px); line-height:1.05; letter-spacing:-0.01em; margin:6px 0 8px; }
  .evo-ps-{{ section.id }} .ps-tile-desc { color:var(--ink-dim); font-size:13px; line-height:1.5; margin:0; }
  .evo-ps-{{ section.id }} .ps-tile-cta { display:inline-flex; align-items:center; gap:8px; font-family:var(--font-m); font-size:11px; letter-spacing:0.2em; text-transform:uppercase; color:var(--mint); }
  .evo-ps-{{ section.id }} .ps-tile-cta svg { width:14px; height:14px; transition:transform .25s var(--ease); }
  .evo-ps-{{ section.id }} .ps-tile:hover .ps-tile-cta svg { transform:translateX(4px); }
  .evo-ps-{{ section.id }} .ps-pill { display:inline-flex; align-items:center; gap:6px; background:rgba(10,8,26,0.7); color:var(--mint); border:1px solid rgba(168,232,152,0.35); font-family:var(--font-m); font-size:9px; letter-spacing:0.22em; text-transform:uppercase; font-weight:700; padding:5px 10px; border-radius:999px; }
  .evo-ps-{{ section.id }} .ps-pill--hot { background:rgba(255,90,106,0.12); color:#FF8B98; border-color:rgba(255,90,106,0.35); }
  .evo-ps-{{ section.id }} .ps-pill--amber { background:rgba(255,197,102,0.12); color:var(--amber); border-color:rgba(255,197,102,0.35); }

  .evo-ps-{{ section.id }} .ps-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:20px; }
  @media (max-width:1100px) { .evo-ps-{{ section.id }} .ps-grid{grid-template-columns:repeat(3,1fr)} }
  @media (max-width:820px) { .evo-ps-{{ section.id }} .ps-grid{grid-template-columns:repeat(2,1fr)} }
  @media (max-width:520px) { .evo-ps-{{ section.id }} .ps-grid{grid-template-columns:1fr} }
  .evo-ps-{{ section.id }} .ps-card { position:relative; display:flex; flex-direction:column; background:linear-gradient(180deg,rgba(20,18,43,0.7) 0%,rgba(11,8,32,0.7) 100%); border:1px solid var(--line); border-radius:20px; overflow:hidden; transition:transform .35s var(--ease),border-color .35s var(--ease); }
  .evo-ps-{{ section.id }} .ps-card:hover { transform:translateY(-6px); border-color:rgba(168,232,152,0.3); }
  .evo-ps-{{ section.id }} .ps-card-rank { position:absolute; top:14px; left:14px; z-index:4; display:inline-flex; align-items:center; gap:6px; padding:5px 11px; background:linear-gradient(90deg,#A8E898 0%,#CDFFBF 100%); color:#0A0A0A; border-radius:999px; font-family:var(--font-m); font-size:10px; letter-spacing:0.18em; font-weight:700; text-transform:uppercase; box-shadow:0 4px 14px rgba(168,232,152,0.35); }
  .evo-ps-{{ section.id }} .ps-card-rank svg { width:12px; height:12px; }
  .evo-ps-{{ section.id }} .ps-card-wish { position:absolute; top:14px; right:14px; z-index:4; width:34px; height:34px; border-radius:50%; background:rgba(10,8,26,0.75); border:1px solid rgba(255,255,255,0.1); display:inline-flex; align-items:center; justify-content:center; color:#fff; backdrop-filter:blur(6px); transition:color .2s var(--ease),border-color .2s var(--ease),background .2s var(--ease); }
  .evo-ps-{{ section.id }} .ps-card-wish:hover { color:var(--mint); border-color:rgba(168,232,152,0.5); background:rgba(168,232,152,0.08); }
  .evo-ps-{{ section.id }} .ps-card-wish svg { width:16px; height:16px; }
  .evo-ps-{{ section.id }} .ps-card-media { position:relative; aspect-ratio:4/3; background:radial-gradient(ellipse at 50% 100%, rgba(168,232,152,0.12), transparent 60%),linear-gradient(180deg,#14122B 0%,#0A0820 100%); display:flex; align-items:center; justify-content:center; overflow:hidden; }
  .evo-ps-{{ section.id }} .ps-card-media img, .evo-ps-{{ section.id }} .ps-card-media svg { width:65%; height:65%; object-fit:contain; filter:drop-shadow(0 30px 40px rgba(0,0,0,0.6)); animation:psCardFloat{{ section.id }} 5s ease-in-out infinite; }
  .evo-ps-{{ section.id }} .ps-card:nth-child(2n) .ps-card-media img, .evo-ps-{{ section.id }} .ps-card:nth-child(2n) .ps-card-media svg { animation-delay:0.8s; }
  .evo-ps-{{ section.id }} .ps-card:nth-child(3n) .ps-card-media img, .evo-ps-{{ section.id }} .ps-card:nth-child(3n) .ps-card-media svg { animation-delay:1.6s; }
  .evo-ps-{{ section.id }} .ps-card:nth-child(4n) .ps-card-media img, .evo-ps-{{ section.id }} .ps-card:nth-child(4n) .ps-card-media svg { animation-delay:2.4s; }
  @keyframes psCardFloat{{ section.id }} { 0%,100%{transform:translateY(-4px) rotate(-1deg)} 50%{transform:translateY(6px) rotate(1deg)} }
  .evo-ps-{{ section.id }} .ps-card-media::after { content:""; position:absolute; inset:0; background:linear-gradient(to bottom, transparent 60%, rgba(5,4,12,0.95)); pointer-events:none; }
  .evo-ps-{{ section.id }} .ps-card-quick { position:absolute; left:14px; right:14px; bottom:14px; z-index:3; display:flex; gap:8px; transform:translateY(80%); opacity:0; transition:transform .35s var(--ease),opacity .35s var(--ease); }
  .evo-ps-{{ section.id }} .ps-card:hover .ps-card-quick { transform:translateY(0); opacity:1; }
  .evo-ps-{{ section.id }} .ps-card-quick a, .evo-ps-{{ section.id }} .ps-card-quick button { flex:1; min-height:36px; background:rgba(10,8,26,0.88); color:#fff; border:1px solid rgba(255,255,255,0.1); border-radius:10px; font-family:var(--font-m); font-size:10px; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; display:inline-flex; align-items:center; justify-content:center; gap:6px; transition:background .2s var(--ease),border-color .2s var(--ease),color .2s var(--ease); backdrop-filter:blur(6px); }
  .evo-ps-{{ section.id }} .ps-card-quick a:hover, .evo-ps-{{ section.id }} .ps-card-quick button:hover { background:rgba(168,232,152,0.15); border-color:rgba(168,232,152,0.5); color:var(--mint); }
  .evo-ps-{{ section.id }} .ps-card-body { padding:18px 20px 22px; display:flex; flex-direction:column; gap:10px; }
  .evo-ps-{{ section.id }} .ps-card-brand { font-family:var(--font-m); font-size:10px; letter-spacing:0.22em; text-transform:uppercase; color:var(--ink-muted); }
  .evo-ps-{{ section.id }} .ps-card-title { font-family:var(--font-s); font-weight:600; font-size:15px; line-height:1.35; color:#fff; margin:0; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; min-height:42px; }
  .evo-ps-{{ section.id }} .ps-card-rating { display:inline-flex; align-items:center; gap:6px; font-family:var(--font-m); font-size:11px; letter-spacing:0.1em; color:var(--ink-dim); }
  .evo-ps-{{ section.id }} .ps-card-stars { display:inline-flex; color:var(--amber); gap:1px; }
  .evo-ps-{{ section.id }} .ps-card-stars svg { width:12px; height:12px; }
  .evo-ps-{{ section.id }} .ps-card-price-row { display:flex; align-items:baseline; gap:10px; margin-top:4px; }
  .evo-ps-{{ section.id }} .ps-card-price { font-family:var(--font-d); font-weight:800; font-size:22px; color:var(--mint); line-height:1; }
  .evo-ps-{{ section.id }} .ps-card-price-compare { font-family:var(--font-s); font-size:13px; color:var(--ink-muted); text-decoration:line-through; }
  .evo-ps-{{ section.id }} .ps-card-save { font-family:var(--font-m); font-size:10px; letter-spacing:0.18em; text-transform:uppercase; color:var(--peach); font-weight:700; }
  .evo-ps-{{ section.id }} .ps-card-live { padding:12px 20px; border-top:1px solid var(--line); display:flex; justify-content:space-between; align-items:center; gap:10px; background:rgba(5,4,12,0.3); }
  .evo-ps-{{ section.id }} .ps-card-sold { display:inline-flex; align-items:center; gap:8px; font-family:var(--font-m); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--ink-dim); }
  .evo-ps-{{ section.id }} .ps-card-sold .dot { width:6px; height:6px; border-radius:50%; background:var(--mint); box-shadow:0 0 8px var(--mint); animation:psLivePulse{{ section.id }} 1.8s ease-in-out infinite; }
  .evo-ps-{{ section.id }} .ps-card-stock { font-family:var(--font-m); font-size:10px; letter-spacing:0.16em; text-transform:uppercase; color:var(--mint); }
  .evo-ps-{{ section.id }} .ps-card-stock.low { color:var(--amber); }
  .evo-ps-{{ section.id }} .ps-card-stock.out { color:var(--red); }
  .evo-ps-{{ section.id }} .ps-card-meter { margin:0 20px 14px; height:4px; border-radius:3px; background:rgba(255,255,255,0.06); overflow:hidden; position:relative; }
  .evo-ps-{{ section.id }} .ps-card-meter-bar { position:absolute; inset:0 auto 0 0; background:linear-gradient(90deg,var(--mint) 0%,var(--indigo-2) 100%); border-radius:3px; }
</style>

{%- liquid
  assign feat = all_products[section.settings.featured_product]
  assign best_coll = collections[section.settings.bestseller_collection]
  if best_coll == empty or best_coll.products_count == 0
    assign best_coll = collections['best-sellers']
  endif
  assign best_limit = section.settings.bestseller_limit | default: 4
-%}

<div class="evo-ps-{{ section.id }}">
  <!-- =========================== FEATURED ============================= -->
  <section class="ps-wrap" aria-label="{{ section.settings.feat_aria | default: 'Featured product' }}">
    <div class="ps-head">
      <div>
        {%- if section.settings.feat_eyebrow != blank -%}<p class="ps-eyebrow">{{ section.settings.feat_eyebrow }}</p>{%- endif -%}
        <h2 class="ps-title">{{ section.settings.feat_title }}</h2>
      </div>
      {%- if section.settings.feat_link_url != blank -%}
        <a href="{{ section.settings.feat_link_url }}" class="ps-head-link">
          {{ section.settings.feat_link_label | default: 'See all featured' }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="ps-feat">
      <article class="ps-hero" aria-label="{{ feat.title | default: section.settings.feat_name_fallback }}">
        <div class="ps-hero-top">
          <div>
            <p class="ps-kicker">{{ section.settings.feat_product_kicker | default: feat.type | upcase }}</p>
            <h3 class="ps-name">{{ feat.title | default: section.settings.feat_name_fallback }}</h3>
            <p class="ps-desc">{{ section.settings.feat_desc | default: feat.description | strip_html | truncatewords: 40 }}</p>
          </div>
          {%- if section.settings.feat_badge != blank -%}
            <span class="ps-badge ps-badge--live">{{ section.settings.feat_badge }}</span>
          {%- endif -%}
        </div>

        <div class="ps-viz">
          {%- if feat.featured_image -%}
            {{ feat.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', alt: feat.title }}
          {%- else -%}
            <svg viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <linearGradient id="nasCase-{{ section.id }}" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#1A1740"/><stop offset="1" stop-color="#08061A"/></linearGradient>
                <linearGradient id="nasFront-{{ section.id }}" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#2B2763"/><stop offset="1" stop-color="#14122B"/></linearGradient>
                <radialGradient id="nasGlow-{{ section.id }}" cx="50%" cy="100%" r="60%"><stop offset="0" stop-color="#A8E898" stop-opacity="0.35"/><stop offset="1" stop-color="#A8E898" stop-opacity="0"/></radialGradient>
              </defs>
              <ellipse cx="200" cy="240" rx="170" ry="18" fill="url(#nasGlow-{{ section.id }})"/>
              <g>
                <polygon points="110,60 290,60 330,90 330,230 110,230 70,200" fill="url(#nasCase-{{ section.id }})" stroke="#A8E898" stroke-width="1"/>
                <rect x="110" y="60" width="180" height="170" rx="6" fill="url(#nasFront-{{ section.id }})" stroke="#A8E898" stroke-width="1"/>
                <polygon points="110,60 290,60 330,90 150,90" fill="#1F1C50" stroke="#A8E898" stroke-width="1"/>
                <rect x="130" y="90" width="140" height="52" rx="4" fill="rgba(168,232,152,0.05)" stroke="rgba(168,232,152,0.35)"/>
                <rect x="130" y="150" width="140" height="52" rx="4" fill="rgba(168,232,152,0.05)" stroke="rgba(168,232,152,0.35)"/>
                <rect x="140" y="112" width="16" height="8" rx="2" fill="rgba(168,232,152,0.5)"/>
                <rect x="140" y="172" width="16" height="8" rx="2" fill="rgba(168,232,152,0.5)"/>
                <circle cx="250" cy="116" r="3" fill="#A8E898"/><circle cx="260" cy="116" r="3" fill="#CDFFBF"/>
                <circle cx="250" cy="176" r="3" fill="#A8E898"/><circle cx="260" cy="176" r="3" fill="#CDFFBF"/>
              </g>
            </svg>
          {%- endif -%}
        </div>

        <div class="ps-meta">
          <div>
            <div class="ps-price-row">
              <span class="ps-price">{{ feat.price | default: 52495 | money }}</span>
              {%- if feat.compare_at_price > feat.price -%}
                <span class="ps-price-compare">{{ feat.compare_at_price | money }}</span>
                {%- assign save = feat.compare_at_price | minus: feat.price | money -%}
                <span class="ps-pill ps-pill--hot">SAVE {{ save }}</span>
              {%- elsif section.settings.feat_compare_at != blank -%}
                <span class="ps-price-compare">{{ section.settings.feat_compare_at }}</span>
              {%- endif -%}
            </div>
            <span class="ps-gst">{{ section.settings.feat_gst_note | default: 'GST included · Free shipping WA' }}</span>
          </div>
          <div class="ps-cta-row">
            {%- if feat -%}
              <form action="/cart/add" method="post">
                <input type="hidden" name="id" value="{{ feat.selected_or_first_available_variant.id }}">
                <button class="ps-btn-primary" type="submit">
                  Add to cart
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                </button>
              </form>
            {%- else -%}
              <a href="{{ section.settings.feat_cta_url | default: '/collections/featured' }}" class="ps-btn-primary">Shop now
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            {%- endif -%}
            <button class="ps-btn-ghost" type="button" aria-label="Add to wishlist">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>
          </div>
        </div>

        <div class="ps-ticker">
          {%- assign sold48 = feat.metafields.custom.sold_last_48h | default: section.settings.feat_sold_text -%}
          {%- if sold48 != blank -%}
            <span class="ps-ticker-item"><span class="dot"></span>{{ sold48 }}</span>
          {%- endif -%}
          {%- if section.settings.feat_location_text != blank -%}
            <span class="ps-ticker-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8a8 8 0 0 1 16 0C20 17.5 12 22 12 22z"/><circle cx="12" cy="10" r="3"/></svg>
              {{ section.settings.feat_location_text }}
            </span>
          {%- endif -%}
          {%- if section.settings.feat_warranty_text != blank -%}
            <span class="ps-ticker-item">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.feat_warranty_text }}
            </span>
          {%- endif -%}
        </div>
      </article>

      <div class="ps-side">
        {%- assign tile_count = 0 -%}
        {%- for block in section.blocks -%}{% if block.type == 'tile' %}{%- assign tile_count = tile_count | plus: 1 -%}{% endif %}{%- endfor -%}

        {%- comment -%} First tile = large, subsequent 2 tiles go into the row-2 grid {%- endcomment -%}
        {%- assign t_idx = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'tile' and t_idx == 0 -%}
            <article class="ps-tile" {{ block.shopify_attributes }}>
              <div class="ps-tile-top">
                <div>
                  {%- if block.settings.kicker != blank -%}<p class="ps-kicker">{{ block.settings.kicker }}</p>{%- endif -%}
                  <h3 class="ps-tile-name">{{ block.settings.name }}</h3>
                  <p class="ps-tile-desc">{{ block.settings.desc }}</p>
                </div>
                {%- if block.settings.badge != blank -%}<span class="ps-pill ps-pill--amber">{{ block.settings.badge }}</span>{%- endif -%}
              </div>
              {%- if block.settings.image -%}
                <div style="margin-top:14px; display:flex; justify-content:center; min-height:110px;">{{ block.settings.image | image_url: width: 360 | image_tag: loading: 'lazy', style: 'max-height:110px; max-width:80%; object-fit:contain;' }}</div>
              {%- endif -%}
              {%- if block.settings.cta_label != blank -%}
                <a href="{{ block.settings.cta_url | default: '#' }}" class="ps-tile-cta">
                  {{ block.settings.cta_label }}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </a>
              {%- endif -%}
            </article>
            {%- assign t_idx = t_idx | plus: 1 -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if tile_count > 1 -%}
          <div class="ps-tile-row-2">
            {%- assign t_idx2 = 0 -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'tile' -%}
                {%- if t_idx2 > 0 -%}
                  <article class="ps-tile" style="min-height:260px" {{ block.shopify_attributes }}>
                    <div class="ps-tile-top">
                      <div>
                        {%- if block.settings.kicker != blank -%}<p class="ps-kicker">{{ block.settings.kicker }}</p>{%- endif -%}
                        <h3 class="ps-tile-name" style="font-size:clamp(18px,1.6vw,24px)">{{ block.settings.name }}</h3>
                        <p class="ps-tile-desc">{{ block.settings.desc }}</p>
                      </div>
                      {%- if block.settings.badge != blank -%}<span class="ps-pill{% if block.settings.badge_tone == 'hot' %} ps-pill--hot{% elsif block.settings.badge_tone == 'amber' %} ps-pill--amber{% endif %}">{{ block.settings.badge }}</span>{%- endif -%}
                    </div>
                    {%- if block.settings.image -%}
                      <div style="height:90px; display:flex; justify-content:center; align-items:center;">{{ block.settings.image | image_url: width: 280 | image_tag: loading: 'lazy', style: 'max-height:90px; max-width:80%; object-fit:contain;' }}</div>
                    {%- endif -%}
                    {%- if block.settings.cta_label != blank -%}
                      <a href="{{ block.settings.cta_url | default: '#' }}" class="ps-tile-cta">
                        {{ block.settings.cta_label }}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                      </a>
                    {%- endif -%}
                  </article>
                {%- endif -%}
                {%- assign t_idx2 = t_idx2 | plus: 1 -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>

  <!-- =========================== BEST SELLERS ============================= -->
  <section class="ps-wrap" style="margin-top:clamp(60px,8vw,110px)" aria-label="{{ section.settings.best_aria | default: 'Best sellers this week' }}">
    <div class="ps-head">
      <div>
        {%- if section.settings.best_eyebrow != blank -%}<p class="ps-eyebrow">{{ section.settings.best_eyebrow }}</p>{%- endif -%}
        <h2 class="ps-title">{{ section.settings.best_title }}</h2>
      </div>
      {%- if section.settings.best_link_url != blank -%}
        <a href="{{ section.settings.best_link_url | default: best_coll.url }}" class="ps-head-link">
          {{ section.settings.best_link_label | default: 'See full leaderboard' }}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      {%- endif -%}
    </div>

    <div class="ps-grid">
      {%- assign best_products = best_coll.products | sort: 'best-selling' -%}
      {%- for product in best_products limit: best_limit -%}
        {%- assign rank = forloop.index -%}
        {%- assign save_amt = 0 -%}
        {%- if product.compare_at_price > product.price -%}
          {%- assign save_amt = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round -%}
        {%- endif -%}
        {%- assign sold = product.metafields.custom.sold_last_7d | default: product.metafields.custom.sold_this_week -%}
        {%- assign rating = product.metafields.reviews.rating.value | default: product.metafields.loox.avg_rating | default: 4.8 -%}
        {%- assign review_count = product.metafields.reviews.rating_count | default: product.metafields.loox.num_reviews -%}
        {%- assign stock_class = 'in' -%}
        {%- assign stock_label = 'In stock' -%}
        {%- if product.available == false -%}
          {%- assign stock_class = 'out' -%}
          {%- assign stock_label = 'Sold out' -%}
        {%- elsif product.inventory_management != blank and product.inventory_quantity > 0 and product.inventory_quantity < 5 -%}
          {%- assign stock_class = 'low' -%}
          {%- assign stock_label = 'Only ' | append: product.inventory_quantity | append: ' left' -%}
        {%- endif -%}

        <article class="ps-card">
          <span class="ps-card-rank">
            {%- if rank == 1 -%}
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endif -%}
            #{{ rank }} THIS WEEK
          </span>
          <button class="ps-card-wish" aria-label="Wishlist">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
          <a href="{{ product.url }}" class="ps-card-media">
            {%- if product.featured_image -%}
              {{ product.featured_image | image_url: width: 500 | image_tag: loading: 'lazy', alt: product.title }}
            {%- else -%}
              <svg viewBox="0 0 260 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <ellipse cx="130" cy="160" rx="90" ry="8" fill="#A8E898" opacity="0.1"/>
                <rect x="40" y="60" width="180" height="80" rx="4" fill="#14122B" stroke="#A8E898" stroke-width="0.8"/>
                <circle cx="130" cy="100" r="22" fill="none" stroke="rgba(168,232,152,0.5)"/>
                <circle cx="130" cy="100" r="6" fill="#A8E898"/>
              </svg>
            {%- endif -%}
            <div class="ps-card-quick">
              <a href="{{ product.url }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                Quick view
              </a>
              {%- if product.available -%}
                <form action="/cart/add" method="post" style="flex:1; display:flex;">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" style="flex:1;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                    Add to cart
                  </button>
                </form>
              {%- endif -%}
            </div>
          </a>
          <div class="ps-card-body">
            <span class="ps-card-brand">{{ product.vendor | upcase }}{% if product.type != blank %} · {{ product.type | upcase }}{% endif %}</span>
            <h3 class="ps-card-title"><a href="{{ product.url }}">{{ product.title }}</a></h3>
            <div class="ps-card-rating">
              <span class="ps-card-stars">
                {%- assign rounded = rating | round -%}
                {%- for i in (1..5) -%}
                  <svg viewBox="0 0 24 24" fill="currentColor"{% if i > rounded %} opacity="0.4"{% endif %}><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {%- endfor -%}
              </span>
              <span>{{ rating }}{% if review_count %} · {{ review_count }} reviews{% endif %}</span>
            </div>
            <div class="ps-card-price-row">
              <span class="ps-card-price">{{ product.price | money_without_trailing_zeros }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="ps-card-price-compare">{{ product.compare_at_price | money_without_trailing_zeros }}</span>
                <span class="ps-card-save">−{{ save_amt }}%</span>
              {%- endif -%}
            </div>
          </div>
          {%- assign meter_pct = 36 | plus: rank | times: 8 -%}
          {%- if product.metafields.custom.sell_through_pct -%}
            {%- assign meter_pct = product.metafields.custom.sell_through_pct -%}
          {%- else -%}
            {%- assign meter_pct = 90 | minus: rank | times: 12 -%}
          {%- endif -%}
          <div class="ps-card-meter"><div class="ps-card-meter-bar" style="width:{{ meter_pct }}%"></div></div>
          <div class="ps-card-live">
            <span class="ps-card-sold"><span class="dot"></span>{{ sold | default: 0 }} sold this week</span>
            <span class="ps-card-stock {{ stock_class }}">{{ stock_label }}</span>
          </div>
        </article>
      {%- else -%}
        {%- comment -%} Fallback preview cards if the collection is empty {%- endcomment -%}
        {%- for i in (1..4) -%}
          <article class="ps-card">
            <span class="ps-card-rank">#{{ i }} THIS WEEK</span>
            <div class="ps-card-media">
              <svg viewBox="0 0 260 180" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <ellipse cx="130" cy="160" rx="90" ry="8" fill="#A8E898" opacity="0.1"/>
                <rect x="40" y="60" width="180" height="80" rx="4" fill="#14122B" stroke="#A8E898" stroke-width="0.8"/>
                <circle cx="130" cy="100" r="22" fill="none" stroke="rgba(168,232,152,0.5)"/>
                <circle cx="130" cy="100" r="6" fill="#A8E898"/>
              </svg>
            </div>
            <div class="ps-card-body">
              <span class="ps-card-brand">EVOTECH</span>
              <h3 class="ps-card-title">Add products to the best-sellers collection</h3>
              <div class="ps-card-price-row"><span class="ps-card-price">A$—</span></div>
            </div>
            <div class="ps-card-live"><span class="ps-card-sold"><span class="dot"></span>0 sold this week</span><span class="ps-card-stock">In stock</span></div>
          </article>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Evotech Product Showcase",
  "tag": "section",
  "class": "evotech-products-section",
  "settings": [
    { "type": "header", "content": "Featured hero" },
    { "type": "text", "id": "feat_eyebrow", "label": "Eyebrow", "default": "FLAGSHIP PICK · PERTH STOCK" },
    { "type": "html", "id": "feat_title", "label": "Title", "default": "This week's <em>featured</em><br>hardware." },
    { "type": "product", "id": "featured_product", "label": "Featured product", "info": "Price, image, title, description and cart form are pulled automatically." },
    { "type": "text", "id": "feat_name_fallback", "label": "Name fallback (if no product)", "default": "Synology DS223/G" },
    { "type": "text", "id": "feat_product_kicker", "label": "Product kicker override", "default": "HYBRID CLOUD STORAGE · 2-BAY NAS" },
    { "type": "textarea", "id": "feat_desc", "label": "Description override", "default": "The ultimate control centre for your digital life. Enterprise-grade stability for home offices and small-business professionals across Perth." },
    { "type": "text", "id": "feat_badge", "label": "Live badge text", "default": "LIVE · GMC VERIFIED" },
    { "type": "text", "id": "feat_compare_at", "label": "Compare-at price fallback (if no product)", "default": "A$589.00" },
    { "type": "text", "id": "feat_gst_note", "label": "GST / shipping note", "default": "GST included · Free shipping WA" },
    { "type": "text", "id": "feat_sold_text", "label": "Sold-recently text (fallback)", "default": "9 sold in the last 48 hrs" },
    { "type": "text", "id": "feat_location_text", "label": "Warehouse text", "default": "Perth warehouse · 4 in stock" },
    { "type": "text", "id": "feat_warranty_text", "label": "Warranty text", "default": "3-year authorised warranty" },
    { "type": "url", "id": "feat_cta_url", "label": "Fallback CTA URL (if no product)", "default": "/collections/featured" },
    { "type": "text", "id": "feat_link_label", "label": "Head-link label", "default": "See all featured" },
    { "type": "url", "id": "feat_link_url", "label": "Head-link URL", "default": "/collections/featured" },
    { "type": "text", "id": "feat_aria", "label": "Aria-label", "default": "Featured product" },

    { "type": "header", "content": "Best-sellers grid" },
    { "type": "text", "id": "best_eyebrow", "label": "Eyebrow", "default": "BEST SELLERS · LAST 30 DAYS · LIVE FROM SHOPIFY" },
    { "type": "html", "id": "best_title", "label": "Title", "default": "Most <em>shipped</em> gear<br>out of Perth." },
    { "type": "collection", "id": "bestseller_collection", "label": "Best-sellers collection", "info": "Defaults to `best-sellers`. Sorted by best-selling automatically." },
    { "type": "range", "id": "bestseller_limit", "label": "Number of cards", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "text", "id": "best_link_label", "label": "Head-link label", "default": "See full leaderboard" },
    { "type": "url", "id": "best_link_url", "label": "Head-link URL", "default": "/collections/best-sellers" },
    { "type": "text", "id": "best_aria", "label": "Aria-label", "default": "Best sellers this week" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Side tile",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "kicker", "label": "Kicker" },
        { "type": "text", "id": "name", "label": "Name", "default": "Automated Living" },
        { "type": "textarea", "id": "desc", "label": "Description", "default": "Intelligent devices for a future-proof home." },
        { "type": "text", "id": "badge", "label": "Badge text", "default": "PREMIUM TECH" },
        { "type": "select", "id": "badge_tone", "label": "Badge tone", "default": "amber", "options": [
          { "value": "amber", "label": "Amber" },
          { "value": "hot", "label": "Hot (red)" },
          { "value": "mint", "label": "Mint" }
        ]},
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Shop now" },
        { "type": "url", "id": "cta_url", "label": "CTA link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Evotech Product Showcase",
      "blocks": [
        { "type": "tile", "settings": { "kicker": "SMART ECOSYSTEMS", "name": "Automated Living", "desc": "Intelligent devices for a future-proof home. Managed centrally, installed by a local pro.", "badge": "PREMIUM TECH", "badge_tone": "amber", "cta_label": "Shop Smart Home", "cta_url": "/collections/smart-home" } },
        { "type": "tile", "settings": { "kicker": "INDUSTRIAL STORAGE", "name": "IronWolf Pro", "desc": "High-performance enterprise hard drives.", "cta_label": "Explore storage", "cta_url": "/collections/enterprise-hdds" } },
        { "type": "tile", "settings": { "kicker": "PERFORMANCE HARDWARE", "name": "Elite PC Parts", "desc": "Graphics cards, CPUs & RAM.", "badge": "HOT DEALS", "badge_tone": "hot", "cta_label": "Build your rig", "cta_url": "/collections/pc-parts" } }
      ]
    }
  ]
}
{% endschema %}
