<div class="customer-address-wrapper color-{{ section.settings.color_scheme }} gradient-enabled">
    <div class="ic-container">
        <div class="ic-py-13" 
            x-data="{ 
                new_address: false, 
                focusedElement: null, 
                focusNewAddressForm() { 
                    this.$nextTick(() => { 
                        this.$refs.newAddressForm.focus(); 
                    }); 
                }, 
                openNewAddressModal(event) { 
                    this.focusedElement = event.target;
                    this.new_address = true; 
                    this.focusNewAddressForm(); 
                }, 
                closeNewAddressModal() { 
                    this.new_address = false; 
                    if (this.focusedElement) {
                        this.$nextTick(() => {
                            this.focusedElement.focus();
                        });
                    }
                } 
            }" 
            @keydown.window.escape="closeNewAddressModal()" x-cloak>
            <div class="ic-flex ic-flex-row ic-align-items-center ic-justify-content-space-between ic-mb-10 ic-flex-gap-4">
                <h1 class="ic-h2 ic-font-bold">{{ "sections.template_customer_addresses.addresses" | t }}</h1>
            </div>
            
            <button x-on:click="openNewAddressModal($event);" 
                type="button" 
                class="ic-btn ic-btn-primary ic-btn-small ic-mb-8"
                x-ref="openButton">{{ "sections.template_customer_addresses.create_new_address" | t }}</button>
            <div x-show="new_address" class="ic-h-100 ic-w-100 ic-fixed new-address-modal" x-on:click.outside="closeNewAddressModal()">
                <div class="ic-container">
                    <div class="address-form-popup-wrapper">
                        <div class="ic-flex-col-12 ic-flex-col-md-7 ic-flex-col-lg-6 ic-flex-col-xl-5 ic-flex-col-2xl-4 form-popup-inner" x-on:click.stop>
                            <div class="form-popup-container">
                                <div class="form-popup-head">
                                    <h2 class="ic-text-lg ic-font-medium" x-ref="newAddressForm" tabindex="-1">{{ "sections.template_customer_addresses.new_address" | t }}</h2>
                                    <button x-on:click="closeNewAddressModal()" class="close-btn" aria-label="{{ "sections.template_customer_addresses.close_new_address" | t }}">{% render 'icon-close' %}</button>
                                </div>
                    
                                {% form 'customer_address', customer.new_address %}
                                    <div class="form-group">
                                        <label for="address_fname_{{ form.id }}" class="required" aria-label="{{ 'sections.template_customer_addresses.first_name' | t }}">{{ "sections.template_customer_addresses.first_name" | t }}</label>
                                        <input 
                                            type="text" 
                                            name="address[first_name]" 
                                            id="address_fname_{{ form.id }}" 
                                            value="{{ form.first_name }}"
                                            required
                                        >
                                    </div>
                                    <div class="form-group">
                                        <label for="address_lname_{{ form.id }}" class="required" aria-label="{{ 'sections.template_customer_addresses.last_name' | t }}">{{ "sections.template_customer_addresses.last_name" | t }}</label>
                                        <input 
                                            type="text" 
                                            name="address[last_name]" 
                                            id="address_lname_{{ form.id }}" 
                                            value="{{ form.last_name }}"
                                            required
                                        >
                                    </div>
                                    <div class="form-group">
                                        <label for="address_company_{{ form.id }}" aria-label="{{ 'sections.template_customer_addresses.company' | t }}">{{ "sections.template_customer_addresses.company" | t }}</label>
                                        <input 
                                            type="text" 
                                            name="address[company]" 
                                            id="address_company_{{ form.id }}" 
                                            value="{{ form.company }}"
                                        >
                                    </div>
                                    <div class="form-group">
                                        <label for="address_address1_{{ form.id }}" class="required" aria-label="{{ 'sections.template_customer_addresses.address_1' | t }}">{{ "sections.template_customer_addresses.address_1" | t }}</label>
                                        <input 
                                            type="text" 
                                            name="address[address1]" 
                                            id="address_address1_{{ form.id }}" 
                                            value="{{ form.address1 }}"
                                            required
                                        >
                                    </div>
                                    <div class="form-group">
                                        <label for="address_address2_{{ form.id }}" aria-label="{{ 'sections.template_customer_addresses.address_2' | t }}">{{ "sections.template_customer_addresses.address_2" | t }}</label>
                                        <input 
                                            type="text" 
                                            name="address[address2]" 
                                            id="address_address2_{{ form.id }}" 
                                            value="{{ form.address2 }}"
                                        >
                                    </div>
                                    <div class="form-group">
                                        <label for="address_city_{{ form.id }}" aria-label="{{ 'sections.template_customer_addresses.city' | t }}">{{ "sections.template_customer_addresses.city" | t }}</label>
                                        <input 
                                            type="text" 
                                            name="address[city]" 
                                            id="address_city_{{ form.id }}" 
                                            value="{{ form.city }}"
                                        >
                                    </div>
                                    <div class="form-group">
                                        <label for="address_country_{{ form.id }}" aria-label="{{ 'sections.template_customer_addresses.country' | t }}">{{ "sections.template_customer_addresses.country" | t }}</label>
                                        <select 
                                            name="address[country]" 
                                            id="address_country_{{ form.id }}" 
                                            value="{{ form.country }}"
                                            data-country-selector
                                            data-id="{{ form.id }}"
                                        >
                                            {{ all_country_option_tags }}
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="address_province_{{ form.id }}" aria-label="{{ 'sections.template_customer_addresses.state' | t }}">{{ "sections.template_customer_addresses.state" | t }}</label>
                                        <select 
                                            name="address[province]"
                                            id="address_province_{{ form.id }}" 
                                            value="{{ form.province }}"
                                        >
                                        </select>
                                    </div>
                                    <div class="form-group">
                                        <label for="address_zip_{{ form.id }}" aria-label="{{ 'sections.template_customer_addresses.postal_zip_code' | t }}">{{ "sections.template_customer_addresses.postal_zip_code" | t }}</label>
                                        <input 
                                            type="text" 
                                            name="address[zip]" 
                                            id="address_zip_{{ form.id }}" 
                                            value="{{ form.zip }}"
                                        >
                                    </div>
                                    <div class="form-group">
                                        <label for="address_phone_{{ form.id }}" class="required" aria-label="{{ 'sections.template_customer_addresses.phone_number' | t }}">{{ "sections.template_customer_addresses.phone_number" | t }}</label>
                                        <input 
                                            type="tel" 
                                            name="address[phone]" 
                                            id="address_phone_{{ form.id }}" 
                                            value="{{ form.phone }}"
                                            required
                                        >
                                    </div>
                                    <div class="form-group">
                                        <div class="form-checkbox-field">
                                        {{ form.set_as_default_checkbox }}
                                        <label for="address_default_address_{{ form.id }}" aria-label="{{ 'sections.template_customer_addresses.set_as_default_address' | t }}" class="checkbox-label">
                                            <span class="icon-checked">{% render 'icon-check' %}</span>
                                            <span class="checkbox-label-text">{{ "sections.template_customer_addresses.set_as_default_address" | t }}</span>
                                        </label>
                                        </div>
                                    </div>
                                    <div class="form-popup-action">
                                        <button type="submit" class="ic-flex-1 ic-btn ic-btn-primary ic-justify-content-center">{{ "sections.template_customer_addresses.create_address" | t }}</button>
                                        <button x-on:click="closeNewAddressModal()" type="reset" class="ic-flex-1 ic-btn ic-btn-secondary ic-justify-content-center">{{ "sections.template_customer_addresses.cancel" | t }}</button>
                                    </div>
                                {% endform %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div>
                {% paginate customer.addresses by 10 %}
                    <div class="ic-grid ic-grid-template-cols-1 ic-grid-template-cols-md-2 ic-grid-template-cols-lg-3 ic-grid-template-cols-2xl-4 ic-grid-gap-4">
                        {% liquid 
                            for address in customer.addresses
                                if address == customer.default_address 
                                render 'address-card', address: address, color_scheme: section.settings.card_color_scheme
                                endif
                            endfor
                            for address in customer.addresses
                                if address != customer.default_address 
                                render 'address-card', address: address, color_scheme: section.settings.card_color_scheme
                                endif
                            endfor
                        %}
                    </div>
                    {% render 'pagination', pagination: paginate %}
                {% endpaginate %}
            </div>
            <div class="ic-mt-14">
                <a href="{{ routes.account_url | default: '#' }}" class="ic-font-medium ic-base-link">
                    <span class="icon icon-left ic-mr-2">{% render 'icon-left' %}</span>
                    {{ "sections.template_customer_addresses.back_to_account" | t }}
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    class CustomerAdress {
        constructor(){
            this.setCountrySelectorValue();
            this.initCustomerAddress();
            this.setProvinceSelectorValue();
            this.customerAdressesSelector();
            this.initDeleteAddressButtons();
        }

        initDeleteAddressButtons(){
            const deleteButtons = document.querySelectorAll("button[data-delete-address]");
            if(deleteButtons.length < 1) return;

            deleteButtons.forEach(button =>{
                button.addEventListener("click", function(e){
                    var url = this.dataset.url;

                    var confirmation = window.confirm("{{ "sections.template_customer_addresses.delete_confirmation" | t }}");

                    if(confirmation){
                        document.querySelector(`form[action="${url}"]`).submit();
                    }

                })
            })
        }
        
        setCountrySelectorValue(){

            const allAddressesSelector = document.querySelectorAll("select[data-country-selector]");


            if (allAddressesSelector.length < 1) return;

            allAddressesSelector.forEach(select => {

                var selectValue = select.getAttribute('value');


                if(selectValue != '') {
                    
                    const selectOptions = select.options;


                    if(selectOptions.length < 1) return;


                    for (var index = 0; index < selectOptions.length; index++) {

                        var optionHTML = selectOptions[index];

                        window.unescapeHTML = function(html) {
                            optionHTML.innerHTML = html;
                            return optionHTML.textContent;
                        };


                        if (selectValue === optionHTML.textContent) {
                            select.setAttribute('value', optionHTML.getAttribute('value'));

                            break;
                        }
                        
                    }

                }else{
                    var firstOption = select.options[0].getAttribute('value');

                    select.setAttribute('value', firstOption);
                }
            
                
            
            })


        }

        setProvinceSelectorValue(){

            const allAddressesSelector = document.querySelectorAll("select[data-country-selector]");

            if (allAddressesSelector.length < 1) return;

            allAddressesSelector.forEach(select => {

                const allProvincesSelector = document.querySelector(`#address_province_${select.dataset.id}`);



                if (allProvincesSelector.length < 1) return;

                if(allProvincesSelector.getAttribute('value') != '') return;

                var firstOption = allProvincesSelector.options[0].getAttribute('value');

                allProvincesSelector.setAttribute('value', firstOption);

                // console.log(firstOption)

                

            })
        }

        initCustomerAddress(){
            const allAddressesSelector = document.querySelectorAll("select[data-country-selector]");

            if (allAddressesSelector.length < 1) return;

            // console.log(allAddressesSelector);

            allAddressesSelector.forEach(select => {
                var selectedCountry = this.getSelectedCountry(select);

                if(!selectedCountry) return;

                var provinces = selectedCountry.dataset.provinces;

                
                var arrayOfProvince = JSON.parse(provinces);

                var provinceSelector = document.querySelector(`#address_province_${select.dataset.id}`);


                if (arrayOfProvince.length < 1) {
                    provinceSelector.setAttribute('disabled', 'disabled')
                    provinceSelector.setAttribute('value', '');

                }else{
                    provinceSelector.removeAttribute('disabled')
                }

                provinceSelector.innerHTML = '';
                var options='';
                for(var index=0; index < arrayOfProvince.length; index++) {
                    if (arrayOfProvince[index][0] === provinceSelector.getAttribute('value')) {
                        options += `<option value="${arrayOfProvince[index][0]}" selected>${arrayOfProvince[index][0]}</option>`;
                    }else{
                        options += `<option value="${arrayOfProvince[index][0]}">${arrayOfProvince[index][0]}</option>`;

                    }
                }

                provinceSelector.innerHTML = options;

            })
        }

        getSelectedCountry(select){

            

            var option, selectedOption;
            for (var index = 0; index < select.options.length; index++) {
                option = select.options[index];

                if (option.value === select.getAttribute('value')) {
                    selectedOption = option;
                    selectedOption.setAttribute('selected', 'selected');
                    break;
                }
                
            }

            return selectedOption;
        }

        customerAdressesSelector(){
            const addressesSelector = document.querySelectorAll("select[data-country-selector]");
            if(addressesSelector.length < 1) return;

            addressesSelector.forEach(select => {
                select.addEventListener('change', function(e) {
                    this.setAttribute('value', this.options[this.selectedIndex].getAttribute('value'));
                    var provinces = this.options[this.selectedIndex].dataset.provinces;
                    var arrayOfProvince = JSON.parse(provinces);

                    var provinceSelector = document.querySelector(`#address_province_${this.dataset.id}`);

                    if(arrayOfProvince.length < 1){
                        provinceSelector.setAttribute('disabled', 'disabled');
                        provinceSelector.setAttribute('value', '');
                    }else{
                        provinceSelector.removeAttribute('disabled');
                    }

                    provinceSelector.innerHTML = '';
                    var options = '';
                    for (var index = 0; index < arrayOfProvince.length; index++) {
                        options += `<option value="${arrayOfProvince[index][0]}">${arrayOfProvince[index][0]}</option>`;
                        
                    }

                    provinceSelector.innerHTML = options;
                })
            })
        }
    }

    const customerAdress = new CustomerAdress();
</script>

{% schema %}
{
    "name": "t:sections.template_customer_address.name",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "t:settings_schema.general.settings.color_scheme.label",
            "default": "scheme_1"
        },
        {
            "type": "header",
            "content": "t:sections.template_customer_address.settings.cards.content"
        },
        {
            "type": "color_scheme",
            "id": "card_color_scheme",
            "label": "t:settings_schema.general.settings.color_scheme.label",
            "default": "scheme_1"
        }
    ]
}
{% endschema %}