{% style %}
/* ── EvoTech Footer Enhancements ── */
.footer-section h4 {
  font-size: 13px !important;
  font-weight: 700 !important;
  letter-spacing: 1px !important;
  text-transform: uppercase !important;
  color: #cff394 !important;
  margin-bottom: 16px !important;
  padding-bottom: 8px !important;
  border-bottom: 1px solid rgba(255,255,255,0.1) !important;
}
.footer_menu--items a {
  font-size: 14px;
  color: rgba(255,255,255,0.65) !important;
  text-decoration: none !important;
  transition: color 0.15s, padding-left 0.15s !important;
  display: inline-block !important;
}
.footer_menu--items a:hover {
  color: #cff394 !important;
  padding-left: 4px !important;
}
.footer_menu--items .ic-nav-link {
  margin-bottom: 8px !important;
}
.footer_menu--items .ic-nav-link::before {
  content: '›  ';
  color: #cff394;
  opacity: 0.5;
  font-weight: 700;
}
.footer-detail-text p, .footer-detail-text a {
  font-size: 13.5px !important;
  line-height: 1.7 !important;
  color: rgba(255,255,255,0.65) !important;
}
.footer-detail-text a:hover { color: #cff394 !important; }
.footer-content { gap: 32px !important; }
.footer-details {
  border-radius: 12px;
}
.footer-newsletter label {
  font-size: 13px !important;
  font-weight: 600 !important;
}
.footer-newsletter input[type="email"] {
  font-size: 13.5px !important;
  border-radius: 6px 0 0 6px !important;
}
.text-content p { 
  font-size: 13.5px !important; 
  color: rgba(255,255,255,0.65) !important;
  line-height: 1.7 !important;
}
.text-content strong { color: rgba(255,255,255,0.9) !important; }
.text-content a { color: #cff394 !important; text-decoration: none !important; }
.text-content a:hover { text-decoration: underline !important; }
{% endstyle %}
<div class="footer-section ic-break-words color-{{ section.settings.color_scheme }} gradient-enabled ic-pt-7">
  <div class="{% if section.settings.content_width != true %}ic-container{% else %}ic-container-fluid{% endif %}">
    <div class="footer-content">
      <div class="footer-details color-{{ section.settings.content_color_scheme }} gradient-enabled">
        {% liquid
          if section.settings.logo_background
          assign logo_bg_class = ' footer-logo-bg'
          assign logo_bg_color = section.settings.logo_background_color
          assign logo_text_color = section.settings.logo_text_color
          else
          assign logo_bg_class = nil
          assign logo_bg_color = 'transparent'
          assign logo_text_color = nil
          endif
        %}
        <div class="footer-logo{{ logo_bg_class }} ic-mb-1 ic-mb-lg-4" style="--_logo-bg-color: {{ logo_bg_color }}">
          {% if section.settings.footer-logo != nil %}
            {%  liquid
              if section.settings.footer-logo.alt != null
                assign alt = section.settings.footer-logo.alt
              else
                assign alt = section.settings.footer-logo.src | split: '/' | last | split: '.' | first
              endif
            %}
            
            {{
              section.settings.footer-logo
              | image_url: width: 820
              | image_tag:
                loading: 'lazy',
                sizes: '(max-width: 639px) calc(100vw - 40px), (max-width: 767px) 550px, (max-width: 899px) 680px, (max-width: 1024px) 810px, (max-width: 1279px) 300px, 400px',
                widths: '200, 350, 420, 600, 700, 820',
                alt: alt
            }}
            {% else %}
            <a class="ic-inline-flex ic-align-items-center ic-text-no-underline" href="{{ routes.root_url }}" {% if logo_text_color %}style="color: {{ logo_text_color }}"{% endif %}> 
              <span class="ic-h3 ic-break-words" {% if logo_text_color %}style="color: {{ logo_text_color }}"{% endif %}>{{ shop.name }}</span>
            </a>
          {% endif %}
        </div>
        {% if section.settings.footer-text != blank %}
          <div class="footer-detail-text ic-pr-14 ic-mb-3 ic-mb-lg-6">
            <p class="ic-text-sm">{{ section.settings.footer-text }}</p>
          </div>
        {% endif %}
        {% if section.settings.newsletter_enable %}
          <div class="footer-newsletter-container">
            <div class="ic-mr-auto ic-flex ic-mb-lg-6">
              {% form 'customer', id: 'footerContactForm', class: 'footer-newsletter ic-w-100' %}
                <input type="hidden" name="contact[tags]" value="newsletter">
                {% if section.settings.newsletter_heading != blank %}
                  <h3 class="ic-block ic-mb-4 ic-font-medium ic-break-words">{{ section.settings.newsletter_heading }}</h3>
                {% endif %}
                <div class="ic-relative ic-i wrapper">
                  <label
                    for="NewsletterForm--footer"
                    class="ic-screen-reader"
                    aria-label="{{ 'sections.footer.enter_your_email' | t }}">{{ "sections.footer.enter_your_email" | t }}</label>
                  <input
                    type="email"
                    id="NewsletterForm--footer"
                    name="contact[email]"
                    placeholder="{{ "sections.footer.email" | t }}"
                    class="ic-w-100"
                    {% if form.errors %}
                      aria-describedby="footerContactError"
                    {% elsif form.posted_successfully? %}
                      aria-describedby="footerContactSuccess"
                    {% endif %}
                    required />
                  <button
                    type="submit"
                    name="commit"
                    aria-label="{{ 'sections.footer.aria_label.newsletter_submit' | t }}">{% render 'icon-right' %}</button>
                </div>
                {% if form.errors %}
                  {% render 'form-error', form: form, error_id: 'footerContactError' %}
                {% elsif form.posted_successfully? %}
                  <div class="success-box ic-text-sm ic-font-medium" id="footerContactSuccess">
                    <span>{% render 'icon-success' %}</span>
                    {{ "sections.footer.posted_succesfully" | t }}
                  </div>
                {% endif %}

              {% endform %}
            </div>
          </div>
        {% endif %}
        {% if shop.features.follow_on_shop? and section.settings.follow_on_shop %}
          <div class="follow-shop-button">
            {{ shop | login_button: action: 'follow' }}
          </div>
        {% endif %}
        {% liquid
          if settings.social_facebook_link != blank or settings.social_instagram_link != blank or settings.social_x_link != blank or settings.social_threads_link != blank or settings.social_whatsapp_link != blank or settings.social_pinterest_link != blank or settings.social_tiktok_link != blank or settings.social_tumblr_link != blank or settings.social_snapchat_link != blank or settings.social_youtube_link != blank or settings.social_vimeo_link != blank or settings.social_spotify_link != blank or settings.social_linkedin_link != blank or settings.social_discord_link != blank or settings.social_email_link != blank
          assign socials = true
          else
          assign socials = false
          endif
          if section.settings.social_media and socials
          assign social_media = true
          else
          assign social_media = false
          endif
        %}
        {% if social_media %}
          {% assign icon_style = section.settings.social_icon_style %}
          <div class="ic-flex footer-social-container ic-mt-3 ic-mt-lg-auto">
            <ul class="ic-flex footer-social-list">
              {% if settings.social_facebook_link != blank %}
                <li>
                  <a
                    href="{{ settings.social_facebook_link | default: '#' }}"
                    class="ic-inline-block"
                    target="_blank"
                    aria-label="{{ 'sections.footer.aria_label.facebook_link' | t }}. {{ 'general.open_new_window' | t }}">
                    {% render 'icon-facebook', style: icon_style %}
                  </a>
                </li>
              {% endif %}
              {% if settings.social_instagram_link != blank %}
                <li>
                  <a
                    href="{{ settings.social_instagram_link | default: '#' }}"
                    class="ic-inline-block"
                    target="_blank"
                    aria-label="{{ 'sections.footer.aria_label.instagram_link' | t }}. {{ 'general.open_new_window' | t }}">
                    {% render 'icon-instagram', style: icon_style %}
                  </a>
                </li>
              {% endif %}
              {% if settings.social_x_link != blank %}
                <li>
                  <a
                    href="{{ settings.social_x_link | default: '#' }}"
                    class="ic-inline-block"
                    target="_blank"
                    aria-label="{{ 'sections.footer.aria_label.x_link' | t }}. {{ 'general.open_new_window' | t }}">
                    {% render 'icon-x', style: icon_style %}
                  </a>
                </li>
              {% endif %}
              {% if settings.social_threads_link != blank %}
                <li>
