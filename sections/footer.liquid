          </div>
        {% endif %}
      </div>
      <div class="footer-nav-container color-{{ section.settings.content_color_scheme }} gradient-enabled">
        {%- comment -%} EvoTech Footer — hardcoded columns for reliability {%- endcomment -%}
        <div class="footer-menu-wrapper footer-menu-grid-4">

          {%- comment -%} Column 1: Brand / Contact {%- endcomment -%}
          <div class="footer-text-column">
            <h4>EvoTech Digital</h4>
            <div class="text-content ic-break-words">
              <p>Perth's trusted Managed IT Services provider for small to medium businesses across Western Australia.</p>
              <p>
                <strong>&#128205;</strong> Perth, WA 6000<br>
                <strong>&#128222;</strong> <a href="tel:+61466911816">+61 466 911 816</a><br>
                <strong>&#128231;</strong> <a href="mailto:info@evotech.au">info@evotech.au</a><br>
                <strong>ABN:</strong> 72 375 743 898
              </p>
              <p>Mon&ndash;Fri: 8:00am &ndash; 6:00pm AWST</p>
            </div>
          </div>

          {%- comment -%} Column 2: IT Services {%- endcomment -%}
          <div class="footer-menu-column">
            <h4>IT Services Perth</h4>
            <nav class="footer_menu--items footer-nav" aria-label="IT Services">
              <ul class="ic-block">
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/managed-it-services-perth">Managed IT Services</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/cyber-security-perth">Cyber Security Solutions</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/business-it-support">IT Support Perth</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/cloud-migration-services">Cloud & Microsoft 365</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/it-consulting-vcio">IT Consulting & vCIO</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/network-design-security">Network Design & Security</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/managed-print-services">Managed Print Services</a></li>
              </ul>
            </nav>
          </div>

          {%- comment -%} Column 3: Company {%- endcomment -%}
          <div class="footer-menu-column">
            <h4>Company</h4>
            <nav class="footer_menu--items footer-nav" aria-label="Company">
              <ul class="ic-block">
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}">Home</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/contact">Contact Us</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}collections/all">IT Catalog</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/it-procurement-perth">IT Procurement</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/onsite-it-support-perth">Onsite IT Support</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/remote-it-support">Remote IT Support</a></li>
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}blogs/news">Blog & IT Tips</a></li>
              </ul>
            </nav>
          </div>

          {%- comment -%} Column 4: Policies — uses Shopify native policy URLs {%- endcomment -%}
          <div class="footer-menu-column">
            <h4>Policies &amp; Legal</h4>
            <nav class="footer_menu--items footer-nav" aria-label="Legal">
              <ul class="ic-block">
                {%- if shop.privacy_policy.body != blank %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
                {%- else %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}policies/privacy-policy">Privacy Policy</a></li>
                {%- endif %}
                {%- if shop.refund_policy.body != blank %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ shop.refund_policy.url }}">Return &amp; Refund Policy</a></li>
                {%- else %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}policies/refund-policy">Return &amp; Refund Policy</a></li>
                {%- endif %}
                {%- if shop.shipping_policy.body != blank %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ shop.shipping_policy.url }}">Shipping Policy</a></li>
                {%- else %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}policies/shipping-policy">Shipping Policy</a></li>
                {%- endif %}
                {%- if shop.terms_of_service.body != blank %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ shop.terms_of_service.url }}">Terms of Service</a></li>
                {%- else %}
                  <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}policies/terms-of-service">Terms of Service</a></li>
                {%- endif %}
                <li class="ic-nav-link ic-mb-3"><a href="{{ routes.root_url }}pages/contact">Contact Information</a></li>
              </ul>
            </nav>
          </div>

        </div>
        {% if section.settings.payment_method and shop.enabled_payment_types.size > 0 %}
          <div class="ic-w-100 ic-flex ic-align-items-center ic-mt-4">
            <p class="ic-text-sm ic-mr-4">{{ 'sections.footer.we_accept' | t }}:</p>
            <div class="ic-flex payment-icons">
              {% for type in shop.enabled_payment_types -%}
                {{ type | payment_type_svg_tag }}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
    </div>
    <div class="ic-flex ic-py-7">
      {% liquid
        if section.settings.lower_footer_alignment == 'ic-justify-content-center'
          assign text_align = 'ic-text-center'
          else
          assign text_align = 'ic-text-left'
        endif
      %}
      <div class="ic-w-100">
        {%- comment -%} SEO Bottom Bar {%- endcomment -%}
        <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 24px; display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
          {%- comment -%} Copyright + ABN {%- endcomment -%}
          <p style="font-size: 13px; color: rgba(255,255,255,0.55); margin: 0;">
            © {{ 'now' | date: "%Y" }} <a href="{{ routes.root_url }}" style="color: rgba(255,255,255,0.75); text-decoration: none; font-weight: 600;">{{ shop.name }}</a> — ABN: 72 375 743 898. All rights reserved.
          </p>
          {%- comment -%} Policy links using Shopify native URLs {%- endcomment -%}
          <nav aria-label="Legal">
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: 16px;">
              <li><a href="{{ shop.privacy_policy.url | default: '/policies/privacy-policy' }}" style="font-size: 12.5px; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='#cff394'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Privacy Policy</a></li>
              <li><a href="{{ shop.refund_policy.url | default: '/policies/refund-policy' }}" style="font-size: 12.5px; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='#cff394'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Return & Refund Policy</a></li>
              <li><a href="{{ shop.shipping_policy.url | default: '/policies/shipping-policy' }}" style="font-size: 12.5px; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='#cff394'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Shipping Policy</a></li>
              <li><a href="{{ shop.terms_of_service.url | default: '/policies/terms-of-service' }}" style="font-size: 12.5px; color: rgba(255,255,255,0.5); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='#cff394'" onmouseout="this.style.color='rgba(255,255,255,0.5)'">Terms of Service</a></li>
            </ul>
          </nav>
        </div>
        {%- comment -%} SEO Location Keywords Row {%- endcomment -%}
        <p style="font-size: 11.5px; color: rgba(255,255,255,0.3); margin: 12px 0 0; text-align: center; line-height: 1.6;">
          Managed IT Services Perth &nbsp;·&nbsp; IT Support Perth &nbsp;·&nbsp; Cyber Security Perth &nbsp;·&nbsp; Cloud Migration Perth &nbsp;·&nbsp; IT Consulting Perth WA &nbsp;·&nbsp; Microsoft 365 Perth &nbsp;·&nbsp; Network Security Perth
        </p>
      </div>
    </div>
  </div>
</div>
{% schema %}
  {
    "name": "t:sections.footer.name",
    "tag": "footer",
    "class": "section-footer",
    "settings": [
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "t:sections.footer.settings.background_color_scheme.label",
        "default": "scheme_1"
      },
      {
        "type": "checkbox",
        "id": "content_width",
        "label": "t:sections.footer.settings.content_width.label",
        "default": false
      },
      {
        "type": "color_scheme",
        "id": "content_color_scheme",
        "label": "t:sections.footer.settings.content_color_scheme.label",
        "default": "scheme_3"
      },
      {
        "type": "header",
        "content": "t:sections.footer.settings.details.content"
      },
      {
        "type": "image_picker",
        "id": "footer-logo",
        "label": "t:sections.footer.settings.logo.label",
        "info": "t:sections.footer.settings.logo.info"
      },
      {
        "type": "checkbox",
        "id": "logo_background",
        "default": false,
        "label":"t:sections.footer.settings.logo_background.label"
      },
      {
        "type": "color",
        "id": "logo_background_color",
        "default": "#cff394",
        "label": "t:sections.footer.settings.logo_background_color.label",
        "info": "t:sections.footer.settings.logo_background.info"
      },
      {
        "type": "color",
        "id": "logo_text_color",
        "default": "#3d3d3d",
        "label": "t:sections.footer.settings.logo_text.label",
        "info": "t:sections.footer.settings.logo_background.info"
      },
      {
        "type": "text",
        "id": "footer-text",
        "default": "Use this text to outline about your brand's story and future.",
        "label": "t:sections.footer.settings.footer_text.label",
        "info": "t:sections.footer.settings.footer_text.info"
      },
      {
        "type": "header",
        "content": "t:sections.footer.settings.email_signup.label",
        "info": "t:sections.footer.settings.email_signup.info"
      },
