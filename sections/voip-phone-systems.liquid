<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is VoIP and how does it benefit my Perth business?",
      "acceptedAnswer": { "@type": "Answer", "text": "VoIP (Voice over IP) routes your business calls over the internet instead of traditional phone lines — delivering better call quality, lower monthly costs, mobile app access and features like auto attendant, call recording and voicemail-to-email that traditional PABX systems charge extra for." }
    },
    {
      "@type": "Question",
      "name": "Can I keep my existing Perth phone number when switching to VoIP?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Number porting transfers your current Perth business phone numbers to your new VoIP system so clients continue reaching you on the same number. EvoTech Digital manages the full porting process with your current carrier — minimal disruption to incoming calls." }
    },
    {
      "@type": "Question",
      "name": "Does Microsoft Teams replace my phone system?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — with Microsoft Teams Calling (Direct Routing), Teams becomes your full business phone system. Your Perth team makes and receives external calls directly inside Teams on any device — desktop, laptop or mobile — with no separate phone app required." }
    },
    {
      "@type": "Question",
      "name": "How reliable is VoIP for Perth business use?",
      "acceptedAnswer": { "@type": "Answer", "text": "Modern cloud VoIP is highly reliable for Perth businesses. EvoTech Digital assesses your internet connection speed and configures QoS on your network router before go-live — prioritising voice traffic to ensure clear, uninterrupted calls even when other staff are using the internet." }
    },
    {
      "@type": "Question",
      "name": "How much does a business VoIP system cost in Perth?",
      "acceptedAnswer": { "@type": "Answer", "text": "Hosted VoIP for Perth businesses typically costs $15–$35 per user per month depending on the platform and call inclusions — significantly less than traditional PABX maintenance and PSTN line rental. Contact EvoTech Digital for a free VoIP assessment and tailored quote." }
    }
  ]
}
</script>

