<div class="rich-text-wrapper color-{{ section.settings.color_scheme }} gradient-enabled">
    <div class="ic-container ic-flex {{ section.settings.text_position }} ic-py-md-20">
        <div class="ic-flex-col-12 {{ section.settings.text_width }} {{ section.settings.text_align }} ic-break-words">
            {% for block in section.blocks %}
                {% case block.type %}
                    {% when 'heading' %}
                        {% if block.settings.heading != empty %}
                            <div class="ic-my-4 richtext-container" {{ block.shopify_attributes }}>
                                <h2>{{ block.settings.heading }}</h2>
                            </div>
                        {% endif %}
                    {% when 'subheading' %}
                        {% if block.settings.subheading != empty %}
                            <div class="ic-h4 ic-my-4 richtext-container" {{ block.shopify_attributes }}>
                            {{ block.settings.subheading }}
                            </div>
                        {% endif %}
                    {% when 'text' %}
                        {% if block.settings.description != empty %}
                            <div class="ic-my-4 richtext-container" {{ block.shopify_attributes }}>{{ block.settings.description }}</div>
                        {% endif %}
                    {% when 'buttons' %}
                        {% if block.settings.first_button_label != empty or block.settings.second_button_label != empty %}
                            {% liquid
                                if section.settings.text_align == 'ic-text-left'
                                assign button_align = 'ic-justify-content-start'
                                elsif section.settings.text_align == 'ic-text-center'
                                assign button_align = 'ic-justify-content-center'
                                elsif section.settings.text_align == 'ic-text-right'
                                assign button_align = 'ic-justify-content-end'
                                endif
                            %}
                            <div class="ic-flex ic-flex-gap-8 {{ button_align }} ic-my-6" {{ block.shopify_attributes }}>
                                {% if block.settings.first_button_label != empty %}
                                    <a href="{{ block.settings.first_button_link | default: '#' }}" class="ic-btn {{ block.settings.first_button_style }} ic-max-w-100">{{ block.settings.first_button_label }}</a>
                                {% endif %}
                                {% if block.settings.second_button_label != empty %}
                                    <a href="{{ block.settings.second_button_link | default: '#' }}" class="ic-btn {{ block.settings.second_button_style }} ic-max-w-100">{{ block.settings.second_button_label }}</a>
                                {% endif %}
                            </div>
                        {% endif %}
                        
                {% endcase %}
            {% endfor %}
        </div>
    </div>
</div>

{% schema %}
{
    "name": "t:sections.rich_text.name",
    "class": "section",
    "tag": "section",
    "settings":[
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "t:settings_schema.general.settings.color_scheme.label",
            "default": "scheme_1"
        },
        {
            "type":"select",
            "id":"text_width",
            "options":[
                {
                    "value":"ic-flex-col-lg-8",
                    "label":"t:sections.rich_text.settings.text_width.option_1.label"
                },
                {
                    "value":"ic-flex-col-lg-10",
                    "label":"t:sections.rich_text.settings.text_width.option_2.label"
                },
                {
                    "value":"ic-flex-col-lg-12",
                    "label":"t:sections.rich_text.settings.text_width.option_3.label"
                }
            ],
            "default":"ic-flex-col-lg-8",
            "label":"t:sections.rich_text.settings.text_width.label"
        },
        {
            "type":"select",
            "id":"text_position",
            "options":[
                {
                    "value":"ic-justify-content-start",
                    "label":"t:sections.rich_text.settings.text_position.option_1.label"
                },
                {
                    "value":"ic-justify-content-center",
                    "label":"t:sections.rich_text.settings.text_position.option_2.label"
                },
                {
                    "value":"ic-justify-content-end",
                    "label":"t:sections.rich_text.settings.text_position.option_3.label"
                }
            ],
            "default":"ic-justify-content-center",
            "label":"t:sections.rich_text.settings.text_position.label"
        },
        {
            "type":"select",
            "id":"text_align",
            "options":[
                {
                    "value":"ic-text-left",
                    "label":"t:sections.rich_text.settings.text_align.option_1.label"
                },
                {
                    "value":"ic-text-center",
                    "label":"t:sections.rich_text.settings.text_align.option_2.label"
                },
                {
                    "value":"ic-text-right",
                    "label":"t:sections.rich_text.settings.text_align.option_3.label"
                }
            ],
            "default":"ic-text-center",
            "label":"t:sections.rich_text.settings.text_align.label"
        }
    ],
    "blocks":[
        {
            "type":"heading",
            "name":"t:sections.rich_text.blocks.heading.name",
            "limit":3,
            "settings":[
                {
                    "type":"richtext",
                    "id":"heading",
                    "default":"<p>Heading</p>",
                    "label":"t:sections.rich_text.blocks.heading.settings.heading.label"
                }
            ]
        },
        {
            "type":"subheading",
            "name":"t:sections.rich_text.blocks.subheading.name",
            "limit":3,
            "settings":[
                {
                    "type":"richtext",
                    "id":"subheading",
                    "default":"<p>Subheading</p>",
                    "label":"t:sections.rich_text.blocks.subheading.settings.subheading.label"
                }
            ]
        },
        {
            "type":"text",
            "name":"t:sections.rich_text.blocks.text.name",
            "limit":3,
            "settings":[
                {
                    "type":"richtext",
                    "id":"description",
                    "default":"<p>Share information about your brand with your customers. Describe a product, make announcements, or welcome customers to your store.</p>",
                    "label":"t:sections.rich_text.blocks.text.settings.description.label"
                }
            ]
        },
        {
            "type":"buttons",
            "name":"t:sections.rich_text.blocks.buttons.name",
            "limit":3,
            "settings":[
                {
                    "type":"text",
                    "id":"first_button_label",
                    "default":"Button label",
                    "label":"t:sections.rich_text.blocks.buttons.settings.first_button_label.label",
                    "info":"t:sections.rich_text.blocks.buttons.settings.first_button_label.info"
                },
                {
                    "type":"url",
                    "id":"first_button_link",
                    "label":"t:sections.rich_text.blocks.buttons.settings.first_button_link.label"
                },
                {
                    "type":"select",
                    "id":"first_button_style",
                    "options":[
                        {
                            "value":"ic-btn-primary",
                            "label":"t:sections.rich_text.blocks.buttons.settings.first_button_style.option_1.label"
                        },
                        {
                            "value":"ic-btn-secondary",
                            "label":"t:sections.rich_text.blocks.buttons.settings.first_button_style.option_2.label"
                        },
                        {
                            "value":"ic-btn-tertiary",
                            "label":"t:sections.rich_text.blocks.buttons.settings.first_button_style.option_3.label"
                        }
                    ],
                    "default":"ic-btn-primary",
                    "label":"t:sections.rich_text.blocks.buttons.settings.first_button_style.label"
                },
                {
                    "type":"text",
                    "id":"second_button_label",
                    "label":"t:sections.rich_text.blocks.buttons.settings.second_button_label.label",
                    "info":"t:sections.rich_text.blocks.buttons.settings.second_button_label.info"
                },
                {
                    "type":"url",
                    "id":"second_button_link",
                    "label":"t:sections.rich_text.blocks.buttons.settings.second_button_link.label"
                },
                {
                    "type":"select",
                    "id":"second_button_style",
                    "options":[
                        {
                            "value":"ic-btn-primary",
                            "label":"t:sections.rich_text.blocks.buttons.settings.second_button_style.option_1.label"
                        },
                        {
                            "value":"ic-btn-secondary",
                            "label":"t:sections.rich_text.blocks.buttons.settings.second_button_style.option_2.label"
                        },
                        {
                            "value":"ic-btn-tertiary",
                            "label":"t:sections.rich_text.blocks.buttons.settings.second_button_style.option_3.label"
                        }
                    ],
                    "default":"ic-btn-primary",
                    "label":"t:sections.rich_text.blocks.buttons.settings.second_button_style.label"
                }
            ]
        }
    ],
    "presets":[
        {
            "name":"t:sections.rich_text.name",
            "blocks":[
                {
                    "type":"heading"
                },
                {
                    "type":"subheading"
                },
                {
                    "type":"text"
                },
                {
                    "type":"buttons"
                }
            ]
        }
    ],
    "disabled_on": {
        "groups": ["*"]
    }
}
{% endschema %}