{%- comment -%}
  FAQPage schema. Pass JSON array string of {q,a} pairs via param `faq_json`
  OR rely on block items iterated from a section. This snippet outputs JSON-LD
  built from a Liquid array of hashes at variable `faq_items` OR from `section.blocks`.

  Usage (from a section with blocks of type 'faq'):
    {%- assign faq_items = section.blocks -%}
    {%- render 'evotech-schema-faq', items: faq_items -%}
{%- endcomment -%}
{%- assign _items = items | default: faq_items -%}
{%- if _items and _items.size > 0 -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for it in _items -%}
    {%- assign _q = it.settings.question | default: it.question -%}
    {%- assign _a = it.settings.answer | default: it.answer -%}
    {
      "@type": "Question",
      "name": {{ _q | json }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ _a | strip_html | json }}
      }
    }{%- unless forloop.last -%},{%- endunless -%}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
