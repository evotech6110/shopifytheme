{%- comment -%} Shared styles for customer account pages {%- endcomment -%}
<style>
  .evo-cust { min-height: 70vh; display: grid; place-items: start center; padding: 64px 24px 120px; color: #FFFFFF; font-family: 'Satoshi', system-ui, sans-serif; }
  .evo-cust__card { max-width: 480px; width: 100%; background: #0B0820; border: 1px solid rgba(255,255,255,.08); border-radius: 18px; padding: 36px 32px; }
  .evo-cust__wide { max-width: 960px; }
  .evo-cust__eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .22em; color: #A8E898; margin: 0 0 14px; }
  .evo-cust__title { font-family: 'Clash Display', sans-serif; font-size: clamp(28px, 4vw, 40px); line-height: 1.1; letter-spacing: -0.02em; margin: 0 0 10px; }
  .evo-cust__subtitle { font-family: 'Clash Display', sans-serif; font-size: 22px; margin: 0 0 14px; }
  .evo-cust__lede { color: #B6B5C6; font-size: 15px; margin: 0 0 24px; line-height: 1.55; }
  .evo-cust__form { display: flex; flex-direction: column; gap: 14px; }
  .evo-cust__form label { display: flex; flex-direction: column; gap: 6px; font-size: 12px; color: #B6B5C6; text-transform: uppercase; letter-spacing: .12em; font-family: 'JetBrains Mono', monospace; }
  .evo-cust__form input, .evo-cust__form select, .evo-cust__form textarea { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); color: #FFFFFF; padding: 12px 14px; border-radius: 10px; font-size: 15px; font-family: inherit; }
  .evo-cust__form button { background: #FF7A4A; color: #0A0A0A; border: 0; border-radius: 999px; padding: 14px 22px; font-weight: 700; font-size: 15px; cursor: pointer; font-family: inherit; margin-top: 6px; }
  .evo-cust__form button:hover { background: #ff9068; }
  .evo-cust__form button.ghost { background: transparent; color: #FFFFFF; border: 1px solid rgba(255,255,255,.22); }
  .evo-cust__links { display: flex; justify-content: space-between; font-size: 13px; margin-top: 10px; }
  .evo-cust__links a { color: #A8E898; text-decoration: none; }
  .evo-cust__error { color: #FF7A4A; font-size: 13px; margin: 0 0 6px; }
  .evo-cust__ok { color: #A8E898; font-size: 13px; margin: 0 0 6px; }
  .evo-cust__table { width: 100%; border-collapse: collapse; margin-top: 10px; }
  .evo-cust__table th, .evo-cust__table td { text-align: left; padding: 10px 8px; border-bottom: 1px solid rgba(255,255,255,.08); font-size: 14px; }
  .evo-cust__table th { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #B6B5C6; letter-spacing: .12em; text-transform: uppercase; }
  .evo-cust__table a { color: #A8E898; }
  .evo-cust__section { margin-top: 32px; }
  .evo-cust__section h2 { font-family: 'Clash Display', sans-serif; font-size: 22px; margin: 0 0 14px; }
  .evo-cust__grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
</style>
