{%- comment -%}
  EvoTech — Original branded SVG illustration library.
  Every glyph authored by EvoTech for EvoTech — 100% copyright-clean, no stock art,
  no third-party licences. Use: {% render 'evotech-illustration', name: 'ai-core' %}
  Available names: ai-core, network-mesh, shield-pulse, grid-orbit, data-flow,
  compliance-check, audit-scroll, hardware-rack, hero-portrait.
{%- endcomment -%}

{%- assign id = 'evoIllus' | append: section.id | append: forloop.index | default: 'evoIllus' -%}

{%- case name -%}
  {%- when 'hero-portrait' -%}
    <svg class="evo-illus evo-illus--portrait" viewBox="0 0 400 500" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="EvoTech AI consciousness">
      <defs>
        <linearGradient id="{{ id }}-bg" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0%"  stop-color="#1A1440"/>
          <stop offset="100%" stop-color="#08070F"/>
        </linearGradient>
        <radialGradient id="{{ id }}-glow" cx="0.5" cy="0.4" r="0.6">
          <stop offset="0%"  stop-color="#A8E898" stop-opacity="0.45"/>
          <stop offset="100%" stop-color="#A8E898" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="{{ id }}-indigo" cx="0.7" cy="0.3" r="0.5">
          <stop offset="0%"  stop-color="#3D2EDE" stop-opacity="0.6"/>
          <stop offset="100%" stop-color="#3D2EDE" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <rect width="400" height="500" fill="url(#{{ id }}-bg)"/>
      <rect width="400" height="500" fill="url(#{{ id }}-indigo)"/>
      <rect width="400" height="500" fill="url(#{{ id }}-glow)"/>
      <!-- circuit lines -->
      <g stroke="#A8E898" stroke-width="0.6" opacity="0.35" fill="none">
        <path d="M20 80 L80 80 L100 100 L100 180 L60 220"/>
        <path d="M340 120 L300 120 L280 140 L280 220 L320 260"/>
        <path d="M40 380 L120 380 L140 400 L200 400"/>
        <path d="M380 420 L300 420 L280 400 L220 400"/>
      </g>
      <!-- stylised head silhouette -->
      <g transform="translate(200, 240)">
        <ellipse cx="0" cy="0" rx="130" ry="160" fill="none" stroke="#A8E898" stroke-width="1.2" opacity="0.8"/>
        <ellipse cx="0" cy="0" rx="100" ry="130" fill="none" stroke="#A8E898" stroke-width="0.8" opacity="0.5"/>
        <ellipse cx="0" cy="0" rx="70"  ry="100" fill="none" stroke="#3D2EDE" stroke-width="1"   opacity="0.8"/>
      </g>
      <!-- neural nodes -->
      <g fill="#A8E898">
        <circle cx="120" cy="160" r="3"/>
        <circle cx="280" cy="160" r="3"/>
        <circle cx="200" cy="120" r="4"/>
        <circle cx="200" cy="240" r="6"/>
        <circle cx="150" cy="320" r="3"/>
        <circle cx="260" cy="320" r="3"/>
        <circle cx="200" cy="380" r="4"/>
      </g>
      <g stroke="#A8E898" stroke-width="0.6" opacity="0.5" fill="none">
        <line x1="120" y1="160" x2="200" y2="240"/>
        <line x1="280" y1="160" x2="200" y2="240"/>
        <line x1="200" y1="120" x2="200" y2="240"/>
        <line x1="150" y1="320" x2="200" y2="240"/>
        <line x1="260" y1="320" x2="200" y2="240"/>
        <line x1="200" y1="380" x2="200" y2="240"/>
      </g>
      <!-- brand mark ring -->
      <g transform="translate(200, 250)">
        <circle r="22" fill="none" stroke="#A8E898" stroke-width="1.5"/>
        <circle r="8"  fill="#A8E898"/>
      </g>
    </svg>

  {%- when 'ai-core' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="EvoTech AI core">
      <defs>
        <radialGradient id="{{ id }}-ai" cx="0.5" cy="0.5" r="0.5">
          <stop offset="0%" stop-color="#A8E898" stop-opacity="0.8"/>
          <stop offset="100%" stop-color="#A8E898" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <circle cx="100" cy="100" r="60" fill="url(#{{ id }}-ai)"/>
      <g fill="none" stroke="#A8E898" stroke-width="1.2">
        <circle cx="100" cy="100" r="80" opacity="0.3"/>
        <circle cx="100" cy="100" r="60" opacity="0.6"/>
        <circle cx="100" cy="100" r="40" opacity="0.9"/>
      </g>
      <circle cx="100" cy="100" r="8" fill="#A8E898"/>
      <g fill="#A8E898">
        <circle cx="100" cy="40"  r="2.5"/>
        <circle cx="160" cy="100" r="2.5"/>
        <circle cx="100" cy="160" r="2.5"/>
        <circle cx="40"  cy="100" r="2.5"/>
      </g>
    </svg>

  {%- when 'network-mesh' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Network mesh">
      <g stroke="#A8E898" stroke-width="1" fill="none" opacity="0.7">
        <polygon points="100,30 170,70 170,130 100,170 30,130 30,70"/>
        <line x1="100" y1="30" x2="100" y2="170"/>
        <line x1="30"  y1="70" x2="170" y2="130"/>
        <line x1="170" y1="70" x2="30"  y2="130"/>
      </g>
      <g fill="#A8E898">
        <circle cx="100" cy="30"  r="4"/>
        <circle cx="170" cy="70"  r="4"/>
        <circle cx="170" cy="130" r="4"/>
        <circle cx="100" cy="170" r="4"/>
        <circle cx="30"  cy="130" r="4"/>
        <circle cx="30"  cy="70"  r="4"/>
        <circle cx="100" cy="100" r="6" fill="#3D2EDE"/>
      </g>
    </svg>

  {%- when 'shield-pulse' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Shield pulse">
      <path d="M100 20 L170 50 L170 110 Q170 160 100 180 Q30 160 30 110 L30 50 Z" fill="none" stroke="#A8E898" stroke-width="2"/>
      <path d="M100 40 L150 60 L150 105 Q150 145 100 160 Q50 145 50 105 L50 60 Z" fill="rgba(168,232,152,0.08)" stroke="#A8E898" stroke-width="1" opacity="0.6"/>
      <path d="M75 100 L92 117 L130 80" fill="none" stroke="#A8E898" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'grid-orbit' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Grid orbit">
      <g fill="none" stroke="#A8E898" stroke-width="1" opacity="0.5">
        <ellipse cx="100" cy="100" rx="80" ry="30"/>
        <ellipse cx="100" cy="100" rx="30" ry="80"/>
        <circle cx="100" cy="100" r="50"/>
      </g>
      <circle cx="100" cy="100" r="10" fill="#3D2EDE"/>
      <circle cx="180" cy="100" r="4" fill="#A8E898"/>
      <circle cx="100" cy="20"  r="4" fill="#A8E898"/>
    </svg>

  {%- when 'data-flow' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Data flow">
      <g stroke="#A8E898" stroke-width="1.5" fill="none">
        <path d="M20 60 Q100 20 180 60"/>
        <path d="M20 100 Q100 60 180 100"/>
        <path d="M20 140 Q100 100 180 140"/>
        <path d="M20 180 Q100 140 180 180"/>
      </g>
      <g fill="#A8E898">
        <circle cx="100" cy="40"  r="3"/>
        <circle cx="100" cy="80"  r="3"/>
        <circle cx="100" cy="120" r="3"/>
        <circle cx="100" cy="160" r="3"/>
      </g>
    </svg>

  {%- when 'compliance-check' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Compliance check">
      <rect x="40" y="30" width="120" height="140" rx="10" fill="none" stroke="#A8E898" stroke-width="2"/>
      <g stroke="#A8E898" stroke-width="1.2" stroke-linecap="round">
        <line x1="60" y1="60" x2="140" y2="60"/>
        <line x1="60" y1="80" x2="120" y2="80"/>
        <line x1="60" y1="100" x2="140" y2="100"/>
        <line x1="60" y1="120" x2="100" y2="120"/>
      </g>
      <circle cx="145" cy="140" r="22" fill="#A8E898"/>
      <path d="M135 140 L143 148 L158 132" fill="none" stroke="#08070F" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>

  {%- when 'audit-scroll' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Audit ready">
      <circle cx="100" cy="100" r="70" fill="none" stroke="#3D2EDE" stroke-width="2" opacity="0.6"/>
      <circle cx="100" cy="100" r="70" fill="none" stroke="#A8E898" stroke-width="2" stroke-dasharray="20 10"/>
      <text x="100" y="110" text-anchor="middle" fill="#A8E898" font-family="monospace" font-size="28" font-weight="bold">E8</text>
    </svg>

  {%- when 'hardware-rack' -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Hardware">
      <rect x="45" y="30" width="110" height="140" rx="6" fill="none" stroke="#A8E898" stroke-width="2"/>
      <g fill="#A8E898" opacity="0.8">
        <rect x="55" y="44"  width="90" height="18" rx="3"/>
        <rect x="55" y="72"  width="90" height="18" rx="3" opacity="0.5"/>
        <rect x="55" y="100" width="90" height="18" rx="3" opacity="0.8"/>
        <rect x="55" y="128" width="90" height="18" rx="3" opacity="0.4"/>
      </g>
      <circle cx="140" cy="53"  r="2" fill="#3D2EDE"/>
      <circle cx="140" cy="109" r="2" fill="#3D2EDE"/>
    </svg>

  {%- else -%}
    <svg class="evo-illus" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><circle cx="100" cy="100" r="60" fill="none" stroke="#A8E898" stroke-width="2"/></svg>
{%- endcase -%}
