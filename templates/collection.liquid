{%- comment -%} Default collection template {%- endcomment -%}
{%- paginate collection.products by 24 -%}
{% render 'evotech-breadcrumbs' %}
<section class="evo-col">
  <header class="evo-col__head">
    <p class="evo-col__eyebrow">COLLECTION</p>
    <h1 class="evo-col__title">{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="evo-col__desc rte">{{ collection.description }}</div>
    {%- endif -%}
    <p class="evo-col__count">{{ collection.products_count }} {% if collection.products_count == 1 %}product{% else %}products{% endif %}</p>
  </header>

  {%- if collection.products.size > 0 -%}
    <div class="evo-col__grid">
      {%- for product in collection.products -%}
        <a class="evo-col__card" href="{{ product.url | within: collection }}">
          <div class="evo-col__thumb">
            {%- if product.featured_media -%}
              {{ product.featured_media | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,500,700', sizes: '(min-width: 900px) 25vw, 50vw', alt: product.title }}
            {%- else -%}
              <span class="evo-col__thumb-empty">No image</span>
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="evo-col__badge">SAVE {{ product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price }}%</span>
            {%- endif -%}
            {%- unless product.available -%}<span class="evo-col__badge evo-col__badge--sold">SOLD OUT</span>{%- endunless -%}
          </div>
          <div class="evo-col__body">
            <p class="evo-col__vendor">{{ product.vendor }}</p>
            <h3 class="evo-col__name">{{ product.title }}</h3>
            <div class="evo-col__price">
              <span>{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <s>{{ product.compare_at_price | money }}</s>
              {%- endif -%}
            </div>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="evo-col__pager" role="navigation">
        {%- if paginate.previous -%}<a href="{{ paginate.previous.url }}">← Previous</a>{%- endif -%}
        <span>Page {{ paginate.current_page }} of {{ paginate.pages }}</span>
        {%- if paginate.next -%}<a href="{{ paginate.next.url }}">Next →</a>{%- endif -%}
      </nav>
    {%- endif -%}
  {%- else -%}
    <p class="evo-col__empty">No products in this collection yet.</p>
  {%- endif -%}
</section>

<style>
  .evo-col { max-width: 1280px; margin: 0 auto; padding: 48px 24px 120px; color: #FFFFFF; font-family: 'Satoshi', system-ui, sans-serif; }
  .evo-col__head { margin-bottom: 40px; max-width: 720px; }
  .evo-col__eyebrow { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12px; letter-spacing: .22em; color: #A8E898; margin: 0 0 12px; }
  .evo-col__title { font-family: 'Clash Display', 'Satoshi', sans-serif; font-size: clamp(34px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.02em; margin: 0 0 14px; }
  .evo-col__desc { color: #B6B5C6; font-size: 16px; line-height: 1.65; margin: 0 0 12px; }
  .evo-col__count { font-family: 'JetBrains Mono', ui-monospace, monospace; color: #B6B5C6; font-size: 13px; letter-spacing: .08em; margin: 0; }
  .evo-col__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
  @media (min-width: 720px) { .evo-col__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .evo-col__grid { grid-template-columns: repeat(4, 1fr); } }
  .evo-col__card { text-decoration: none; color: inherit; display: flex; flex-direction: column; border-radius: 16px; overflow: hidden; background: #0B0820; border: 1px solid rgba(255,255,255,.06); transition: transform .2s ease, border-color .2s ease; }
  .evo-col__card:hover { transform: translateY(-3px); border-color: rgba(168,232,152,.3); }
  .evo-col__thumb { aspect-ratio: 1; position: relative; background: #0B0820; display: grid; place-items: center; overflow: hidden; }
  .evo-col__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .evo-col__thumb-empty { color: #B6B5C6; font-size: 13px; font-family: 'JetBrains Mono', monospace; }
  .evo-col__badge { position: absolute; top: 10px; left: 10px; background: #A8E898; color: #0A0A0A; padding: 4px 8px; border-radius: 6px; font-size: 11px; font-weight: 700; letter-spacing: .08em; font-family: 'JetBrains Mono', monospace; }
  .evo-col__badge--sold { background: #FF7A4A; color: #0A0A0A; right: 10px; left: auto; }
  .evo-col__body { padding: 16px; }
  .evo-col__vendor { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #A8E898; text-transform: uppercase; letter-spacing: .12em; margin: 0 0 6px; }
  .evo-col__name { font-size: 16px; margin: 0 0 8px; line-height: 1.3; font-weight: 600; }
  .evo-col__price { display: flex; gap: 8px; align-items: baseline; font-size: 15px; }
  .evo-col__price s { color: #B6B5C6; font-size: 13px; }
  .evo-col__pager { margin-top: 48px; display: flex; justify-content: space-between; align-items: center; gap: 16px; color: #B6B5C6; font-family: 'JetBrains Mono', monospace; font-size: 13px; }
  .evo-col__pager a { color: #A8E898; text-decoration: none; }
  .evo-col__empty { color: #B6B5C6; font-size: 16px; padding: 40px 0; }
</style>
{%- endpaginate -%}
