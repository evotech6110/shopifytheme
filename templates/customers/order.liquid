{%- comment -%} Customer order detail {%- endcomment -%}
<section class="evo-cust">
  <div class="evo-cust__card evo-cust__wide">
    <p class="evo-cust__eyebrow">ORDER {{ order.name }}</p>
    <h1 class="evo-cust__title">Order {{ order.name }}</h1>
    <p style="color:#B6B5C6;font-size:14px;margin:0 0 20px;">
      Placed {{ order.created_at | date: '%B %d, %Y at %I:%M %p' }} · {{ order.financial_status_label }} · {{ order.fulfillment_status_label }}
    </p>
    <div class="evo-cust__links"><a href="{{ routes.account_url }}">← Back to account</a></div>

    <div class="evo-cust__section">
      <h2>Items</h2>
      <table class="evo-cust__table">
        <thead><tr><th>Product</th><th>SKU</th><th>Qty</th><th>Price</th><th>Total</th></tr></thead>
        <tbody>
          {%- for line_item in order.line_items -%}
            <tr>
              <td><a href="{{ line_item.product.url }}">{{ line_item.title }}</a></td>
              <td>{{ line_item.sku }}</td>
              <td>{{ line_item.quantity }}</td>
              <td>{{ line_item.price | money }}</td>
              <td>{{ line_item.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
        <tfoot>
          <tr><td colspan="4" style="text-align:right;color:#B6B5C6;">Subtotal</td><td>{{ order.subtotal_price | money }}</td></tr>
          {%- for discount in order.cart_level_discount_applications -%}
            <tr><td colspan="4" style="text-align:right;color:#B6B5C6;">Discount ({{ discount.title }})</td><td>-{{ discount.total_allocated_amount | money }}</td></tr>
          {%- endfor -%}
          {%- for shipping_method in order.shipping_methods -%}
            <tr><td colspan="4" style="text-align:right;color:#B6B5C6;">Shipping ({{ shipping_method.title }})</td><td>{{ shipping_method.price | money }}</td></tr>
          {%- endfor -%}
          {%- for tax_line in order.tax_lines -%}
            <tr><td colspan="4" style="text-align:right;color:#B6B5C6;">{{ tax_line.title }}</td><td>{{ tax_line.price | money }}</td></tr>
          {%- endfor -%}
          <tr><td colspan="4" style="text-align:right;font-weight:700;">Total</td><td style="font-weight:700;">{{ order.total_price | money }}</td></tr>
        </tfoot>
      </table>
    </div>

    <div class="evo-cust__section" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:18px;">
      <div>
        <h2>Shipping address</h2>
        <div style="color:#D8D7E3;font-size:14px;line-height:1.6;">{{ order.shipping_address | format_address }}</div>
      </div>
      <div>
        <h2>Billing address</h2>
        <div style="color:#D8D7E3;font-size:14px;line-height:1.6;">{{ order.billing_address | format_address }}</div>
      </div>
    </div>
  </div>
</section>
{% render 'evotech-customer-styles' %}
