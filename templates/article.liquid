{%- comment -%} Default single article {%- endcomment -%}
<article class="evo-article">
  <header class="evo-article__head">
    <p class="evo-article__eyebrow"><a href="{{ blog.url }}">{{ blog.title }}</a></p>
    <h1 class="evo-article__title">{{ article.title }}</h1>
    <p class="evo-article__meta">{{ article.published_at | date: '%B %d, %Y' }} · {{ article.author }}{% if article.tags.size > 0 %} · {{ article.tags | join: ', ' }}{% endif %}</p>
    {%- if article.image -%}
      <div class="evo-article__hero">
        {{ article | image_url: width: 1600 | image_tag: loading: 'eager', widths: '600,900,1200,1600', sizes: '(min-width: 1000px) 960px, 100vw', alt: article.title }}
      </div>
    {%- endif -%}
  </header>

  <div class="evo-article__body rte">
    {{ article.content }}
  </div>

  {%- if blog.comments_enabled? -%}
    <section class="evo-article__comments">
      <h2>Comments</h2>
      {%- if article.comments_count > 0 -%}
        {%- for comment in article.comments -%}
          <div class="evo-article__comment">
            <p class="evo-article__comment-meta"><strong>{{ comment.author }}</strong> · {{ comment.created_at | date: '%B %d, %Y' }}</p>
            <div>{{ comment.content }}</div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <p class="evo-article__comment-empty">Be the first to comment.</p>
      {%- endif -%}

      {%- form 'new_comment', article, class: 'evo-article__comment-form' -%}
        {%- if form.posted_successfully? -%}
          <p class="evo-article__comment-ok">Thanks — your comment was posted{% if blog.moderated? %} and is awaiting moderation{% endif %}.</p>
        {%- endif -%}
        {%- if form.errors -%}
          <p class="evo-article__comment-error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
        <div class="evo-article__comment-row">
          <input type="text" name="comment[author]" placeholder="Name" required>
          <input type="email" name="comment[email]" placeholder="Email" required>
        </div>
        <textarea name="comment[body]" rows="4" placeholder="Your comment" required></textarea>
        <button type="submit">Post comment</button>
      {%- endform -%}
    </section>
  {%- endif -%}
</article>

<style>
  .evo-article { max-width: 820px; margin: 0 auto; padding: 48px 24px 120px; color: #FFFFFF; font-family: 'Satoshi', system-ui, sans-serif; }
  .evo-article__head { margin-bottom: 28px; }
  .evo-article__eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .22em; color: #A8E898; margin: 0 0 10px; text-transform: uppercase; }
  .evo-article__eyebrow a { color: inherit; text-decoration: none; }
  .evo-article__title { font-family: 'Clash Display', sans-serif; font-size: clamp(32px, 5vw, 52px); line-height: 1.1; letter-spacing: -0.02em; margin: 0 0 14px; }
  .evo-article__meta { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #B6B5C6; letter-spacing: .06em; margin: 0 0 28px; }
  .evo-article__hero { border-radius: 16px; overflow: hidden; }
  .evo-article__hero img { width: 100%; height: auto; display: block; }
  .evo-article__body { color: #D8D7E3; font-size: 17px; line-height: 1.75; }
  .evo-article__body h2 { font-family: 'Clash Display', sans-serif; font-size: 28px; margin: 36px 0 14px; color: #FFFFFF; }
  .evo-article__body h3 { font-family: 'Clash Display', sans-serif; font-size: 22px; margin: 28px 0 10px; color: #FFFFFF; }
  .evo-article__body p { margin: 0 0 16px; }
  .evo-article__body a { color: #A8E898; text-decoration: underline; text-underline-offset: 3px; }
  .evo-article__body ul, .evo-article__body ol { padding-left: 22px; margin: 0 0 16px; }
  .evo-article__body li { margin-bottom: 8px; }
  .evo-article__body img { max-width: 100%; border-radius: 12px; margin: 20px 0; }
  .evo-article__body blockquote { border-left: 3px solid #A8E898; margin: 20px 0; padding: 6px 18px; color: #B6B5C6; font-style: italic; }
  .evo-article__body code { background: rgba(255,255,255,.06); padding: 2px 6px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; font-size: .92em; }
  .evo-article__body pre { background: #0B0820; padding: 16px; border-radius: 10px; overflow-x: auto; border: 1px solid rgba(255,255,255,.08); }
  .evo-article__comments { margin-top: 56px; border-top: 1px solid rgba(255,255,255,.1); padding-top: 32px; }
  .evo-article__comments h2 { font-family: 'Clash Display', sans-serif; font-size: 26px; margin: 0 0 20px; }
  .evo-article__comment { background: #0B0820; border: 1px solid rgba(255,255,255,.06); border-radius: 12px; padding: 16px 18px; margin-bottom: 14px; }
  .evo-article__comment-meta { margin: 0 0 8px; color: #B6B5C6; font-size: 13px; }
  .evo-article__comment-empty { color: #B6B5C6; }
  .evo-article__comment-form { margin-top: 24px; display: flex; flex-direction: column; gap: 10px; }
  .evo-article__comment-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .evo-article__comment-form input, .evo-article__comment-form textarea { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); color: #FFFFFF; padding: 12px 14px; border-radius: 10px; font-family: inherit; font-size: 14px; }
  .evo-article__comment-form button { align-self: flex-start; background: #FF7A4A; color: #0A0A0A; border: 0; border-radius: 999px; padding: 12px 22px; font-weight: 700; cursor: pointer; font-family: inherit; }
  .evo-article__comment-ok { color: #A8E898; }
  .evo-article__comment-error { color: #FF7A4A; }
</style>
