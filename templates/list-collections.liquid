{%- comment -%} List of all collections {%- endcomment -%}
<section class="evo-cols">
  <header class="evo-cols__head">
    <p class="evo-cols__eyebrow">SHOP · ALL CATEGORIES</p>
    <h1 class="evo-cols__title">Browse every collection.</h1>
    <p class="evo-cols__lede">Hand-picked enterprise gear & software — from Perth, for Australian businesses.</p>
  </header>
  <div class="evo-cols__grid">
    {%- for collection in collections -%}
      {%- unless collection.handle == 'frontpage' or collection.handle == 'all' -%}
        <a class="evo-cols__card" href="{{ collection.url }}">
          <div class="evo-cols__thumb">
            {%- if collection.featured_image -%}
              {{ collection.featured_image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300,500,700', alt: collection.title }}
            {%- else -%}
              <span class="evo-cols__thumb-empty">{{ collection.title | slice: 0, 1 | upcase }}</span>
            {%- endif -%}
          </div>
          <div class="evo-cols__body">
            <h3 class="evo-cols__name">{{ collection.title }}</h3>
            <p class="evo-cols__count">{{ collection.products_count }} product{% unless collection.products_count == 1 %}s{% endunless %}</p>
          </div>
        </a>
      {%- endunless -%}
    {%- endfor -%}
  </div>
</section>

<style>
  .evo-cols { max-width: 1280px; margin: 0 auto; padding: 48px 24px 120px; color: #FFFFFF; font-family: 'Satoshi', system-ui, sans-serif; }
  .evo-cols__head { margin-bottom: 40px; max-width: 720px; }
  .evo-cols__eyebrow { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 12px; letter-spacing: .22em; color: #A8E898; margin: 0 0 12px; }
  .evo-cols__title { font-family: 'Clash Display', 'Satoshi', sans-serif; font-size: clamp(34px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.02em; margin: 0 0 14px; }
  .evo-cols__lede { color: #B6B5C6; font-size: 16px; line-height: 1.65; margin: 0; }
  .evo-cols__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 24px; }
  .evo-cols__card { text-decoration: none; color: inherit; border-radius: 16px; overflow: hidden; background: #0B0820; border: 1px solid rgba(255,255,255,.06); transition: transform .2s ease, border-color .2s ease; }
  .evo-cols__card:hover { transform: translateY(-3px); border-color: rgba(168,232,152,.3); }
  .evo-cols__thumb { aspect-ratio: 16/10; position: relative; background: linear-gradient(135deg, #0B0820, #05040C); display: grid; place-items: center; overflow: hidden; }
  .evo-cols__thumb img { width: 100%; height: 100%; object-fit: cover; }
  .evo-cols__thumb-empty { font-family: 'Clash Display', sans-serif; font-size: 56px; color: #A8E898; font-weight: 700; }
  .evo-cols__body { padding: 14px 16px 18px; }
  .evo-cols__name { font-size: 17px; margin: 0 0 6px; font-weight: 600; }
  .evo-cols__count { font-family: 'JetBrains Mono', monospace; font-size: 12px; color: #B6B5C6; margin: 0; letter-spacing: .06em; }
</style>
