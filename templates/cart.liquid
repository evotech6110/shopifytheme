{%- comment -%} Default cart template {%- endcomment -%}
<section class="evo-cart">
  <header class="evo-cart__head">
    <p class="evo-cart__eyebrow">YOUR BAG</p>
    <h1 class="evo-cart__title">Cart</h1>
  </header>

  {%- if cart.item_count > 0 -%}
    {%- form 'cart', cart, class: 'evo-cart__form' -%}
      <ul class="evo-cart__list">
        {%- for item in cart.items -%}
          <li class="evo-cart__item">
            <a class="evo-cart__thumb" href="{{ item.url }}">
              {%- if item.image -%}
                {{ item | image_url: width: 200 | image_tag: widths: '120,200', alt: item.title }}
              {%- endif -%}
            </a>
            <div class="evo-cart__info">
              <p class="evo-cart__vendor">{{ item.vendor }}</p>
              <a class="evo-cart__name" href="{{ item.url }}">{{ item.product.title }}</a>
              {%- unless item.product.has_only_default_variant -%}
                <p class="evo-cart__variant">{{ item.variant.title }}</p>
              {%- endunless -%}
              {%- if item.selling_plan_allocation -%}
                <p class="evo-cart__plan">{{ item.selling_plan_allocation.selling_plan.name }}</p>
              {%- endif -%}
            </div>
            <div class="evo-cart__qty">
              <label for="Qty-{{ item.key }}">Qty</label>
              <input type="number" id="Qty-{{ item.key }}" name="updates[]" value="{{ item.quantity }}" min="0">
            </div>
            <div class="evo-cart__price">
              {{ item.final_line_price | money }}
              <a class="evo-cart__remove" href="{{ item.url_to_remove }}" aria-label="Remove {{ item.product.title }}">Remove</a>
            </div>
          </li>
        {%- endfor -%}
      </ul>

      <div class="evo-cart__note">
        <label for="CartNote">Order notes</label>
        <textarea id="CartNote" name="note" rows="2" placeholder="Anything we should know about this order?">{{ cart.note }}</textarea>
      </div>

      <div class="evo-cart__totals">
        <div class="evo-cart__subtotal">
          <span>Subtotal</span>
          <strong>{{ cart.total_price | money }}</strong>
        </div>
        <p class="evo-cart__shipping-note">Shipping &amp; taxes calculated at checkout. AUD · GST invoiced.</p>

        <div class="evo-cart__actions">
          <button class="evo-cart__btn evo-cart__btn--ghost" type="submit" name="update">Update cart</button>
          <button class="evo-cart__btn evo-cart__btn--primary" type="submit" name="checkout">Checkout</button>
        </div>
      </div>
    {%- endform -%}
  {%- else -%}
    <div class="evo-cart__empty">
      <p>Your cart is empty.</p>
      <a class="evo-cart__btn evo-cart__btn--primary" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
    </div>
  {%- endif -%}
</section>

<style>
  .evo-cart { max-width: 1040px; margin: 0 auto; padding: 48px 24px 120px; color: #FFFFFF; font-family: 'Satoshi', system-ui, sans-serif; }
  .evo-cart__head { margin-bottom: 32px; }
  .evo-cart__eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .22em; color: #A8E898; margin: 0 0 12px; }
  .evo-cart__title { font-family: 'Clash Display', sans-serif; font-size: clamp(34px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.02em; margin: 0; }
  .evo-cart__list { list-style: none; padding: 0; margin: 0 0 24px; border-top: 1px solid rgba(255,255,255,.08); }
  .evo-cart__item { display: grid; grid-template-columns: 96px 1fr auto auto; gap: 16px; align-items: start; padding: 20px 0; border-bottom: 1px solid rgba(255,255,255,.08); }
  .evo-cart__thumb { background: #0B0820; border-radius: 10px; overflow: hidden; display: block; border: 1px solid rgba(255,255,255,.06); }
  .evo-cart__thumb img { width: 100%; height: auto; display: block; }
  .evo-cart__vendor { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: #A8E898; text-transform: uppercase; letter-spacing: .12em; margin: 0 0 4px; }
  .evo-cart__name { color: #FFFFFF; text-decoration: none; font-weight: 600; font-size: 16px; line-height: 1.3; }
  .evo-cart__name:hover { color: #A8E898; }
  .evo-cart__variant, .evo-cart__plan { margin: 6px 0 0; color: #B6B5C6; font-size: 13px; }
  .evo-cart__qty { display: flex; flex-direction: column; gap: 4px; }
  .evo-cart__qty label { font-size: 11px; text-transform: uppercase; letter-spacing: .1em; color: #B6B5C6; }
  .evo-cart__qty input { width: 72px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); color: #FFFFFF; padding: 8px 10px; border-radius: 8px; font-family: inherit; }
  .evo-cart__price { text-align: right; font-weight: 600; font-size: 15px; }
  .evo-cart__remove { display: block; margin-top: 6px; color: #B6B5C6; font-size: 12px; text-decoration: underline; }
  .evo-cart__remove:hover { color: #FF7A4A; }
  .evo-cart__note { margin: 20px 0; display: flex; flex-direction: column; gap: 8px; }
  .evo-cart__note label { font-size: 12px; text-transform: uppercase; letter-spacing: .12em; color: #B6B5C6; font-family: 'JetBrains Mono', monospace; }
  .evo-cart__note textarea { background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); color: #FFFFFF; padding: 12px 14px; border-radius: 10px; font-family: inherit; resize: vertical; }
  .evo-cart__totals { background: #0B0820; border: 1px solid rgba(255,255,255,.08); border-radius: 16px; padding: 20px 22px; margin-top: 16px; }
  .evo-cart__subtotal { display: flex; justify-content: space-between; align-items: baseline; }
  .evo-cart__subtotal span { font-size: 14px; color: #B6B5C6; text-transform: uppercase; letter-spacing: .12em; font-family: 'JetBrains Mono', monospace; }
  .evo-cart__subtotal strong { font-family: 'Clash Display', sans-serif; font-size: 28px; }
  .evo-cart__shipping-note { margin: 8px 0 0; color: #B6B5C6; font-size: 13px; }
  .evo-cart__actions { display: flex; gap: 10px; margin-top: 18px; flex-wrap: wrap; }
  .evo-cart__btn { padding: 14px 22px; border-radius: 999px; font-weight: 700; font-size: 15px; border: 0; cursor: pointer; text-decoration: none; font-family: inherit; }
  .evo-cart__btn--primary { background: #FF7A4A; color: #0A0A0A; flex: 1; min-width: 180px; }
  .evo-cart__btn--primary:hover { background: #ff9068; }
  .evo-cart__btn--ghost { background: transparent; color: #FFFFFF; border: 1px solid rgba(255,255,255,.22); }
  .evo-cart__btn--ghost:hover { background: rgba(255,255,255,.06); }
  .evo-cart__empty { text-align: center; padding: 60px 0; color: #B6B5C6; }
  .evo-cart__empty p { font-size: 18px; margin-bottom: 20px; }
  @media (max-width: 640px) {
    .evo-cart__item { grid-template-columns: 72px 1fr; grid-template-rows: auto auto; }
    .evo-cart__qty, .evo-cart__price { grid-column: 2; }
    .evo-cart__price { text-align: left; }
  }
</style>
