              <rect x="140" y="172" width="16" height="8" rx="2" fill="rgba(168,232,152,0.5)"/>
              <!-- status LEDs -->
              <circle cx="250" cy="116" r="3" fill="#A8E898"/>
              <circle cx="260" cy="116" r="3" fill="#CDFFBF"/>
              <circle cx="250" cy="176" r="3" fill="#A8E898"/>
              <circle cx="260" cy="176" r="3" fill="#CDFFBF"/>
              <!-- brand plate -->
              <rect x="140" y="214" width="50" height="10" rx="2" fill="rgba(255,255,255,0.1)"/>
              <text x="165" y="222" text-anchor="middle" font-family="JetBrains Mono" font-size="7" font-weight="700" fill="rgba(168,232,152,0.9)" letter-spacing="1.5">DS223/G</text>
            </g>
          </svg>
          {%- endif -%}
        </a>

        <div class="evo-feat__meta">
