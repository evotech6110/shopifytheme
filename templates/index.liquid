          {%- else -%}
          <!-- Stylised NAS illustration -->
          <svg viewBox="0 0 400 260" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="nasCase" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#1A1740"/>
                <stop offset="1" stop-color="#08061A"/>
              </linearGradient>
              <linearGradient id="nasFront" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="#2B2763"/>
                <stop offset="1" stop-color="#14122B"/>
              </linearGradient>
              <radialGradient id="nasGlow" cx="50%" cy="100%" r="60%">
                <stop offset="0" stop-color="#A8E898" stop-opacity="0.35"/>
                <stop offset="1" stop-color="#A8E898" stop-opacity="0"/>
              </radialGradient>
            </defs>
            <!-- floor glow -->
            <ellipse cx="200" cy="240" rx="170" ry="18" fill="url(#nasGlow)"/>
            <!-- case body (isometric-ish) -->
            <g>
              <polygon points="110,60 290,60 330,90 330,230 110,230 70,200" fill="url(#nasCase)" stroke="#A8E898" stroke-width="1"/>
              <rect x="110" y="60" width="180" height="170" rx="6" fill="url(#nasFront)" stroke="#A8E898" stroke-width="1"/>
              <!-- top edge -->
              <polygon points="110,60 290,60 330,90 150,90" fill="#1F1C50" stroke="#A8E898" stroke-width="1"/>
              <!-- drive bays -->
              <rect x="130" y="90" width="140" height="52" rx="4" fill="rgba(168,232,152,0.05)" stroke="rgba(168,232,152,0.35)"/>
              <rect x="130" y="150" width="140" height="52" rx="4" fill="rgba(168,232,152,0.05)" stroke="rgba(168,232,152,0.35)"/>
              <!-- bay handles -->
