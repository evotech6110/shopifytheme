<!-- =========================================================================
     BEST-SELLER GRID
     ========================================================================= -->
<section class="evo-section evo-section--dark" aria-label="Best sellers this week">
  <div class="evo-wrap">
    <div class="evo-section__head">
      <div>
        <p class="evo-eyebrow">BEST SELLERS · LAST 30 DAYS · LIVE FROM SHOPIFY</p>
        <h2 class="evo-title">Most <em>shipped</em> gear<br>out of Perth.</h2>
      </div>
      <a href="{{ collections['best-sellers'].url | default: '/collections/best-sellers' }}" class="evo-head-link">
        See full leaderboard
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:14px;height:14px"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    <div class="evo-grid">
      {%- assign bestsellers = collections['best-sellers'].products | default: collections.all.products -%}
      {%- if bestsellers.size > 0 -%}
        {%- for product in bestsellers limit: 4 -%}
          {%- assign p_rating = product.metafields.reviews.rating.value | default: 4.8 -%}
          {%- assign p_count  = product.metafields.reviews.rating_count | default: 0 -%}
          {%- assign p_sold   = product.metafields.custom.sold_last_7d | default: 0 -%}
          <article class="evo-card">
            <span class="evo-card__rank">
              {%- if forloop.first -%}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endif -%}
              #{{ forloop.index }} THIS WEEK
            </span>
            <a href="{{ product.url }}" class="evo-card__wish" aria-label="View {{ product.title | escape }}" style="display:inline-flex;align-items:center;justify-content:center;">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </a>

            <a href="{{ product.url }}" class="evo-card__media" style="display:block;text-decoration:none;">
              {%- if product.featured_image != blank -%}
                <img src="{{ product.featured_image | image_url: width: 520 }}" alt="{{ product.featured_image.alt | default: product.title | escape }}" loading="lazy" style="width:100%;height:100%;object-fit:contain;">
              {%- else -%}
                <svg viewBox="0 0 260 180" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <defs><linearGradient id="gp{{ forloop.index }}" x1="0" y1="0" x2="0" y2="1"><stop offset="0" stop-color="#1F1C50"/><stop offset="1" stop-color="#08061A"/></linearGradient></defs>
                  <ellipse cx="130" cy="160" rx="90" ry="8" fill="#A8E898" opacity="0.1"/>
                  <rect x="40" y="40" width="180" height="100" rx="6" fill="url(#gp{{ forloop.index }})" stroke="#A8E898" stroke-width="0.8"/>
                  <circle cx="130" cy="90" r="22" fill="none" stroke="rgba(168,232,152,0.5)" stroke-width="0.8"/>
                  <circle cx="130" cy="90" r="4" fill="#A8E898"/>
                </svg>
              {%- endif -%}
              <div class="evo-card__quick">
                <span>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                  View details
                </span>
              </div>
            </a>

            <div class="evo-card__body">
              <span class="evo-card__brand">{{ product.vendor | default: 'EVOTECH' | upcase }}</span>
              <h3 class="evo-card__title"><a href="{{ product.url }}" style="color:inherit;text-decoration:none;">{{ product.title }}</a></h3>
              <div class="evo-card__rating">
                <span class="evo-card__stars">
                  {%- assign full_stars = p_rating | floor -%}
                  {%- for i in (1..5) -%}
                    {%- if i <= full_stars -%}
