<script>
(function () {
    var root = document.getElementById('zpHero');
    if (!root) return;
    var slideKeys = ['solutions','services','products'];
    var idx = 0;
    var autoplayMs = 7000;
    var timer = null;

    function go(toIdx) {
      idx = (toIdx + slideKeys.length) % slideKeys.length;
      var key = slideKeys[idx];
      root.querySelectorAll('.evo-zp__slide').forEach(function (el) {
        el.setAttribute('data-active', el.getAttribute('data-slide') === key ? 'true' : 'false');
      });
      root.querySelectorAll('[data-tracker]').forEach(function (btn) {
        btn.setAttribute('aria-current', btn.getAttribute('data-tracker') === key ? 'true' : 'false');
      });
      root.querySelectorAll('[data-slide-link]').forEach(function (a) {
        if (a.getAttribute('data-slide-link') === key) a.setAttribute('aria-current','page');
        else a.removeAttribute('aria-current');
      });
    }

    function restartAutoplay() {
      if (timer) clearInterval(timer);
      timer = setInterval(function () { go(idx + 1); }, autoplayMs);
    }

    root.querySelectorAll('[data-tracker]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        go(slideKeys.indexOf(btn.getAttribute('data-tracker')));
        restartAutoplay();
      });
    });
    root.querySelectorAll('[data-slide-link]').forEach(function (a) {
      a.addEventListener('click', function (e) {
        e.preventDefault();
        go(slideKeys.indexOf(a.getAttribute('data-slide-link')));
        restartAutoplay();
      });
    });
    root.querySelector('[data-nav="prev"]').addEventListener('click', function () { go(idx - 1); restartAutoplay(); });
    root.querySelector('[data-nav="next"]').addEventListener('click', function () { go(idx + 1); restartAutoplay(); });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowRight') { go(idx + 1); restartAutoplay(); }
      else if (e.key === 'ArrowLeft') { go(idx - 1); restartAutoplay(); }
    });

    root.addEventListener('mouseenter', function () { if (timer) { clearInterval(timer); timer = null; } });
    root.addEventListener('mouseleave', restartAutoplay);

    restartAutoplay();
  })();
</script>
<script>
(function () {
    var rail = document.getElementById('catRail');
    var bar  = document.getElementById('catBar');
    if (!rail || !bar) return;

    function updateBar() {
      var max = rail.scrollWidth - rail.clientWidth;
      var pct = max > 0 ? (rail.scrollLeft / max) : 0;
      // bar width proportional to viewport share, then translate based on scroll
      var barWidthPct = Math.max(18, (rail.clientWidth / rail.scrollWidth) * 100);
      bar.style.width = barWidthPct + '%';
      bar.style.transform = 'translateX(' + (pct * (100 - barWidthPct)) + '%)';
    }

    rail.addEventListener('scroll', updateBar, { passive: true });
    window.addEventListener('resize', updateBar);
    updateBar();

    document.querySelectorAll('[data-nav]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var dir = btn.getAttribute('data-nav') === 'next' ? 1 : -1;
        // advance by one card width + gap (~214px)
        rail.scrollBy({ left: dir * 420, behavior: 'smooth' });
      });
    });
  })();
</script>
