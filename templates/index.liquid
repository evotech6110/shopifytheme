<style>

  



@media (max-width: 760px) {
  
}



/* ---- ZERO POINT HERO ---- */

  :root {
    --bg:        #05040C;
    --bg-2:      #0B0820;
    --bg-3:      #14122B;
    --ink:       #FFFFFF;
    --ink-dim:   #B6B5C6;
    --ink-muted: #7A7A8F;
    --mint:      #A8E898;
    --mint-2:    #CDFFBF;
    --indigo:    #3D2EDE;
    --indigo-2:  #5B4DFF;
    --peach:     #FF7A4A;
    --font-d:    'Clash Display','Satoshi','Inter',sans-serif;
    --font-s:    'Satoshi','Inter',system-ui,sans-serif;
    --font-m:    'JetBrains Mono',ui-monospace,monospace;
    --ease:      cubic-bezier(.21,.83,.33,1);
  }
  
  a { color:inherit; text-decoration:none; }

  /* =========================================================================
     ZERO-POINT STYLE HERO — no promo strip, animated brain in header
     ========================================================================= */
  .evo-zp {
    position: relative;
    padding-top: 0;
    min-height: 100vh;
    overflow: hidden;
    background:
      radial-gradient(1200px 600px at 20% 10%, rgba(61,46,222,0.22), transparent 55%),
      radial-gradient(900px 500px at 80% 20%, rgba(168,232,152,0.10), transparent 60%),
      linear-gradient(180deg, #05040C 0%, #0A0820 55%, #14122B 100%);
    font-family: var(--font-s);
  }

  /* Starfield — procedurally generated twinkle layers (no image) */
  .evo-zp::before, .evo-zp::after {
    content: "";
    position: absolute; inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,.7), transparent),
      radial-gradient(1px 1px at 70% 50%, rgba(255,255,255,.55), transparent),
      radial-gradient(1.5px 1.5px at 45% 80%, rgba(255,255,255,.8), transparent),
      radial-gradient(1px 1px at 85% 20%, rgba(168,232,152,.65), transparent),
      radial-gradient(1px 1px at 10% 70%, rgba(255,255,255,.6), transparent),
      radial-gradient(2px 2px at 60% 15%, rgba(205,255,191,.7), transparent),
      radial-gradient(1px 1px at 30% 90%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 90% 85%, rgba(255,255,255,.7), transparent);
    background-size: 800px 800px;
    background-repeat: repeat;
    opacity: .85;
    animation: twinkle 6s linear infinite;
  }
  .evo-zp::after { background-size: 1100px 1100px; opacity:.45; animation-duration:11s; animation-direction: reverse; }
  @keyframes twinkle {
    0%,100% { opacity: .85; }
    50%     { opacity: .55; }
  }

  /* Moon surface */
  .evo-zp__moon {
    position: absolute;
    left: 0; right: 0; bottom: -40px;
    height: 220px;
    background:
      radial-gradient(ellipse at 20% 10%, rgba(255,255,255,0.06), transparent 60%),
      radial-gradient(ellipse at 80% 30%, rgba(168,232,152,0.08), transparent 60%),
      radial-gradient(ellipse at 50% 100%, rgba(61,46,222,0.25), transparent 70%),
      linear-gradient(180deg, rgba(30,26,60,0.2), rgba(5,4,12,1));
    filter: blur(1px);
    pointer-events: none;
    z-index: 1;
    mask-image: radial-gradient(ellipse 120% 90% at 50% 100%, #000 60%, transparent 85%);
    -webkit-mask-image: radial-gradient(ellipse 120% 90% at 50% 100%, #000 60%, transparent 85%);
  }
  .evo-zp__moon::before {
    content:""; position:absolute; inset:0;
    background:
      radial-gradient(30px 20px at 18% 55%, rgba(0,0,0,.5), transparent 70%),
      radial-gradient(22px 15px at 36% 70%, rgba(0,0,0,.5), transparent 70%),
      radial-gradient(40px 25px at 62% 60%, rgba(0,0,0,.5), transparent 70%),
      radial-gradient(18px 12px at 82% 75%, rgba(0,0,0,.5), transparent 70%),
      radial-gradient(50px 30px at 5% 80%, rgba(0,0,0,.5), transparent 70%);
  }

  {%- comment -%} Hardcoded header removed to use global Shopify header {%- endcomment -%}

  /* Slide stage */
  .evo-zp__stage {
    position: relative; z-index: 5;
    min-height: calc(100vh - 140px);
    display: flex; align-items: center; justify-content: center;
    padding: 0 clamp(20px, 4vw, 56px);
  }
  .evo-zp__slide {
    position: absolute; inset: 0;
    display: grid;
    grid-template-columns: 280px 1fr 280px;
    align-items: center;
    gap: 36px;
    padding: 0 clamp(20px, 4vw, 56px) 120px;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity .6s var(--ease), transform .6s var(--ease);
    pointer-events: none;
  }
  .evo-zp__slide[data-active="true"] {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  @media (max-width: 1050px) {
    .evo-zp__slide { grid-template-columns: 1fr; gap: 20px; text-align: center; padding-bottom: 160px; }
  }

  /* Ghost background text behind the visual */
  .evo-zp__ghost {
    position: absolute;
    left: 50%; top: 50%;
    transform: translate(-50%, -52%);
    font-family: var(--font-d);
    font-weight: 800;
    font-size: clamp(18vw, 22vw, 28vw);
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(255,255,255,0.07);
    white-space: nowrap;
    pointer-events: none;
    z-index: 1;
    line-height: 1;
    user-select: none;
  }

  /* Left copy column */
  .evo-zp__copy-left { position: relative; z-index: 10; }
  .evo-zp__eyebrow {
    font-family: var(--font-m);
    font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--ink-dim);
    margin-bottom: 18px;
  }
  .evo-zp__chevrons {
    margin-top: 26px; margin-bottom: 28px;
    font-family: var(--font-m);
    font-size: 18px; letter-spacing: 0.22em;
    color: var(--mint);
  }
  .evo-zp__headline {
    font-family: var(--font-d);
    font-weight: 800;
    font-size: clamp(22px, 2vw, 30px);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: #fff;
    margin: 0;
    text-transform: uppercase;
  }
  .evo-zp__cta {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 28px;
    font-family: var(--font-m);
    font-size: 12px; letter-spacing: 0.22em; text-transform: uppercase;
    font-weight: 700;
    background: var(--peach);
    color: #110A04;
    border-radius: 6px;
    transition: transform .25s var(--ease), background .25s var(--ease), box-shadow .25s var(--ease);
    box-shadow: 0 8px 28px rgba(255,122,74,0.35);
  }
  .evo-zp__cta:hover { transform: translateY(-2px); background: #FF8E62; box-shadow: 0 12px 36px rgba(255,122,74,0.55); }

  /* Center visual */
  .evo-zp__visual {
    position: relative;
    display: flex; align-items: center; justify-content: center;
    min-height: clamp(360px, 48vh, 560px);
    z-index: 5;
  }
  .evo-zp__visual svg {
    width: min(420px, 55vw);
    height: auto;
    filter: drop-shadow(0 0 80px rgba(168,232,152,0.35)) drop-shadow(0 30px 60px rgba(0,0,0,.55));
    animation: evo-zp-float 6s ease-in-out infinite;
  }
  @keyframes evo-zp-float {
    0%,100% { transform: translateY(-6px) rotate(-2deg); }
    50%     { transform: translateY(8px)  rotate(2deg); }
  }

  /* Floating orbital particles */
  .evo-zp__orbit { position: absolute; inset: 0; pointer-events: none; }
  .evo-zp__orbit span {
    position: absolute;
    width: 10px; height: 10px; border-radius: 999px;
    background: var(--mint);
    box-shadow: 0 0 18px var(--mint);
    animation: evo-zp-orbit 9s linear infinite;
  }
  .evo-zp__orbit span:nth-child(1) { top:10%; left:18%; width:14px; height:14px; background:var(--indigo-2); box-shadow:0 0 22px var(--indigo-2); animation-duration: 13s; }
  .evo-zp__orbit span:nth-child(2) { top:28%; left:82%; width:10px; height:10px; animation-duration: 10s; animation-direction: reverse; }
  .evo-zp__orbit span:nth-child(3) { top:70%; left:12%; width:8px; height:8px; background:#fff; box-shadow:0 0 12px #fff; animation-duration: 15s; }
  .evo-zp__orbit span:nth-child(4) { top:78%; left:78%; width:12px; height:12px; background:var(--mint-2); box-shadow:0 0 20px var(--mint-2); animation-duration: 11s; animation-direction: reverse; }
  .evo-zp__orbit span:nth-child(5) { top:42%; left:94%; width:6px; height:6px; background:#fff; opacity:.7; animation-duration: 17s; }
  @keyframes evo-zp-orbit {
    0%   { transform: translate(0,0);    }
    25%  { transform: translate(20px,-14px); }
    50%  { transform: translate(0,-24px);   }
    75%  { transform: translate(-20px,-14px);}
    100% { transform: translate(0,0);    }
  }

  /* Right description column */
  .evo-zp__copy-right {
    position: relative; z-index: 10;
    font-family: var(--font-m);
    font-size: 13px;
    line-height: 1.7;
    color: var(--ink-dim);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    justify-self: end;
    text-align: right;
    max-width: 260px;
  }
  @media (max-width: 1050px) {
    .evo-zp__copy-right, .evo-zp__copy-left { text-align: center; justify-self: center; max-width: 420px; }
  }

  /* Slide tracker */
  .evo-zp__tracker {
    position: absolute; z-index: 20;
    left: clamp(20px, 4vw, 56px); bottom: 32px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .evo-zp__tracker button {
    display: inline-flex; align-items: center; gap: 10px;
    background: transparent; border: none; cursor: pointer;
    padding: 6px 2px;
    color: var(--ink-muted);
    font-family: var(--font-m);
    font-size: 13px; letter-spacing: 0.22em;
    text-transform: uppercase;
    transition: color .2s var(--ease);
    text-align: left;
  }
  .evo-zp__tracker button::before {
    content: "";
    width: 18px; height: 1px; background: currentColor; opacity: .4; transition: width .3s var(--ease), opacity .3s var(--ease), background .3s var(--ease);
  }
  .evo-zp__tracker button:hover { color: var(--ink); }
  .evo-zp__tracker button[aria-current="true"] { color: #fff; font-weight: 700; }
  .evo-zp__tracker button[aria-current="true"]::before { width: 36px; opacity: 1; background: var(--mint); }

  /* Social */
  .evo-zp__social {
    position: absolute; z-index: 20;
    right: clamp(20px, 4vw, 56px); bottom: 32px;
    display: inline-flex; gap: 6px;
  }
  .evo-zp__social a {
    display:inline-flex; align-items:center; justify-content:center;
    width: 38px; height: 38px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 4px;
    font-family: var(--font-m);
    font-size: 11px; letter-spacing: 0.1em;
    color: var(--ink-dim);
    transition: color .2s var(--ease), border-color .2s var(--ease), background .2s var(--ease);
  }
  .evo-zp__social a:hover { color: var(--mint); border-color: rgba(168,232,152,0.5); background: rgba(168,232,152,0.06); }

  /* Side arrows */
  .evo-zp__arrow {
    position: absolute; z-index: 15;
    top: 50%; transform: translateY(-50%);
    width: 44px; height: 44px; border-radius: 999px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.12);
    color: #fff;
    cursor: pointer;
    transition: background .2s var(--ease), border-color .2s var(--ease), transform .2s var(--ease);
  }
  .evo-zp__arrow:hover { background: rgba(168,232,152,0.1); border-color: rgba(168,232,152,0.5); transform: translateY(-50%) scale(1.05); }
  .evo-zp__arrow--prev { left: clamp(10px, 2vw, 28px); }
  .evo-zp__arrow--next { right: clamp(10px, 2vw, 28px); }
  .evo-zp__arrow svg { width: 16px; height: 16px; }

/* ---- COLLECTION RAIL ---- */

  :root {
    --bg:        #05040C;
    --bg-2:      #0B0820;
    --bg-3:      #14122B;
    --ink:       #FFFFFF;
    --ink-dim:   #B6B5C6;
    --ink-muted: #7A7A8F;
    --mint:      #A8E898;
    --mint-2:    #CDFFBF;
    --indigo:    #3D2EDE;
    --indigo-2:  #5B4DFF;
    --line:      rgba(255,255,255,0.08);
    --font-d:    'Clash Display','Satoshi','Inter',sans-serif;
    --font-s:    'Satoshi','Inter',system-ui,sans-serif;
    --font-m:    'JetBrains Mono',ui-monospace,monospace;
    --ease:      cubic-bezier(.21,.83,.33,1);
  }
  
  a { color:inherit; text-decoration:none; }

  /* ===== Section wrapper ===== */
  .evo-cat {
    position: relative;
    padding: clamp(60px, 8vw, 110px) 0 clamp(80px, 10vw, 140px);
    background:
      radial-gradient(1200px 500px at 15% -10%, rgba(61,46,222,0.18), transparent 55%),
      radial-gradient(900px 400px at 85% 110%, rgba(168,232,152,0.10), transparent 60%),
      linear-gradient(180deg, #05040C 0%, #0A0820 100%);
    overflow: hidden;
  }
  .evo-cat::before {
    content: "";
    position: absolute; inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,.5), transparent),
      radial-gradient(1.5px 1.5px at 70% 50%, rgba(168,232,152,.4), transparent),
      radial-gradient(1px 1px at 45% 80%, rgba(255,255,255,.6), transparent),
      radial-gradient(1px 1px at 85% 20%, rgba(205,255,191,.45), transparent),
      radial-gradient(1px 1px at 10% 70%, rgba(255,255,255,.5), transparent);
    background-size: 900px 900px;
    background-repeat: repeat;
    opacity: .6;
    animation: twinkle 8s linear infinite;
  }
  @keyframes twinkle { 0%,100% { opacity:.6; } 50% { opacity:.35; } }

  /* ===== Header row ===== */
  .evo-cat__head {
    position: relative; z-index: 2;
    max-width: 1320px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr auto;
    gap: 28px; align-items: end;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .evo-cat__kicker {
    font-family: var(--font-m);
    font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--mint);
    margin: 0 0 16px 0;
  }
  .evo-cat__title {
    font-family: var(--font-d);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 72px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
  }
  .evo-cat__title em { color: var(--mint); font-style: normal; font-family: 'Caveat', cursive; font-weight: 500; }
  .evo-cat__subtitle {
    max-width: 380px;
    color: var(--ink-dim);
    font-size: 15px; line-height: 1.6;
  }
  @media (max-width: 860px) {
    .evo-cat__head { grid-template-columns: 1fr; }
    .evo-cat__subtitle { max-width: none; }
  }

  /* ===== Carousel / scroller ===== */
  .evo-cat__rail-wrap {
    position: relative; z-index: 2;
    margin-top: clamp(40px, 6vw, 72px);
  }
  .evo-cat__rail {
    display: flex; gap: 24px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    padding: 12px clamp(20px, 4vw, 48px) 28px;
    scroll-padding-left: clamp(20px, 4vw, 48px);
    scrollbar-width: none;
  }
  .evo-cat__rail::-webkit-scrollbar { display: none; }

  /* ===== Category card ===== */
  .evo-cat__card {
    flex: 0 0 auto;
    width: 190px;
    scroll-snap-align: start;
    display: flex; flex-direction: column; align-items: center;
    text-align: center;
    gap: 14px;
    padding: 28px 12px 20px;
    border-radius: 24px;
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(20,18,43,0.55) 0%, rgba(11,8,32,0.55) 100%);
    transition: transform .35s var(--ease), border-color .35s var(--ease), background .35s var(--ease);
    cursor: pointer;
  }
  .evo-cat__card:hover {
    transform: translateY(-6px);
    border-color: rgba(168,232,152,0.35);
    background: linear-gradient(180deg, rgba(35,28,80,0.7) 0%, rgba(15,11,46,0.7) 100%);
  }
  .evo-cat__card:hover .evo-cat__ring {
    box-shadow:
      0 0 0 1px rgba(168,232,152,0.6) inset,
      0 0 28px rgba(168,232,152,0.35);
  }

  /* Ring holding the animated icon */
  .evo-cat__ring {
    position: relative;
    width: 124px; height: 124px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    background:
      radial-gradient(circle at 30% 25%, rgba(168,232,152,0.22), transparent 60%),
      radial-gradient(circle at 70% 75%, rgba(61,46,222,0.28), transparent 65%),
      linear-gradient(160deg, #14122B 0%, #08061A 100%);
    box-shadow:
      0 0 0 1px rgba(168,232,152,0.18) inset,
      0 0 24px rgba(168,232,152,0.08);
    transition: box-shadow .35s var(--ease);
  }
  .evo-cat__ring::after {
    content: "";
    position: absolute; inset: -4px;
    border-radius: inherit;
    border: 1px dashed rgba(168,232,152,0.18);
    animation: ring-spin 22s linear infinite;
  }
  .evo-cat__card:hover .evo-cat__ring::after { animation-duration: 8s; border-color: rgba(168,232,152,0.45); }
  @keyframes ring-spin { to { transform: rotate(360deg); } }

  .evo-cat__icon {
    width: 74px; height: 74px;
    position: relative;
    z-index: 2;
  }

  .evo-cat__label {
    font-family: var(--font-s);
    font-weight: 600;
    font-size: 14px;
    color: #fff;
    line-height: 1.3;
  }
  .evo-cat__count {
    font-family: var(--font-m);
    font-size: 10px; letter-spacing: 0.22em;
    color: var(--ink-muted);
    text-transform: uppercase;
  }

  /* ===== Progress rail underneath (like the live site's green bar) ===== */
  .evo-cat__progress {
    max-width: 1320px; margin: 6px auto 0;
    padding: 0 clamp(20px, 4vw, 48px);
    display: flex; align-items: center; gap: 16px;
  }
  .evo-cat__progress-track {
    flex: 1;
    height: 3px;
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }
  .evo-cat__progress-bar {
    position: absolute; left: 0; top: 0; bottom: 0;
    width: 22%;
    background: linear-gradient(90deg, var(--mint) 0%, var(--indigo-2) 100%);
    border-radius: 3px;
    transition: width .25s var(--ease), transform .25s var(--ease);
  }
  .evo-cat__progress-ctrls { display: inline-flex; gap: 8px; }
  .evo-cat__progress-ctrls button {
    width: 40px; height: 40px;
    display: inline-flex; align-items: center; justify-content: center;
    background: transparent;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 999px;
    color: #fff; cursor: pointer;
    transition: background .2s var(--ease), border-color .2s var(--ease), transform .2s var(--ease);
  }
  .evo-cat__progress-ctrls button:hover {
    background: rgba(168,232,152,0.08);
    border-color: rgba(168,232,152,0.5);
    transform: scale(1.05);
  }
  .evo-cat__progress-ctrls svg { width: 16px; height: 16px; }

  /* =========================================================================
     Per-icon animations
     ========================================================================= */

  /* Routers — radiating wifi arcs from chassis */
  .ico-router .wave { opacity: 0; animation: router-wave 2.4s ease-out infinite; transform-origin: 37px 40px; }
  .ico-router .wave.w1 { animation-delay: 0s; }
  .ico-router .wave.w2 { animation-delay: 0.6s; }
  .ico-router .wave.w3 { animation-delay: 1.2s; }
  @keyframes router-wave {
    0%   { opacity: 0.9; transform: scale(0.6); }
    100% { opacity: 0; transform: scale(1.8); }
  }
  .ico-router .led { animation: pulse-led 1.2s ease-in-out infinite alternate; }
  .ico-router .led.l2 { animation-delay: .2s; }
  .ico-router .led.l3 { animation-delay: .4s; }
  .ico-router .led.l4 { animation-delay: .6s; }

  /* Switches — LED traffic across port strip */
  .ico-switch .port-led { opacity: 0.2; animation: switch-flow 2s linear infinite; }
  .ico-switch .port-led.p2 { animation-delay: 0.15s; }
  .ico-switch .port-led.p3 { animation-delay: 0.30s; }
  .ico-switch .port-led.p4 { animation-delay: 0.45s; }
  .ico-switch .port-led.p5 { animation-delay: 0.60s; }
  .ico-switch .port-led.p6 { animation-delay: 0.75s; }
  .ico-switch .port-led.p7 { animation-delay: 0.90s; }
  .ico-switch .port-led.p8 { animation-delay: 1.05s; }
  @keyframes switch-flow {
    0%   { opacity: 0.1; }
    20%  { opacity: 1;   }
    60%  { opacity: 1;   }
    100% { opacity: 0.1; }
  }

  /* Access points — radiating dome signals */
  .ico-ap .arc { opacity: 0; animation: ap-arc 2.6s ease-out infinite; transform-origin: 37px 48px; }
  .ico-ap .arc.a1 { animation-delay: 0s; }
  .ico-ap .arc.a2 { animation-delay: 0.65s; }
  .ico-ap .arc.a3 { animation-delay: 1.3s; }
  @keyframes ap-arc {
    0%   { opacity: 0.9; transform: scale(0.4); }
    100% { opacity: 0;   transform: scale(1.8); }
  }

  /* NAS — stacked drives with sync pulse */
  .ico-nas .drive-led { animation: nas-sync 1.6s ease-in-out infinite; }
  .ico-nas .drive-led.d2 { animation-delay: .2s; }
  .ico-nas .drive-led.d3 { animation-delay: .4s; }
  .ico-nas .drive-led.d4 { animation-delay: .6s; }
  @keyframes nas-sync {
    0%,100% { opacity: 0.3; fill: #A8E898; }
    50%     { opacity: 1;   fill: #CDFFBF; }
  }

  /* HDD — spinning platter */
  .ico-hdd .platter { transform-origin: 37px 37px; animation: hdd-spin 4s linear infinite; }
  @keyframes hdd-spin { to { transform: rotate(360deg); } }
  .ico-hdd .head-arm { transform-origin: 58px 18px; animation: hdd-arm 3s ease-in-out infinite alternate; }
  @keyframes hdd-arm {
    0%   { transform: rotate(-10deg); }
    100% { transform: rotate(15deg); }
  }

  /* GPU — fan spinning */
  .ico-gpu .fan { transform-origin: 37px 37px; animation: gpu-fan 1.6s linear infinite; }
  @keyframes gpu-fan { to { transform: rotate(360deg); } }

  /* Laptop — screen gradient cycling */
  .ico-lap .screen-wave {
    animation: lap-wave 3s ease-in-out infinite;
  }
  @keyframes lap-wave {
    0%,100% { opacity: 0.3; }
    50%     { opacity: 1; }
  }

  /* CPU — die cores pulsing */
  .ico-cpu .core { animation: cpu-core 1.8s ease-in-out infinite; }
  .ico-cpu .core.c1 { animation-delay: 0s; }
  .ico-cpu .core.c2 { animation-delay: .3s; }
  .ico-cpu .core.c3 { animation-delay: .6s; }
  .ico-cpu .core.c4 { animation-delay: .9s; }
  @keyframes cpu-core {
    0%,100% { opacity: 0.3; }
    50%     { opacity: 1; }
  }

  /* Motherboard — traces lighting up */
  .ico-mobo .trace {
    stroke-dasharray: 3 4;
    animation: mobo-trace 1.8s linear infinite;
  }
  .ico-mobo .trace.t2 { animation-duration: 2.4s; animation-direction: reverse; }
  @keyframes mobo-trace {
    from { stroke-dashoffset: 0;   }
    to   { stroke-dashoffset: -14; }
  }
  .ico-mobo .chip-led { animation: pulse-led 1.4s ease-in-out infinite alternate; }

  /* Generic LED pulse */
  @keyframes pulse-led {
    0%   { opacity: 0.4; }
    100% { opacity: 1;   }
  }

  /* Preview caption */
  .zp-caption {
    position: fixed; top: 12px; left: 12px; z-index: 900;
    font-family: var(--font-m);
    font-size: 10px; letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: rgba(10,8,26,0.75);
    border: 1px solid var(--line);
    padding: 6px 12px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }

/* ---- PRODUCT SHOWCASE ---- */

  :root {
    --bg:        #05040C;
    --bg-2:      #0B0820;
    --bg-3:      #14122B;
    --ink:       #FFFFFF;
    --ink-dim:   #B6B5C6;
    --ink-muted: #7A7A8F;
    --mint:      #A8E898;
    --mint-2:    #CDFFBF;
    --indigo:    #3D2EDE;
    --indigo-2:  #5B4DFF;
    --peach:     #FF7A4A;
    --amber:     #FFC566;
    --red:       #FF5A6A;
    --line:      rgba(255,255,255,0.08);
    --font-d:    'Clash Display','Satoshi','Inter',sans-serif;
    --font-s:    'Satoshi','Inter',system-ui,sans-serif;
    --font-m:    'JetBrains Mono',ui-monospace,monospace;
    --ease:      cubic-bezier(.21,.83,.33,1);
  }
  
  a { color:inherit; text-decoration:none; }
  button { font: inherit; cursor: pointer; }

  /* ========= Shared section chrome ========= */
  .evo-wrap {
    max-width: 1320px; margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 48px);
  }
  .evo-section {
    position: relative;
    padding: clamp(60px, 8vw, 110px) 0;
  }
  .evo-section--dark {
    background:
      radial-gradient(1200px 500px at 15% -10%, rgba(61,46,222,0.16), transparent 55%),
      radial-gradient(900px 400px at 85% 110%, rgba(168,232,152,0.08), transparent 60%),
      linear-gradient(180deg, #05040C 0%, #0A0820 100%);
    overflow: hidden;
  }
  .evo-section__head {
    display: grid; grid-template-columns: 1fr auto;
    gap: 24px; align-items: end;
    margin-bottom: clamp(32px, 4vw, 56px);
  }
  .evo-eyebrow {
    font-family: var(--font-m);
    font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--mint);
    margin: 0 0 14px 0;
  }
  .evo-title {
    font-family: var(--font-d);
    font-weight: 700;
    font-size: clamp(32px, 4.2vw, 60px);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
  }
  .evo-title em { color: var(--mint); font-style: normal; font-family: 'Caveat', cursive; font-weight: 500; }
  .evo-head-link {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-m); font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--mint);
    border-bottom: 1px solid rgba(168,232,152,0.4);
    padding-bottom: 4px;
    align-self: start;
  }
  @media (max-width: 860px) {
    .evo-section__head { grid-template-columns: 1fr; }
  }

  /* ========================================================================
     FEATURED PRODUCT SHOWCASE
     ======================================================================== */
  .evo-feat {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 28px;
    align-items: stretch;
  }
  @media (max-width: 980px) {
    .evo-feat { grid-template-columns: 1fr; }
  }

  .evo-feat__hero {
    position: relative;
    min-height: 540px;
    border-radius: 28px;
    overflow: hidden;
    background:
      radial-gradient(1000px 500px at 80% 100%, rgba(61,46,222,0.35), transparent 60%),
      radial-gradient(500px 300px at 20% 20%, rgba(168,232,152,0.14), transparent 60%),
      linear-gradient(145deg, #0F0C2A 0%, #06041A 100%);
    border: 1px solid var(--line);
    padding: clamp(28px, 3vw, 44px);
    display: flex; flex-direction: column; justify-content: space-between;
    isolation: isolate;
  }
  .evo-feat__hero::before {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 15% 25%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 75% 65%, rgba(168,232,152,.4), transparent),
      radial-gradient(1.5px 1.5px at 50% 85%, rgba(205,255,191,.5), transparent);
    background-size: 800px 800px;
    opacity: .45;
  }
  .evo-feat__hero-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 16px;
    position: relative; z-index: 2;
  }
  .evo-feat__kicker {
    font-family: var(--font-m); font-size: 11px; letter-spacing: 0.26em; text-transform: uppercase;
    color: var(--ink-muted);
    margin: 0 0 10px 0;
  }
  .evo-feat__name {
    font-family: var(--font-d); font-weight: 800;
    font-size: clamp(32px, 3.6vw, 56px);
    line-height: 1.02; letter-spacing: -0.02em;
    margin: 0 0 18px 0;
    color: #fff;
  }
  .evo-feat__desc {
    max-width: 480px;
    color: var(--ink-dim);
    font-size: 15px; line-height: 1.6;
    margin: 0;
  }
  .evo-feat__badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: linear-gradient(90deg, #A8E898 0%, #CDFFBF 100%);
    color: #0A0A0A;
    font-family: var(--font-m);
    font-size: 10px; letter-spacing: 0.24em; text-transform: uppercase;
    font-weight: 700;
    padding: 6px 12px; border-radius: 999px;
    box-shadow: 0 4px 20px rgba(168,232,152,0.35);
    white-space: nowrap;
  }
  .evo-feat__badge--live::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: #0A0A0A; animation: blink-live 1.2s ease-in-out infinite;
  }
  @keyframes blink-live { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }

  .evo-feat__viz {
    position: relative; z-index: 2;
    margin: 28px 0;
    display: flex; align-items: center; justify-content: center;
    min-height: 220px;
  }
  .evo-feat__viz svg {
    width: min(340px, 70%); height: auto;
    filter: drop-shadow(0 40px 60px rgba(0,0,0,0.5));
    animation: feat-float 6s ease-in-out infinite;
  }
  @keyframes feat-float {
    0%,100% { transform: translateY(-6px); }
    50%     { transform: translateY(10px); }
  }

  .evo-feat__meta {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1fr auto; gap: 18px;
    align-items: end;
  }
  .evo-feat__price-row {
    display: flex; align-items: baseline; gap: 14px;
    flex-wrap: wrap;
  }
  .evo-feat__price {
    font-family: var(--font-d); font-weight: 800;
    font-size: clamp(32px, 3vw, 44px);
    color: var(--mint);
    line-height: 1;
  }
  .evo-feat__price-compare {
    font-family: var(--font-s);
    font-size: 18px; color: var(--ink-muted);
    text-decoration: line-through;
  }
  .evo-feat__gst {
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.2em;
    color: var(--ink-muted); text-transform: uppercase;
  }
  .evo-feat__cta-row {
    display: inline-flex; gap: 10px; align-items: center;
  }
  .evo-btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 22px;
    font-family: var(--font-m);
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 700;
    background: var(--peach);
    color: #110A04;
    border: none; border-radius: 10px;
    transition: transform .2s var(--ease), background .2s var(--ease), box-shadow .2s var(--ease);
    box-shadow: 0 6px 22px rgba(255,122,74,0.3);
  }
  .evo-btn-primary:hover { transform: translateY(-2px); background: #FF8E62; box-shadow: 0 12px 30px rgba(255,122,74,0.5); }
  .evo-btn-ghost {
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px;
    border: 1px solid rgba(255,255,255,0.15);
    background: transparent; color: #fff;
    border-radius: 10px;
    transition: background .2s var(--ease), border-color .2s var(--ease), color .2s var(--ease);
  }
  .evo-btn-ghost:hover { background: rgba(168,232,152,0.08); border-color: rgba(168,232,152,0.5); color: var(--mint); }
  .evo-btn-ghost svg { width: 18px; height: 18px; }

  .evo-feat__ticker {
    position: relative; z-index: 2;
    margin-top: 18px; padding-top: 18px;
    border-top: 1px solid var(--line);
    display: flex; gap: 22px; flex-wrap: wrap;
    font-family: var(--font-m);
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-dim);
  }
  .evo-feat__ticker-item { display: inline-flex; align-items: center; gap: 8px; }
  .evo-feat__ticker-item svg { width: 14px; height: 14px; color: var(--mint); flex-shrink: 0; }
  .evo-feat__ticker-item .dot {
    width: 7px; height: 7px; border-radius: 50%; background: var(--mint);
    box-shadow: 0 0 10px var(--mint);
    animation: live-pulse 1.8s ease-in-out infinite;
  }
  @keyframes live-pulse { 0%,100% { transform: scale(1); opacity: 0.85; } 50% { transform: scale(1.25); opacity: 1; } }

  /* Right column — 3 stacked feature cards */
  .evo-feat__side {
    display: grid; grid-template-rows: 1fr 1fr;
    gap: 28px;
  }
  .evo-feat__tile {
    position: relative;
    border-radius: 28px; overflow: hidden;
    border: 1px solid var(--line);
    background:
      radial-gradient(800px 400px at 100% 0%, rgba(168,232,152,0.12), transparent 55%),
      linear-gradient(160deg, #120E2E 0%, #06041A 100%);
    padding: clamp(24px, 2.4vw, 36px);
    min-height: 240px;
    display: flex; flex-direction: column; justify-content: space-between;
    transition: transform .35s var(--ease), border-color .35s var(--ease);
  }
  .evo-feat__tile:hover {
    transform: translateY(-4px);
    border-color: rgba(168,232,152,0.35);
  }
  .evo-feat__tile-row-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  @media (max-width: 640px) {
    .evo-feat__tile-row-2 { grid-template-columns: 1fr; }
  }
  .evo-feat__tile-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 12px;
  }
  .evo-feat__tile-name {
    font-family: var(--font-d); font-weight: 700;
    font-size: clamp(22px, 2.2vw, 30px);
    line-height: 1.05; letter-spacing: -0.01em;
    margin: 6px 0 8px;
  }
  .evo-feat__tile-desc { color: var(--ink-dim); font-size: 13px; line-height: 1.5; margin: 0; }
  .evo-feat__tile-viz {
    align-self: flex-end;
    display: flex; align-items: center; justify-content: center;
    margin-top: 14px;
    width: 100%; height: 110px;
  }
  .evo-feat__tile-viz svg { max-width: 80%; max-height: 100%; }
  .evo-feat__tile-cta {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-m); font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--mint);
  }
  .evo-feat__tile-cta svg { width: 14px; height: 14px; transition: transform .25s var(--ease); }
  .evo-feat__tile:hover .evo-feat__tile-cta svg { transform: translateX(4px); }

  .evo-pill {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(10,8,26,0.7); color: var(--mint);
    border: 1px solid rgba(168,232,152,0.35);
    font-family: var(--font-m); font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;
    font-weight: 700;
    padding: 5px 10px; border-radius: 999px;
  }
  .evo-pill--hot { background: rgba(255,90,106,0.12); color: #FF8B98; border-color: rgba(255,90,106,0.35); }
  .evo-pill--amber { background: rgba(255,197,102,0.12); color: var(--amber); border-color: rgba(255,197,102,0.35); }

  /* ========================================================================
     BEST-SELLER GRID
     ======================================================================== */
  .evo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  @media (max-width: 1100px) { .evo-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 820px)  { .evo-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px)  { .evo-grid { grid-template-columns: 1fr; } }

  .evo-card {
    position: relative;
    display: flex; flex-direction: column;
    background: linear-gradient(180deg, rgba(20,18,43,0.7) 0%, rgba(11,8,32,0.7) 100%);
    border: 1px solid var(--line);
    border-radius: 20px;
    overflow: hidden;
    transition: transform .35s var(--ease), border-color .35s var(--ease);
  }
  .evo-card:hover {
    transform: translateY(-6px);
    border-color: rgba(168,232,152,0.3);
  }

  /* Rank ribbon */
  .evo-card__rank {
    position: absolute; top: 14px; left: 14px; z-index: 4;
    display: inline-flex; align-items: center; gap: 6px;
    padding: 5px 11px;
    background: linear-gradient(90deg, #A8E898 0%, #CDFFBF 100%);
    color: #0A0A0A;
    border-radius: 999px;
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.18em; font-weight: 700; text-transform: uppercase;
    box-shadow: 0 4px 14px rgba(168,232,152,0.35);
  }
  .evo-card__rank svg { width: 12px; height: 12px; }

  /* Wishlist */
  .evo-card__wish {
    position: absolute; top: 14px; right: 14px; z-index: 4;
    width: 34px; height: 34px; border-radius: 50%;
    background: rgba(10,8,26,0.75);
    border: 1px solid rgba(255,255,255,0.1);
    display: inline-flex; align-items: center; justify-content: center;
    color: #fff;
    backdrop-filter: blur(6px);
    transition: color .2s var(--ease), border-color .2s var(--ease), background .2s var(--ease);
  }
  .evo-card__wish:hover { color: var(--mint); border-color: rgba(168,232,152,0.5); background: rgba(168,232,152,0.08); }
  .evo-card__wish svg { width: 16px; height: 16px; }

  /* Product image area */
  .evo-card__media {
    position: relative;
    aspect-ratio: 4 / 3;
    background:
      radial-gradient(ellipse at 50% 100%, rgba(168,232,152,0.12), transparent 60%),
      linear-gradient(180deg, #14122B 0%, #0A0820 100%);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .evo-card__media svg {
    width: 65%; height: 65%;
    filter: drop-shadow(0 30px 40px rgba(0,0,0,0.6));
    animation: card-float 5s ease-in-out infinite;
  }
  .evo-card:nth-child(2n) .evo-card__media svg { animation-delay: 0.8s; }
  .evo-card:nth-child(3n) .evo-card__media svg { animation-delay: 1.6s; }
  .evo-card:nth-child(4n) .evo-card__media svg { animation-delay: 2.4s; }
  @keyframes card-float {
    0%,100% { transform: translateY(-4px) rotate(-1deg); }
    50%     { transform: translateY(6px)  rotate(1deg); }
  }
  .evo-card__media::after {
    content: "";
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(5,4,12,0.95));
    pointer-events: none;
  }

  /* Quick actions over media */
  .evo-card__quick {
    position: absolute; left: 14px; right: 14px; bottom: 14px; z-index: 3;
    display: flex; gap: 8px;
    transform: translateY(80%);
    opacity: 0;
    transition: transform .35s var(--ease), opacity .35s var(--ease);
  }
  .evo-card:hover .evo-card__quick { transform: translateY(0); opacity: 1; }
  .evo-card__quick button {
    flex: 1; min-height: 36px;
    background: rgba(10,8,26,0.88);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 600;
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    transition: background .2s var(--ease), border-color .2s var(--ease), color .2s var(--ease);
    backdrop-filter: blur(6px);
  }
  .evo-card__quick button:hover { background: rgba(168,232,152,0.15); border-color: rgba(168,232,152,0.5); color: var(--mint); }
  .evo-card__quick button svg { width: 14px; height: 14px; }

  /* Card body */
  .evo-card__body {
    padding: 18px 20px 22px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .evo-card__brand {
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-muted);
  }
  .evo-card__title {
    font-family: var(--font-s); font-weight: 600;
    font-size: 15px; line-height: 1.35;
    color: #fff; margin: 0;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 42px;
  }
  .evo-card__rating {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-m); font-size: 11px; letter-spacing: 0.1em;
    color: var(--ink-dim);
  }
  .evo-card__stars { display: inline-flex; color: var(--amber); gap: 1px; }
  .evo-card__stars svg { width: 12px; height: 12px; }

  .evo-card__price-row {
    display: flex; align-items: baseline; gap: 10px;
    margin-top: 4px;
  }
  .evo-card__price {
    font-family: var(--font-d); font-weight: 800;
    font-size: 22px;
    color: var(--mint);
    line-height: 1;
  }
  .evo-card__price-compare {
    font-family: var(--font-s); font-size: 13px;
    color: var(--ink-muted); text-decoration: line-through;
  }
  .evo-card__save {
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--peach);
    font-weight: 700;
  }

  /* Live ticker footer */
  .evo-card__live {
    padding: 12px 20px;
    border-top: 1px solid var(--line);
    display: flex; justify-content: space-between; align-items: center;
    gap: 10px;
    background: rgba(5,4,12,0.3);
  }
  .evo-card__sold {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-dim);
  }
  .evo-card__sold .dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 8px var(--mint);
    animation: live-pulse 1.8s ease-in-out infinite;
  }
  .evo-card__stock {
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--mint);
  }
  .evo-card__stock.low { color: var(--amber); }
  .evo-card__stock.out { color: var(--red); }

  /* Caption */
  .zp-caption {
    position: fixed; top: 12px; left: 12px; z-index: 900;
    font-family: var(--font-m);
    font-size: 10px; letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: rgba(10,8,26,0.75);
    border: 1px solid var(--line);
    padding: 6px 12px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }

  /* Progress meter at bottom of card (for sell-through) */
  .evo-card__meter {
    margin: 0 20px 14px;
    height: 4px; border-radius: 3px;
    background: rgba(255,255,255,0.06);
    overflow: hidden;
    position: relative;
  }
  .evo-card__meter-bar {
    position: absolute; inset: 0 auto 0 0;
    background: linear-gradient(90deg, var(--mint) 0%, var(--indigo-2) 100%);
    border-radius: 3px;
  }

/* ---- CUSTOM AI AGENTS ---- */

  :root {
    --bg:        #05040C;
    --bg-2:      #0B0820;
    --bg-3:      #14122B;
    --ink:       #FFFFFF;
    --ink-dim:   #B6B5C6;
    --ink-muted: #7A7A8F;
    --mint:      #A8E898;
    --mint-2:    #CDFFBF;
    --indigo:    #3D2EDE;
    --indigo-2:  #5B4DFF;
    --peach:     #FF7A4A;
    --amber:     #FFC566;
    --line:      rgba(255,255,255,0.08);
    --font-d:    'Clash Display','Satoshi','Inter',sans-serif;
    --font-s:    'Satoshi','Inter',system-ui,sans-serif;
    --font-m:    'JetBrains Mono',ui-monospace,monospace;
    --ease:      cubic-bezier(.21,.83,.33,1);
  }
  
  a { color:inherit; text-decoration:none; }
  button { font: inherit; cursor: pointer; }

  .evo-wrap { max-width: 1320px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }
  .evo-section {
    position: relative;
    padding: clamp(64px, 8vw, 120px) 0;
    background:
      radial-gradient(1200px 500px at 15% -10%, rgba(61,46,222,0.16), transparent 55%),
      radial-gradient(900px 400px at 85% 110%, rgba(168,232,152,0.08), transparent 60%),
      linear-gradient(180deg, #05040C 0%, #0A0820 100%);
    overflow: hidden;
  }
  .evo-section::before {
    content: ""; position: absolute; inset: 0;
    pointer-events: none;
    background-image:
      radial-gradient(1px 1px at 20% 30%, rgba(255,255,255,.5), transparent),
      radial-gradient(1.5px 1.5px at 70% 50%, rgba(168,232,152,.4), transparent),
      radial-gradient(1px 1px at 45% 80%, rgba(255,255,255,.5), transparent),
      radial-gradient(1px 1px at 85% 20%, rgba(205,255,191,.45), transparent);
    background-size: 900px 900px;
    background-repeat: repeat;
    opacity: .55;
    animation: twinkle 8s linear infinite;
  }
  @keyframes twinkle { 0%,100% { opacity:.55; } 50% { opacity:.3; } }

  /* ========= MAIN AGENTS HERO ========= */
  .evo-ag {
    position: relative; z-index: 2;
    display: grid; grid-template-columns: 1fr 1.05fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: start;
  }
  @media (max-width: 1020px) {
    .evo-ag { grid-template-columns: 1fr; }
  }

  /* Left column */
  .evo-ag__kicker {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--font-m);
    font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--mint);
    margin-bottom: 22px;
  }
  .evo-ag__kicker-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--mint);
    box-shadow: 0 0 10px var(--mint);
    animation: pulse-dot 1.6s ease-in-out infinite;
  }
  @keyframes pulse-dot { 0%,100% { transform: scale(1); } 50% { transform: scale(1.4); } }

  .evo-ag__title {
    font-family: var(--font-d);
    font-weight: 700;
    font-size: clamp(40px, 5.2vw, 76px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0 0 22px 0;
  }
  .evo-ag__title em { color: var(--mint); font-style: normal; font-family: 'Caveat', cursive; font-weight: 500; }
  .evo-ag__title-grad {
    background: linear-gradient(90deg, #A8E898 0%, #5B4DFF 100%);
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .evo-ag__desc {
    color: var(--ink-dim);
    font-size: 17px; line-height: 1.65;
    max-width: 540px;
    margin: 0 0 28px 0;
  }
  .evo-ag__desc strong { color: #fff; font-weight: 600; }

  .evo-ag__cta-row {
    display: inline-flex; flex-wrap: wrap; gap: 12px; align-items: center;
    margin-bottom: 32px;
  }
  .evo-btn-primary {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 26px;
    font-family: var(--font-m);
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 700;
    background: var(--peach);
    color: #110A04;
    border: none; border-radius: 10px;
    transition: transform .2s var(--ease), background .2s var(--ease), box-shadow .2s var(--ease);
    box-shadow: 0 8px 26px rgba(255,122,74,0.35);
  }
  .evo-btn-primary:hover { transform: translateY(-2px); background: #FF8E62; box-shadow: 0 14px 34px rgba(255,122,74,0.55); }
  .evo-btn-ghost {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 26px;
    font-family: var(--font-m);
    font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 700;
    background: transparent;
    color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 10px;
    transition: border-color .2s var(--ease), background .2s var(--ease), color .2s var(--ease);
  }
  .evo-btn-ghost:hover { border-color: rgba(168,232,152,0.55); background: rgba(168,232,152,0.06); color: var(--mint); }

  /* Trust chips */
  .evo-ag__trust {
    display: flex; flex-wrap: wrap; gap: 18px 28px;
    font-family: var(--font-m);
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    color: var(--ink-dim);
  }
  .evo-ag__trust-item { display: inline-flex; align-items: center; gap: 8px; }
  .evo-ag__trust-item svg { width: 14px; height: 14px; color: var(--mint); flex-shrink: 0; }

  /* Feature tiles (right column) */
  .evo-ag__tiles {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 16px;
    position: relative;
  }
  @media (max-width: 560px) { .evo-ag__tiles { grid-template-columns: 1fr; } }

  .evo-ag__tile {
    border-radius: 20px;
    padding: 22px;
    border: 1px solid var(--line);
    background: linear-gradient(180deg, rgba(20,18,43,0.7) 0%, rgba(11,8,32,0.7) 100%);
    transition: transform .3s var(--ease), border-color .3s var(--ease);
  }
  .evo-ag__tile:hover { transform: translateY(-4px); border-color: rgba(168,232,152,0.35); }
  .evo-ag__tile-icon {
    width: 40px; height: 40px; border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, rgba(168,232,152,0.18), rgba(61,46,222,0.28));
    border: 1px solid rgba(168,232,152,0.2);
    margin-bottom: 16px;
  }
  .evo-ag__tile-icon svg { width: 20px; height: 20px; color: var(--mint); }
  .evo-ag__tile-name {
    font-family: var(--font-d); font-weight: 700;
    font-size: 18px; line-height: 1.2;
    color: #fff;
    margin: 0 0 8px 0;
  }
  .evo-ag__tile-desc {
    color: var(--ink-dim);
    font-size: 13px; line-height: 1.55;
    margin: 0;
  }

  /* Floating price card */
  .evo-ag__price-card {
    position: absolute; top: -8px; right: -8px;
    z-index: 4;
    padding: 18px 22px;
    background: linear-gradient(135deg, #A8E898 0%, #CDFFBF 100%);
    color: #0A0A0A;
    border-radius: 18px;
    box-shadow: 0 20px 50px rgba(168,232,152,0.3), 0 0 0 1px rgba(255,255,255,0.4) inset;
    animation: price-float 5s ease-in-out infinite;
    transform: rotate(3deg);
  }
  @keyframes price-float {
    0%,100% { transform: rotate(3deg) translateY(-4px); }
    50%     { transform: rotate(3deg) translateY(6px); }
  }
  .evo-ag__price-card-label {
    font-family: var(--font-m);
    font-size: 9px; letter-spacing: 0.24em; text-transform: uppercase;
    font-weight: 700;
    opacity: 0.7;
  }
  .evo-ag__price-card-amount {
    font-family: var(--font-d);
    font-weight: 800;
    font-size: 34px;
    line-height: 1;
    margin-top: 4px;
  }
  .evo-ag__price-card-amount sup { font-size: 16px; vertical-align: top; margin-right: 2px; font-weight: 700; }
  .evo-ag__price-card-sub {
    font-family: var(--font-m);
    font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    opacity: 0.75;
    margin-top: 4px;
  }

  @media (max-width: 560px) {
    .evo-ag__price-card { position: static; transform: none; margin-bottom: 16px; display: inline-block; }
    .evo-ag__price-card:hover { animation: none; }
  }

  /* ========= USE CASES ========= */
  .evo-ag__cases {
    position: relative; z-index: 2;
    margin-top: clamp(64px, 8vw, 100px);
  }
  .evo-ag__cases-head {
    display: grid; grid-template-columns: 1fr auto;
    gap: 24px; align-items: end;
    margin-bottom: 32px;
  }
  .evo-ag__cases-title {
    font-family: var(--font-d);
    font-weight: 700;
    font-size: clamp(28px, 3.4vw, 44px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .evo-ag__cases-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 920px) { .evo-ag__cases-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .evo-ag__cases-grid { grid-template-columns: 1fr; } }

  .evo-ag__case {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 16px;
    background: rgba(11,8,32,0.5);
    display: flex; flex-direction: column; gap: 10px;
    transition: transform .3s var(--ease), border-color .3s var(--ease), background .3s var(--ease);
  }
  .evo-ag__case:hover { transform: translateY(-3px); border-color: rgba(168,232,152,0.3); background: rgba(20,18,43,0.7); }
  .evo-ag__case-emoji {
    font-size: 20px;
    width: 40px; height: 40px;
    border-radius: 10px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(168,232,152,0.1);
    border: 1px solid rgba(168,232,152,0.25);
  }
  .evo-ag__case-emoji svg { width: 20px; height: 20px; color: var(--mint); }
  .evo-ag__case-name {
    font-family: var(--font-d); font-weight: 700; font-size: 16px;
    color: #fff; margin: 0;
  }
  .evo-ag__case-desc {
    color: var(--ink-dim); font-size: 13px; line-height: 1.55;
    margin: 0;
  }
  .evo-ag__case-tag {
    align-self: flex-start;
    font-family: var(--font-m); font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--mint);
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(168,232,152,0.08);
    border: 1px solid rgba(168,232,152,0.25);
    margin-top: auto;
  }

  /* ========= PRICING TIERS ========= */
  .evo-ag__pricing {
    position: relative; z-index: 2;
    margin-top: clamp(64px, 8vw, 100px);
  }
  .evo-ag__pricing-head {
    text-align: center;
    margin-bottom: 40px;
  }
  .evo-ag__pricing-sub {
    color: var(--ink-dim);
    font-size: 16px; line-height: 1.6;
    max-width: 560px; margin: 14px auto 0;
  }
  .evo-ag__tiers {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  @media (max-width: 980px) { .evo-ag__tiers { grid-template-columns: 1fr; max-width: 520px; margin: 0 auto; } }

  .evo-ag__tier {
    position: relative;
    padding: 32px 28px 36px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: linear-gradient(180deg, rgba(20,18,43,0.7) 0%, rgba(11,8,32,0.7) 100%);
    display: flex; flex-direction: column;
  }
  .evo-ag__tier--featured {
    border-color: rgba(168,232,152,0.4);
    background:
      radial-gradient(600px 400px at 100% 0%, rgba(168,232,152,0.14), transparent 60%),
      linear-gradient(180deg, rgba(35,28,80,0.7) 0%, rgba(15,11,46,0.7) 100%);
    box-shadow: 0 30px 70px rgba(61,46,222,0.25);
    transform: translateY(-8px);
  }
  @media (max-width: 980px) { .evo-ag__tier--featured { transform: none; } }

  .evo-ag__tier-badge {
    position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
    padding: 6px 14px;
    background: linear-gradient(90deg, #A8E898 0%, #CDFFBF 100%);
    color: #0A0A0A;
    border-radius: 999px;
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.22em; font-weight: 700; text-transform: uppercase;
    box-shadow: 0 4px 14px rgba(168,232,152,0.4);
  }

  .evo-ag__tier-name {
    font-family: var(--font-m); font-size: 11px; letter-spacing: 0.24em; text-transform: uppercase;
    color: var(--mint);
    margin: 0 0 8px 0;
  }
  .evo-ag__tier-title {
    font-family: var(--font-d); font-weight: 700;
    font-size: 26px; line-height: 1.1;
    color: #fff;
    margin: 0 0 16px 0;
  }
  .evo-ag__tier-price {
    font-family: var(--font-d); font-weight: 800;
    font-size: 48px; line-height: 1;
    color: #fff;
    margin: 0;
  }
  .evo-ag__tier-price sup { font-size: 22px; font-weight: 700; vertical-align: top; margin-right: 2px; }
  .evo-ag__tier-price-sub {
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-muted);
    margin-top: 6px;
  }
  .evo-ag__tier-hr {
    border: none; border-top: 1px solid var(--line);
    margin: 22px 0;
  }
  .evo-ag__tier-list {
    list-style: none; padding: 0; margin: 0 0 28px 0;
    display: flex; flex-direction: column; gap: 12px;
    font-size: 14px; color: var(--ink-dim);
    line-height: 1.5;
  }
  .evo-ag__tier-list li {
    display: flex; gap: 10px; align-items: flex-start;
  }
  .evo-ag__tier-list li::before {
    content: ""; margin-top: 6px;
    width: 14px; height: 14px; flex-shrink: 0;
    background: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 14 14'><path d='M3 7l3 3 5-6' stroke='%23A8E898' stroke-width='2' fill='none' stroke-linecap='round' stroke-linejoin='round'/></svg>") no-repeat center / 14px;
  }
  .evo-ag__tier-cta {
    margin-top: auto;
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    padding: 14px 20px;
    font-family: var(--font-m); font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 700;
    border-radius: 10px;
    background: transparent; color: #fff;
    border: 1px solid rgba(255,255,255,0.2);
    transition: border-color .2s var(--ease), background .2s var(--ease), color .2s var(--ease);
  }
  .evo-ag__tier-cta:hover { border-color: rgba(168,232,152,0.5); background: rgba(168,232,152,0.06); color: var(--mint); }
  .evo-ag__tier--featured .evo-ag__tier-cta {
    background: var(--peach); color: #110A04; border-color: transparent;
    box-shadow: 0 8px 22px rgba(255,122,74,0.3);
  }
  .evo-ag__tier--featured .evo-ag__tier-cta:hover { background: #FF8E62; color: #110A04; box-shadow: 0 12px 28px rgba(255,122,74,0.5); }

  /* ========= PROCESS ========= */
  .evo-ag__process {
    position: relative; z-index: 2;
    margin-top: clamp(64px, 8vw, 100px);
  }
  .evo-ag__steps {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    position: relative;
  }
  @media (max-width: 980px) { .evo-ag__steps { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 520px) { .evo-ag__steps { grid-template-columns: 1fr; } }

  .evo-ag__step {
    position: relative;
    padding: 28px 24px 26px;
    border: 1px solid var(--line);
    border-radius: 18px;
    background: rgba(11,8,32,0.55);
    display: flex; flex-direction: column; gap: 10px;
    overflow: hidden;
  }
  .evo-ag__step::before {
    content: attr(data-step);
    position: absolute; top: -6px; right: 18px;
    font-family: var(--font-d); font-weight: 800;
    font-size: 88px; line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(168,232,152,0.18);
    pointer-events: none;
    user-select: none;
  }
  .evo-ag__step-icon {
    width: 44px; height: 44px; border-radius: 12px;
    display: inline-flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, rgba(168,232,152,0.2), rgba(61,46,222,0.25));
    border: 1px solid rgba(168,232,152,0.28);
  }
  .evo-ag__step-icon svg { width: 22px; height: 22px; color: var(--mint); }
  .evo-ag__step-name {
    font-family: var(--font-d); font-weight: 700;
    font-size: 18px; line-height: 1.2; color: #fff; margin: 0;
  }
  .evo-ag__step-desc {
    color: var(--ink-dim); font-size: 13px; line-height: 1.55; margin: 0;
    position: relative; z-index: 2;
  }
  .evo-ag__step-meta {
    margin-top: auto;
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--mint);
    padding-top: 6px;
  }

  /* ========= Data callout ========= */
  .evo-ag__data {
    position: relative; z-index: 2;
    margin-top: clamp(48px, 6vw, 72px);
    padding: 28px clamp(24px, 3vw, 40px);
    border-radius: 20px;
    background:
      radial-gradient(800px 300px at 100% 50%, rgba(168,232,152,0.12), transparent 60%),
      linear-gradient(90deg, rgba(20,18,43,0.8) 0%, rgba(11,8,32,0.8) 100%);
    border: 1px dashed rgba(168,232,152,0.3);
    display: grid; grid-template-columns: auto 1fr auto; gap: 24px;
    align-items: center;
  }
  @media (max-width: 780px) {
    .evo-ag__data { grid-template-columns: 1fr; text-align: center; }
  }
  .evo-ag__data-icon {
    width: 56px; height: 56px; border-radius: 14px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(168,232,152,0.12);
    border: 1px solid rgba(168,232,152,0.3);
  }
  .evo-ag__data-icon svg { width: 28px; height: 28px; color: var(--mint); }
  @media (max-width: 780px) {
    .evo-ag__data-icon { margin: 0 auto; }
  }
  .evo-ag__data-title {
    font-family: var(--font-d); font-weight: 700;
    font-size: 20px; line-height: 1.2; color: #fff;
    margin: 0 0 6px 0;
  }
  .evo-ag__data-desc {
    color: var(--ink-dim); font-size: 14px; line-height: 1.55; margin: 0;
  }

  /* Caption */
  .zp-caption {
    position: fixed; top: 12px; left: 12px; z-index: 900;
    font-family: var(--font-m);
    font-size: 10px; letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink-muted);
    background: rgba(10,8,26,0.75);
    border: 1px solid var(--line);
    padding: 6px 12px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }

/* ---- FOOTER ---- */

  :root {
    --bg: #05040C; --bg-2: #0B0820;
    --ink: #FFFFFF; --ink-dim: #B6B5C6; --ink-muted: #7A7A8F;
    --mint: #A8E898; --peach: #FF7A4A;
    --line: rgba(255,255,255,0.08);
    --font-d: 'Clash Display','Satoshi','Inter',sans-serif;
    --font-s: 'Satoshi','Inter',system-ui,sans-serif;
    --font-m: 'JetBrains Mono',ui-monospace,monospace;
  }
  
  a { color: inherit; text-decoration: none; }
  .preview-caption {
    position: fixed; top: 12px; left: 12px; z-index: 900;
    font-family: var(--font-m); font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--ink-muted); background: rgba(10,8,26,0.75);
    border: 1px solid var(--line); padding: 6px 12px; border-radius: 999px;
    backdrop-filter: blur(6px);
  }
  .spacer { height: 60vh; display: flex; align-items: center; justify-content: center; color: var(--ink-muted); font-family: var(--font-m); font-size: 12px; letter-spacing: 0.2em; }

  .evo-ft {
    position: relative;
    background:
      radial-gradient(900px 400px at 10% 0%, rgba(61,46,222,0.12), transparent 55%),
      linear-gradient(180deg, #0A0820 0%, #05040C 100%);
    padding: 96px 0 24px;
    border-top: 1px solid var(--line);
  }
  .evo-ft__wrap { max-width: 1320px; margin: 0 auto; padding: 0 clamp(20px, 4vw, 48px); }
  .evo-ft__top {
    display: grid;
    grid-template-columns: 1.4fr 1.1fr 1fr 1fr 1fr;
    gap: clamp(28px, 3vw, 56px);
    align-items: start;
    margin-bottom: 40px;
  }
  @media (max-width: 1100px) { .evo-ft__top { grid-template-columns: 1fr 1fr 1fr; } .evo-ft__brand { grid-column: 1 / -1; } }
