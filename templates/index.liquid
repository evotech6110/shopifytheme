      {%- assign feat = collections.all.products.first -%}
    {%- endif -%}
    {%- assign feat_url = feat.url | default: '/pages/contact' -%}
    <div class="evo-feat">
      <!-- Featured hero card -->
      <article class="evo-feat__hero" aria-label="{{ feat.title | default: 'Featured product' | escape }}">
        <div class="evo-feat__hero-top">
          <div>
            <p class="evo-feat__kicker">{{ feat.type | default: 'HYBRID CLOUD STORAGE · 2-BAY NAS' | upcase }}</p>
            <h3 class="evo-feat__name"><a href="{{ feat_url }}" style="color:inherit;text-decoration:none;">{{ feat.title | default: 'Synology DS223/G' }}</a></h3>
            <p class="evo-feat__desc">{{ feat.description | default: "The ultimate control centre for your digital life. Enterprise-grade stability for home offices and small-business professionals across Perth." | strip_html | truncatewords: 32 }}</p>
          </div>
          <span class="evo-feat__badge evo-feat__badge--live">LIVE · GMC VERIFIED</span>
        </div>

        <a href="{{ feat_url }}" class="evo-feat__viz" style="display:block;text-decoration:none;" aria-label="View {{ feat.title | default: 'Synology DS223/G' | escape }}">
          {%- if feat.featured_image != blank -%}
