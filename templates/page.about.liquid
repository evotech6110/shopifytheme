{%- comment -%} About page — EvoTech Digital story, founder profile, credentials. Assign via Pages → Template picker. {%- endcomment -%}
{% render 'evotech-breadcrumbs' %}

<section class="evo-about">
  <header class="evo-about__head">
    <p class="evo-about__eyebrow">ABOUT EVOTECH DIGITAL</p>
    <h1 class="evo-about__title">Perth's trusted MSP — proactive IT, cyber security &amp; custom AI agents.</h1>
    <p class="evo-about__lede">EvoTech Digital is a Perth-based managed service provider helping Australian small and mid-size businesses run secure, modern IT. We design, deploy and support the full stack — from endpoint hardening and Essential 8 to Microsoft 365, cloud migration, and bespoke AI agents built on our in-house SaaS platform.</p>
  </header>

  <div class="evo-about__stats">
    <div class="evo-about__stat"><strong>600+</strong><span>Australian businesses supported</span></div>
    <div class="evo-about__stat"><strong>9 min</strong><span>Avg. ticket first-response</span></div>
    <div class="evo-about__stat"><strong>99.98%</strong><span>Managed uptime across client stack</span></div>
    <div class="evo-about__stat"><strong>6</strong><span>SaaS products in the EvoTech ecosystem</span></div>
  </div>

  <div class="evo-about__grid">
    <div class="evo-about__card evo-about__card--founder">
      <p class="evo-about__label">MEET THE FOUNDER</p>
      <h2 class="evo-about__card-title">Built by engineers who run the stack they sell.</h2>
      <p class="evo-about__person">Manoj Kumar <span>Founder &amp; Principal Engineer</span></p>
      <p class="evo-about__bio">Manoj founded EvoTech Digital in 2022 after a decade of running managed IT for Australian SMBs. Based in Perth, he leads product, architecture, and the team behind the EvoTech SaaS ecosystem — SentryOps, EvolveAI, ProcureIQ, Essential 8 Compass, vCIO Console and NetPulse.</p>
      <ul class="evo-about__creds">
        <li>Microsoft 365 Certified</li>
        <li>CompTIA Security+</li>
        <li>10+ years managed IT for Australian SMBs</li>
        <li>Speaker — AusCERT, WA CyberCon</li>
      </ul>
      <div class="evo-about__social">
        <a href="https://www.linkedin.com/in/evotech" rel="noopener noreferrer" target="_blank">LinkedIn →</a>
        <a href="https://github.com/evotech6110" rel="noopener noreferrer" target="_blank">GitHub →</a>
      </div>
    </div>

    <div class="evo-about__card">
      <p class="evo-about__label">OUR APPROACH</p>
      <h2 class="evo-about__card-title">Operational discipline. Security-first. Local accountability.</h2>
      <p class="evo-about__body">We run the same tooling we sell — our SentryOps SIEM, Essential 8 Compass, vCIO Console and NetPulse monitor every client tenant. When we recommend a control, it's because we already run it for ourselves.</p>
      <p class="evo-about__body">Every client gets a named engineer, documented runbooks, and a quarterly vCIO review. No ticket queues to the other side of the world — real people in Perth, answering in AWST business hours.</p>
    </div>

    <div class="evo-about__card">
      <p class="evo-about__label">WHAT WE DO</p>
      <h2 class="evo-about__card-title">Managed IT + cyber security + custom AI — under one roof.</h2>
      <ul class="evo-about__list">
        <li><strong>Managed IT Services</strong> — 24×7 monitoring, patching, endpoint support and helpdesk.</li>
        <li><strong>Cyber Security &amp; Essential 8</strong> — ACSC-aligned hardening, MFA, backups, incident response.</li>
        <li><strong>Cloud &amp; Microsoft 365</strong> — tenant design, migration, Intune, Entra ID, Defender.</li>
        <li><strong>vCIO / IT Consulting</strong> — quarterly roadmaps, budget planning, vendor management.</li>
        <li><strong>Custom AI Agents</strong> — bespoke agents on our EvolveAI Engine, tuned for your workflows.</li>
        <li><strong>Hardware procurement</strong> — enterprise gear sourced from authorised AU distributors.</li>
      </ul>
    </div>

    <div class="evo-about__card">
      <p class="evo-about__label">BUSINESS DETAILS</p>
      <h2 class="evo-about__card-title">Registered in Western Australia.</h2>
      <p class="evo-about__body"><strong>EvoTech Digital</strong><br>ABN 72 375 743 898<br>30 Tenterden Way, Gosnells, WA 6110<br>Mon–Fri · 9:00 AM – 5:00 PM AWST</p>
      <p class="evo-about__body"><a href="mailto:info@evotech.au">info@evotech.au</a> · <a href="tel:+61466911816">+61 466 911 816</a></p>
    </div>
  </div>

  {%- if page.content != blank -%}
    <div class="evo-about__extra rte">{{ page.content }}</div>
  {%- endif -%}

  <div class="evo-about__cta">
    <div>
      <p class="evo-about__label">LET'S BUILD</p>
      <h2 class="evo-about__cta-title">Work with us.</h2>
      <p class="evo-about__cta-lede">From a single SaaS app to a full managed IT transformation — talk to a specialist today.</p>
    </div>
    <div class="evo-about__cta-btns">
      <a class="evo-about__btn evo-about__btn--primary" href="/pages/contact">Book a 20-min call</a>
      <a class="evo-about__btn evo-about__btn--ghost" href="/pages/solutions">Browse Solutions</a>
    </div>
  </div>
</section>

<style>
  .evo-about { max-width: 1200px; margin: 0 auto; padding: 48px 24px 120px; color: #FFFFFF; font-family: 'Satoshi', system-ui, sans-serif; }
  .evo-about__head { max-width: 820px; margin: 0 0 40px; }
  .evo-about__eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .22em; color: #A8E898; margin: 0 0 12px; }
  .evo-about__title { font-family: 'Clash Display', sans-serif; font-size: clamp(32px, 5vw, 56px); line-height: 1.05; letter-spacing: -0.02em; margin: 0 0 16px; }
  .evo-about__lede { color: #B6B5C6; font-size: 17px; line-height: 1.65; margin: 0; }

  .evo-about__stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 14px; margin: 36px 0 48px; }
  .evo-about__stat { background: #0B0820; border: 1px solid rgba(255,255,255,.08); border-radius: 14px; padding: 20px 22px; }
  .evo-about__stat strong { display: block; font-family: 'Clash Display', sans-serif; font-size: 28px; color: #A8E898; margin-bottom: 6px; }
  .evo-about__stat span { color: #B6B5C6; font-size: 13px; line-height: 1.4; }

  .evo-about__grid { display: grid; grid-template-columns: 1fr; gap: 20px; }
  @media (min-width: 860px) { .evo-about__grid { grid-template-columns: 1fr 1fr; } .evo-about__card--founder { grid-column: 1 / -1; } }
  .evo-about__card { background: #0B0820; border: 1px solid rgba(255,255,255,.08); border-radius: 18px; padding: 32px 30px; }
  .evo-about__label { font-family: 'JetBrains Mono', monospace; font-size: 11px; letter-spacing: .22em; color: #A8E898; margin: 0 0 12px; }
  .evo-about__card-title { font-family: 'Clash Display', sans-serif; font-size: clamp(22px, 3vw, 30px); line-height: 1.15; margin: 0 0 14px; }
  .evo-about__body { color: #D8D7E3; font-size: 15px; line-height: 1.7; margin: 0 0 12px; }
  .evo-about__body a { color: #A8E898; text-decoration: none; border-bottom: 1px solid rgba(168,232,152,.3); }

  .evo-about__person { font-size: 16px; color: #FFFFFF; margin: 6px 0 14px; }
  .evo-about__person span { display: block; color: #B6B5C6; font-size: 13.5px; margin-top: 2px; }
  .evo-about__bio { color: #D8D7E3; font-size: 15px; line-height: 1.7; margin: 0 0 18px; }
  .evo-about__creds { list-style: none; padding: 0; margin: 0 0 18px; display: grid; grid-template-columns: repeat(auto-fill, minmax(220px,1fr)); gap: 10px; }
  .evo-about__creds li { background: rgba(168,232,152,.08); border: 1px solid rgba(168,232,152,.25); color: #D8F2C9; padding: 8px 12px; border-radius: 999px; font-size: 13px; font-family: 'JetBrains Mono', monospace; letter-spacing: .03em; text-align: center; }
  .evo-about__social a { display: inline-block; margin-right: 16px; color: #A8E898; font-family: 'JetBrains Mono', monospace; font-size: 13px; text-decoration: none; letter-spacing: .06em; }

  .evo-about__list { list-style: none; padding: 0; margin: 0; }
  .evo-about__list li { padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,.06); color: #D8D7E3; font-size: 15px; line-height: 1.55; }
  .evo-about__list li:last-child { border-bottom: 0; }
  .evo-about__list strong { color: #FFFFFF; }

  .evo-about__extra { margin-top: 48px; color: #D8D7E3; font-size: 16px; line-height: 1.7; }
  .evo-about__extra a { color: #A8E898; }

  .evo-about__cta { margin-top: 48px; background: linear-gradient(135deg, #0B0820, #1a0f2e); border: 1px solid rgba(168,232,152,.2); border-radius: 22px; padding: 40px; display: grid; grid-template-columns: 1fr; gap: 24px; align-items: center; }
  @media (min-width: 760px) { .evo-about__cta { grid-template-columns: 1.4fr 1fr; } }
  .evo-about__cta-title { font-family: 'Clash Display', sans-serif; font-size: clamp(26px, 4vw, 38px); margin: 6px 0 10px; }
  .evo-about__cta-lede { color: #B6B5C6; font-size: 15.5px; margin: 0; line-height: 1.55; }
  .evo-about__cta-btns { display: flex; flex-wrap: wrap; gap: 12px; justify-content: flex-start; }
  @media (min-width: 760px) { .evo-about__cta-btns { justify-content: flex-end; } }
  .evo-about__btn { display: inline-block; padding: 14px 24px; border-radius: 999px; font-weight: 700; font-size: 14.5px; text-decoration: none; font-family: inherit; }
  .evo-about__btn--primary { background: #FF7A4A; color: #0A0A0A; }
  .evo-about__btn--primary:hover { background: #ff9068; }
  .evo-about__btn--ghost { color: #FFFFFF; border: 1px solid rgba(255,255,255,.25); }
  .evo-about__btn--ghost:hover { border-color: #A8E898; color: #A8E898; }
</style>
