<script>
  (function(){
    var mainMedia = document.querySelector('[data-evo-main-media]');
    var thumbs = document.querySelectorAll('[data-evo-thumb]');
    if (mainMedia && thumbs.length) {
      thumbs.forEach(function(btn){
        btn.addEventListener('click', function(){
          var src = btn.getAttribute('data-src');
          var img = mainMedia.querySelector('img');
          if (img) { img.src = src; img.srcset = ''; }
        });
      });
    }
    var variantSelect = document.querySelector('.evo-product__variant-select');
    var optionSelects = document.querySelectorAll('.evo-product__option-select');
    if (variantSelect && optionSelects.length) {
      optionSelects.forEach(function(sel){
        sel.addEventListener('change', function(){
          var chosen = Array.prototype.map.call(optionSelects, function(s){ return s.value; });
          Array.prototype.forEach.call(variantSelect.options, function(opt){
            if (opt.textContent.split(' — ')[0].trim() === chosen.join(' / ')) { variantSelect.value = opt.value; }
          });
        });
      });
    }
  })();
</script>
