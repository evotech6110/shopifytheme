{% comment %}
  EvoTech Expert Mastery Landing Page
  Trust-pivot: Focus on deep IT expertise and architecture knowledge.
  Features: Profile, Gap Analysis, Tech Timeline, FAQ, and Rich JSON-LD.
{% endcomment %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Deep IT Expertise | EvoTech Digital Australia</title>
  <style>
    :root {
      --primary: #008060;
      --navy: #0f172a;
      --slate: #64748b;
      --bg: #ffffff;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      line-height: 1.6;
      color: var(--navy);
      margin: 0;
      padding: 0;
    }

    .mastery-hero {
      background: var(--navy);
      color: #fff;
      padding: 100px 20px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .mastery-hero h1 {
      font-size: 56px;
      font-weight: 900;
      margin-bottom: 20px;
      line-height: 1.1;
    }

    .mastery-hero p {
      font-size: 20px;
      color: var(--slate);
      max-width: 800px;
      margin: 0 auto;
    }

    .section-container {
      max-width: 1200px;
      margin: 80px auto;
      padding: 0 20px;
    }

    .grid-2 {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 60px;
      align-items: center;
    }

    .expertise-card {
      background: #f8fafc;
      padding: 40px;
      border-radius: 20px;
      border: 1px solid #e2e8f0;
    }

    .expertise-card h2 {
      color: var(--primary);
      text-transform: uppercase;
      font-size: 14px;
      letter-spacing: 0.1em;
      margin-bottom: 10px;
    }

    .timeline {
      border-left: 2px solid var(--primary);
      padding-left: 30px;
      margin-top: 40px;
    }

    .timeline-item {
      position: relative;
      margin-bottom: 40px;
    }

    .timeline-item::before {
      content: '';
      position: absolute;
      left: -37px;
      top: 5px;
      width: 12px;
      height: 12px;
      background: var(--primary);
      border-radius: 50%;
    }

    .timeline-year { font-weight: 800; color: var(--primary); }
    .timeline-title { font-weight: 700; font-size: 18px; margin: 5px 0; }
    .timeline-desc { font-size: 14px; color: var(--slate); }

    .gap-banner {
      background: var(--primary);
      color: #fff;
      padding: 60px;
      border-radius: 30px;
      text-align: center;
      margin: 100px auto;
    }

    .gap-banner h2 { font-size: 36px; font-weight: 800; }

    .faq-container { margin-top: 60px; }
    .faq-item { border-bottom: 1px solid #e2e8f0; padding: 20px 0; }
    .faq-q { font-weight: 700; font-size: 18px; color: var(--navy); cursor: pointer; }
    .faq-a { color: var(--slate); margin-top: 10px; display: block; font-size: 15px; }

    /* --- Visionary Badge --- */
    .authority-badge {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      background: rgba(0, 128, 96, 0.1);
      color: var(--primary);
      padding: 8px 16px;
      border-radius: 50px;
      font-weight: 700;
      font-size: 13px;
      margin-bottom: 30px;
    }

    @media (max-width: 768px) {
      .grid-2 { grid-template-columns: 1fr; }
      .mastery-hero h1 { font-size: 36px; }
    }
  </style>

  <!-- JSON-LD SEO Schema -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "mainEntity": {
      "@type": "Organization",
      "name": "EvoTech Digital Australia",
      "description": "Enterprise IT Architecture and Infrastructure Mastery. Bridging the gap between hardware delivery and technical execution.",
      "knowsAbout": ["IT Infrastructure", "AI Node Clusters", "Networking Architecture", "Sovereign Data Storage"],
      "logo": "https://www.evotech.au/logo.png"
    }
  }
  </script>
</head>
<body>

<section class="mastery-hero">
  <div class="authority-badge">
    🛡️ Architecture Verified Excellence
  </div>
  <h1>Expertise Over Delivery.</h1>
  <p>At EvoTech, we don't just ship boxes. We architect the sovereign infrastructure that powers the future. Our trust is built on a decade of deep technical mastery.</p>
</section>

<div class="section-container">
  <div class="grid-2">
    <div>
      <div class="expertise-card">
        <h2>Expert Knowledge</h2>
        <h3 style="font-size: 28px; font-weight: 800; margin: 10px 0;">The Technical Advantage</h3>
        <p>In a world of generic drop-shippers, EvoTech fills the <strong>Expertise Gap</strong>. We select hardware based on latency, thermal efficiency, and node compatibility—not just margin. When you buy from us, you are buying a piece of verified infrastructure.</p>
      </div>
    </div>
    <div class="timeline">
      <div class="timeline-item">
        <div class="timeline-year">Legacy Era</div>
        <div class="timeline-title">Core Infrastructure Mastery</div>
        <div class="timeline-desc">Mastering enterprise networking and storage fundamentals long before the cloud era.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-year">Cloud Pivot</div>
        <div class="timeline-title">Hybrid Integration</div>
        <div class="timeline-desc">Bridging local performance with global accessibility for seamless IT distribution.</div>
      </div>
      <div class="timeline-item">
        <div class="timeline-year">Now: AI Future</div>
        <div class="timeline-title">Sovereign Node Clusters</div>
        <div class="timeline-desc">Architecting distributed AI processing nodes for true data sovereignty.</div>
      </div>
    </div>
  </div>
</div>

<div class="section-container">
  <div class="gap-banner">
    <h2>Filling the Retail Gap</h2>
    <p style="font-size: 18px; max-width: 700px; margin: 20px auto;">Most retailers focus on the transaction. We focus on the implementation. Our consultants are available for complex hardware verification to ensure your build works the first time.</p>
  </div>
</div>

<div class="section-container">
  <h2 style="font-size: 32px; font-weight: 800;">Expertise FAQ</h2>
  <div class="faq-container">
    <div class="faq-item">
      <div class="faq-q">Why choose EvoTech for infrastructure hardware?</div>
      <div class="faq-a">Unlike generic marketplaces, every SKU in our catalog is architecturally vetted. We understand the compatibility requirements of AI clusters and enterprise storage nodes.</div>
    </div>
    <div class="faq-item">
      <div class="faq-q">Do you provide post-sale technical support?</div>
      <div class="faq-a">Yes. We offer architecture-level consultations to ensure your hardware is configured for maximum performance and 99.9% uptime.</div>
    </div>
  </div>
</div>

<div style="text-align: center; margin-bottom: 100px;">
  <a href="/pages/contact" style="background: var(--navy); color: #fff; padding: 20px 40px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 18px;">Book a Technical Audit</a>
</div>

</body>
</html>
