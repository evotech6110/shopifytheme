{%- comment -%} Password page — shown when storefront is password-protected {%- endcomment -%}
<section class="evo-pw">
  <div class="evo-pw__card">
    <p class="evo-pw__eyebrow">{{ shop.name | upcase }} · COMING SOON</p>
    <h1 class="evo-pw__title">Something evolved is on the way.</h1>
    <p class="evo-pw__lede">We're putting the finishing touches on the store. Enter the password to take a peek.</p>

    {%- form 'storefront_password', class: 'evo-pw__form' -%}
      {%- if form.errors -%}
        <p class="evo-pw__error">{{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}</p>
      {%- endif -%}
      <input class="evo-pw__input" type="password" name="password" placeholder="Password" required>
      <button class="evo-pw__submit" type="submit">Enter</button>
    {%- endform -%}

    <p class="evo-pw__contact">
      Questions? <a href="mailto:info@evotech.au">info@evotech.au</a>
    </p>
  </div>

  <footer class="evo-pw__foot">
    <p>© {{ 'now' | date: '%Y' }} EvoTech Digital · ABN 72 375 743 898</p>
  </footer>
</section>

<style>
  html, body { margin: 0; padding: 0; }
  .evo-pw { min-height: 100vh; display: grid; place-items: center; padding: 40px 24px; background: radial-gradient(1200px 600px at 50% -10%, rgba(61,46,222,.22), transparent), #05040C; color: #FFFFFF; font-family: 'Satoshi', system-ui, sans-serif; text-align: center; }
  .evo-pw__card { max-width: 520px; width: 100%; background: rgba(255,255,255,.03); border: 1px solid rgba(255,255,255,.08); border-radius: 20px; padding: 48px 36px; backdrop-filter: blur(20px); }
  .evo-pw__eyebrow { font-family: 'JetBrains Mono', monospace; font-size: 12px; letter-spacing: .22em; color: #A8E898; margin: 0 0 18px; }
  .evo-pw__title { font-family: 'Clash Display', sans-serif; font-size: clamp(30px, 5vw, 44px); line-height: 1.1; letter-spacing: -0.02em; margin: 0 0 14px; }
  .evo-pw__lede { color: #B6B5C6; font-size: 15px; line-height: 1.6; margin: 0 0 28px; }
  .evo-pw__form { display: flex; gap: 8px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); border-radius: 12px; padding: 6px; margin-bottom: 18px; }
  .evo-pw__input { flex: 1; background: transparent; border: 0; color: #FFFFFF; padding: 12px 14px; font-size: 15px; outline: none; font-family: inherit; }
  .evo-pw__input::placeholder { color: #B6B5C6; }
  .evo-pw__submit { background: #FF7A4A; color: #0A0A0A; border: 0; border-radius: 8px; padding: 0 22px; font-weight: 700; cursor: pointer; font-family: inherit; }
  .evo-pw__error { color: #FF7A4A; font-size: 13px; margin: 0 0 10px; }
  .evo-pw__contact { color: #B6B5C6; font-size: 13px; margin: 0; }
  .evo-pw__contact a { color: #A8E898; }
  .evo-pw__foot { position: fixed; bottom: 16px; color: #B6B5C6; font-size: 12px; font-family: 'JetBrains Mono', monospace; letter-spacing: .06em; }
  .evo-pw__foot p { margin: 0; }
</style>
