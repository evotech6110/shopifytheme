<script>
  document.querySelectorAll('.evo-faq__question').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.evo-faq__item');
      var isOpen = item.classList.contains('is-open');
      document.querySelectorAll('.evo-faq__item').forEach(function(i) {
        i.classList.remove('is-open');
        i.querySelector('.evo-faq__question').setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>

