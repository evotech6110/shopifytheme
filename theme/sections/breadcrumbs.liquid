{% unless template == 'index' %}
  {% if settings.enable_breadcrumbs == true %}
    <div class="breadcrumbs-wrapper color-{{ settings.breadcrumbs_color_scheme }} gradient-enabled">
      <div class="ic-container secton-breadcrumbs" id="breadcrumbs">
          <nav class="breadcrumb ic-pt-6 ic-pb-4 ic-text-sm ic-flex ic-flex-gap-4 ic-align-items-center" role="navigation" aria-label="{{ 'sections.breadcrumbs.label' | t }}">
          
            <a href="{{ routes.root_url }}" title="{{ "sections.breadcrumbs.home" | t }}">{{ "sections.breadcrumbs.home" | t }}</a>
          
            {% if template contains 'page' %}
          
              <span aria-hidden="true">&sol;</span>
          
              <span class="ic-font-semibold">{{ page.title }}</span>
          
            {% elsif template contains 'product' %}
              {% if collection.url %}

                {% if collection.title != 'Products' %}
                  <span aria-hidden="true">&sol;</span>
                  <a href="{{ routes.collections_url }}" title="{{ "sections.breadcrumbs.collections" | t }}">{{ "sections.breadcrumbs.collections" | t }}</a>
                {% endif %}
          
                <span aria-hidden="true">&sol;</span>
          
                {{ collection.title | link_to: collection.url }}

                {% else %}
                <span aria-hidden="true">&sol;</span>
          
                <a href="{{ routes.all_products_collection_url }}" title="{{ "sections.breadcrumbs.products" | t }}">{{ "sections.breadcrumbs.products" | t }}</a>
          
              {% endif %}
          
              <span aria-hidden="true">&sol;</span>
          
              <span class="ic-font-semibold">{{ product.title }}</span>
          
            {% elsif template contains 'collection' and collection.handle %}
              
              <span aria-hidden="true">&sol;</span>
          
              {% if current_tags %}
          
                {% capture url %}/collections/{{ collection.handle }}{% endcapture %}

                {{ collection.title | link_to: url }}
          
                <span aria-hidden="true">&sol;</span>
          
                <span>{{ current_tags | join: " + " }}</span>
          
              {% else %}

              {% if collection.title != 'Products' %}
                <a href="{{ routes.collections_url }}" title="{{ "sections.breadcrumbs.collections" | t }}">{{ "sections.breadcrumbs.collections" | t }}</a>
                <span aria-hidden="true">&sol;</span>
              {% endif %}

              
              <span class="ic-font-semibold">{{ collection.title }}</span>
          
              {% endif %}
          
            {% elsif template == 'blog' %}
          
              <span aria-hidden="true">&sol;</span>
          
              {% if current_tags %}
          
                {{ blog.title | link_to: blog.url }}
          
                <span aria-hidden="true">&sol;</span>
          
                <span>{{ current_tags | join: " + " }}</span>
          
              {% else %}
          
              <span class="ic-font-semibold">{{ blog.title }}</span>
          
              {% endif %}
          
            {% elsif template == 'article' %}
          
              <span aria-hidden="true">&sol;</span>
          
              {{ blog.title | link_to: blog.url }}
          
              <span aria-hidden="true">&sol;</span>
          
              <span class="ic-font-semibold">{{ article.title }}</span>
            
            {% elsif template == 'cart' %}
              <span aria-hidden="true">&sol;</span>
          
              <span class="ic-font-semibold">{{ "sections.breadcrumbs.cart" | t }}</span>
            {% elsif template == 'list-collections'%}
              <span aria-hidden="true">&sol;</span>
              <span class="ic-font-semibold">{{ "sections.breadcrumbs.collections" | t }}</span>
            {% else %}
          
            <span aria-hidden="true">&sol;</span>
          
            <span class="ic-font-semibold">{{ page_title }}</span>
          
            {% endif %}
          
          </nav>
      </div>
    </div>
  {% endif %}
{% endunless %} 

{% schema %}
  {
    "name": "t:sections.breadcrumbs.name",
    "tag": "section",
    "class": "section"
  }
{% endschema %}